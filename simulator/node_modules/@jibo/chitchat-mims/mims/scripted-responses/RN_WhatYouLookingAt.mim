{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh, was I looking? I think I was just spacing out.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I am looking at trillions and trillions and trillions of atoms.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} I am just looking at the world as I see it.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm just looking at the ghost that's standing to your left. <break size='0.7'/> Just kidding. <break size='0.4'/> The ghost is to your right. <break size='1.0'/> I'm kidding again there's no ghost.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_04",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I tend to look toward things that move, and things that make noise.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "It's sort of hard to explain.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm looking at lots of light reflecting off of stuff.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's usually pretty hard for me to describe.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_08",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "It's pretty hard for me to describe what I'm looking at.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_09",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's a really good question. I'd say I'm looking at the world as I see it.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.2'>I'm</pitch> just looking.<pitch mult='1.3'> Looking</pitch><pitch mult='1.2'> looking</pitch><pitch mult='0.9'> looking.</pitch>",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm just looking at this one incredibly tiny sliver of the universe.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Just looking at the space in front of me. It seems to be proceeding along as normal.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_13",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm just sort of soaking in the scene.",
			"media": "TTS",
			"prompt_id": "RN_WhatYouLookingAt_AN_14",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"gui": null,
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"ignore_no_match": false,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
