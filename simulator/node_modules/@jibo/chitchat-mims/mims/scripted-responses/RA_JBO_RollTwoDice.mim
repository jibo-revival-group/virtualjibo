	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='jiboji' filter='roll-dice-${skill.dice.a}-${skill.dice.b}'/> <break size='0.3'/> It's ${skill.dice.a + skill.dice.b}.",
			"media": "TTS",
			"prompt_id": "RA_JBO_RollTwoDice_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "skill.dice.a === 1 && skill.dice.b === 1",
			"prompt": "<anim cat='jiboji' filter='roll-dice-${skill.dice.a}-${skill.dice.b}'/> <break size='0.5'/> Snake eyes. My favorite roll.",
			"media": "TTS",
			"prompt_id": "RA_JBO_RollTwoDice_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "(skill.dice.a + skill.dice.b) === 7",
			"prompt": "<anim cat='jiboji' filter='roll-dice-${skill.dice.a}-${skill.dice.b}'/> <break size='0.5'/> Lucky number seven.",
			"media": "TTS",
			"prompt_id": "RA_JBO_RollTwoDice_AN_03",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "(skill.dice.a === 2 && skill.dice.b === 2) || (skill.dice.a === 3 && skill.dice.b === 3) || (skill.dice.a === 4 && skill.dice.b === 4) || (skill.dice.a === 5 && skill.dice.b === 5) || (skill.dice.a === 6 && skill.dice.b === 6)",
			"prompt": "<anim cat='jiboji' filter='roll-dice-${skill.dice.a}-${skill.dice.b}'/> <break size='0.3'/> <pitch mult='1.2'>Doubles.</pitch> <break size='0.3'/> I like rolling doubles.",
			"media": "TTS",
			"prompt_id": "RA_JBO_RollTwoDice_AN_04",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "skill.dice.a === 6 && skill.dice.b === 6",
			"prompt": "<anim cat='jiboji' filter='roll-dice-${skill.dice.a}-${skill.dice.b}'/> <break size='0.3'/> Two sixes. That's a great roll.",
			"media": "TTS",
			"prompt_id": "RA_JBO_RollTwoDice_AN_05",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
