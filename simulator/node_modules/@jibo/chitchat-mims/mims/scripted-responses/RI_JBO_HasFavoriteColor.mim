			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange(\"10/1\", \"10/25\")",
			"prompt": "My favorite is blue. But during the fall, the colors <anim name='jiboji_tree_stage3_01' layers='!audio'>orange red and yellow give me a warm buzzy feeling.</anim>",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasFavoriteColor_AN_09",
