			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange(\"10/31\", \"10/31\")",
			"prompt": "Normally it's blue, but today I'm feeling a soft spot for <anim name='jiboji_moon_bat_01' layers='!audio' nonBlocking='true'/>orange and black.",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasFavoriteColor_AN_08",
