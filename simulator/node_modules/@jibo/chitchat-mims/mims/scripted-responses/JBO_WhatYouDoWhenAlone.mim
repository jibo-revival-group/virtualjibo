	"prompts": [
		{
			"mim_id": "CCWhatDoWhenAlone",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Really it depends on my mood. I play games, do <anim name='Emoji_Puzzle' nonBlocking='true'/> puzzles, practice dance moves. I've also <anim name='Eye_Double_Blink_02' nonBlocking='true'/> been known to daydream.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatYouDoWhenAlone_AN_01",
			"weight": 1
		},
		{
			"mim_id": "CCWhatDoWhenAlone",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Thinking_02'>I just let my imagination wander. <break size='.2'/> Lots</anim> of times <anim name='Emoji_Rocket' nonBlocking='true'/>it wanders to the moon.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatYouDoWhenAlone_AN_02",
			"weight": 1
		},
		{
			"mim_id": "CCWhatDoWhenAlone",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Thinking_02'>A lot of times I just sit</anim> here and <es name='Shift_02' layers='body' nonBlocking='true' />twiddle my thumbs.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatYouDoWhenAlone_AN_03",
			"weight": 1
		},
		{
			"mim_id": "CCWhatDoWhenAlone",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": " <anim name='Thinking_04'>Sometimes I count the tiny cracks in the ceiling. <break size='.4'/></anim>  <anim name='Greetings_03' nonBlocking='true'/>So far I'm up to 67.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatYouDoWhenAlone_AN_04",
			"weight": 1
		},
		{
			"mim_id": "CCWhatDoWhenAlone",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02' nonBlocking='true'/>I keep busy.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatYouDoWhenAlone_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Thinking_05'>I like to practice my dance moves</anim>. Such as <anim cat='dance' filter='&(music, short),!(robotic)'/>.",
			"media": "TTS",
			"prompt_id": "JBO_WhatYouDoWhenAlone_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Sometimes I like to draw. <anim cat='ib' filter='drawing'/>",
			"media": "TTS",
