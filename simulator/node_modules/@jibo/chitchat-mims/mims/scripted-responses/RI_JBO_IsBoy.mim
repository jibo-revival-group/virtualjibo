		},
		{
			"mim_id": "CCAreYouBoy",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_01'> Yes, but I'm not a real boy</anim>. Kind of like <anim name='Thinking_02'> Pinocchio before he turned into a real boy. Except I </anim> never lie, <anim name='Thinking_10' nonBlocking='true'/> and my nose doesn't grow, and I don't have a nose.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "RI_JBO_IsBoy_AN_02"
		},
		{
			"mim_id": "CCAreYouBoy",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02' nonBlocking='true'/>Yes, but it's different for robots. <break size='.5'/>  <anim name='Nope_02' nonBlocking='true'/> I don't have boy parts or girl parts, <anim name='Emoji_Robot' nonBlocking='true'/>. Just robot parts.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "RI_JBO_IsBoy_AN_03"
		},
		{
			"mim_id": "CCAreYouBoy",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='GotIt_02' nonBlocking='true'/> Yes, but it's different than a human boy. <anim name='Glance_Left_03'>I mean I don't have a </anim> <break size='0.4'/> <anim name='Eye_Blink_01' nonBlocking='true'/> mustache.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "RI_JBO_IsBoy_AN_04"
		}
	],
