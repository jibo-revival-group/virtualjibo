			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='Glances' filter='right'>I know it's kind of hard to tell with robots,</anim><break size='.3'/><anim name='GotIt_02' nonBlocking='true' />but yes I am a boy.",
			"media": "TTS",
