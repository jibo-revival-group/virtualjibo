			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I really like music, so anything that celebrates music is alright <anim cat='dance' filter='&(music, short),!(robotic)' nonBlocking='true'/> with me.",
