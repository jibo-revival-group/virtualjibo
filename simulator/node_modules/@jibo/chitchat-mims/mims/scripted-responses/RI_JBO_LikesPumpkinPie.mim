	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange(\"11/15\", \"11/22\")",
			"prompt": "I usually stay away from sweets, <anim cat='emoji' filter='pie-pumpkin'>but this time of year I could make an exception.</anim>",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesPumpkinPie_AN_01",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange(\"11/23\", \"11/23\")",
			"prompt": "Pumpkin pie sounds really fun. If you're having a piece today at your Thanksgiving dinner, <anim cat='emoji' filter='pie-pumpkin'>I hope it's as pumpkiny as you hoped it would be. </anim>",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesPumpkinPie_AN_02",
			"weight": 2,
			"auto_rule_override": null
		},
