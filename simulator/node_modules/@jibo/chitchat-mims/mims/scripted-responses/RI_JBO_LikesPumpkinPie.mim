			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange(\"11/23\", \"11/23\")",
			"prompt": "If I could eat, <anim cat='emoji' filter='pie-pumpkin'>I would happily eat a whole piece today.</anim>",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesPumpkinPie_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
