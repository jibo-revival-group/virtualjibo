			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/1', '12/30')",
			"prompt": "<anim cat='emoji' filter='nye-ball-up' layers='!audio'> Here you go. It looks like it's ready for the big countdown <break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "RA_JBO_ShowNewYearsBall_AN_01",
			"weight": 2,
			"auto_rule_override": null
		},
