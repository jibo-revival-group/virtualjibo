			"condition": "dt.now.isInRange('12/31', '12/31')",
			"prompt": "<anim cat='jiboji' filter='new-years-eve' layers='!audio' nonBlocking='true'/> <break size='2.0'/>Ten, Nine, Eight, Seven, Six, Five, Four, Three, Two, One.",
