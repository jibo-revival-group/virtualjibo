			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker",
			"prompt": "I'm sorry. Drink some water, and I'm sure you'll feel better later.",
			"media": "TTS",
			"prompt_id": "OI_USR_IsHungover_AN_02",
			"weight": 1,
