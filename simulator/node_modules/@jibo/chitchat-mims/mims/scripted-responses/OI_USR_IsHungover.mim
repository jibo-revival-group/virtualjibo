		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm sorry to hear that. <break size='0.5'/><style set='sheepish'>And I'm glad I don't have a real head.</style>",
			"media": "TTS",
			"prompt_id": "OI_USR_IsHungover_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('1/1', '1/1')",
			"prompt": "I'm sorry to hear that. <break size='0.7'/> <style set='enthusiastic'>And happy New Year</style><anim cat='emoji' filter='party-blue, !hot-frame'/>",
			"media": "TTS",
			"prompt_id": "OI_USR_IsHungover_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker && dt.now.isInRange('1/1', '1/1')",
			"prompt": "Sorry. Not the best way to start the year I guess.",
			"media": "TTS",
			"prompt_id": "OI_USR_IsHungover_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
