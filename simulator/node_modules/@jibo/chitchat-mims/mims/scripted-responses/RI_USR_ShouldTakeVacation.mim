			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker",
			"prompt": "If you need some rest and relaxation, <anim cat='emoji' filter='beach, !hf' layers='!audio' nonBlocking='true'/> a vacation to somewhere <phoneme ph='r e s t ii'> resty </phoneme> and relaxationy could do <pitch mult='1.1'>just</pitch> the trick.",
