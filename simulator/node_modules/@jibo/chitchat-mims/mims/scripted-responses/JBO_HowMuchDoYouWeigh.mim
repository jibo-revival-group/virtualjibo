			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Emoji_Moon' nonBlocking='true'/> On the Moon I'd weigh 1.5 pounds, including my battery.",
			"media": "TTS",
			"extra": "",
