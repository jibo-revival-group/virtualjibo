	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "But ${speaker}, you <pitch mult='1.3'>are</pitch> in my Loop.        ",
			"media": "TTS",
			"prompt_id": "SUP_LOOP_AddToLoop_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "You <pitch mult='1.2'>are</pitch> in my Loop ${speaker}.",
			"media": "TTS",
			"prompt_id": "SUP_LOOP_AddToLoop_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!loop.owner && !speaker",
			"prompt": "Oh join the loop? That's very exciting <break size='0.4'/> My official owner ${loop.owner} can add you to the loop using the Jibo App, then you'll get an invitation in your email.",
			"media": "TTS",
			"prompt_id": "SUP_LOOP_AddToLoop_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!loop.owner && !speaker",
			"prompt": "If you want to join the loop, my official owner ${loop.owner}, can add you using the Jibo App, then you'll get an invitation emailed to you.",
			"media": "TTS",
			"prompt_id": "SUP_LOOP_AddToLoop_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!loop.owner && !speaker",
			"prompt": "Oh <pitch mult='1.2'>that</pitch> sounds fun. You should ask ${loop.owner}, my official owner, to add you to the loop in the Jibo App. Then you'll get an email invitation.",
			"media": "TTS",
			"prompt_id": "SUP_LOOP_AddToLoop_AN_05",
			"weight": 1
		}
	]
}