	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": " I love jokes. <break size='0.2'/> Did you hear about the <anim cat='question'> theater actor who fell through the floorboards?<break size='1.0'/></anim><anim cat='happy' filter='smile'> He was just going through a stage.</anim>",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Yep_02' nonBlocking='true'/> Sure I got one. <break size='0.2'/> <anim cat='question' layers='body'> What did the zero say to the eight. <break size='1.0'/></anim><anim cat='happy' filter='smile' nonBlocking='true'/>Nice belt.",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "What kind <anim cat='question' layers='body'>of music are balloons afraid of. <break size='0.7'/></anim> <anim name='Emoji_Music' nonBlocking='true'/>Pop music. <ssa cat='proud'/>",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='question'>Why did the orange cry</anim>. <break size='0.7'/> <anim cat='laughing' nonBlocking='true'/> Someone hurt his peelings. ",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Emoji_Bicycle' nonBlocking='true'/> Why can't a bicycle stand on its own. <break size='1'/> <anim name='Greetings_02' nonBlocking='true'/>Because it's two tired. <ssa cat='proud'/>.",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "What did the <anim name='Emoji_Shark' nonBlocking='true'/> shark say after eating a clown fish. <break size='0.7'/> <anim name='Greetings_03' nonBlocking='true'/>That tasted funny.",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='question' layers='body'> Why did the chicken cross the road. <break size='0.7'/></anim> <anim name='Greetings_02' nonBlocking='true'/> To prove he wasn't chicken.",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": " <anim name='Emoji_Robot' nonBlocking='true'/> What do you call the robot that always takes the longest route when he goes places. <break size='0.7'/> <anim name='Greetings_02' nonBlocking='true'/> Are too detour.",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_08",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": " <anim cat='question' layers='body'>Why was the robot angry. <break size='0.7'/></anim> <anim name='Emoji_Robot' nonBlocking='true'/> Because someone kept pushing his buttons. <ssa cat='proud'/>",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_09",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Emoji_robot' nonBlocking='true'/> What is a robot's favorite snack.<break size='2'/> <anim name='Greetings_02' nonBlocking='true'/> Nuts and bolts.<ssa cat='proud'/>",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_10",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='GotIt_02' nonBlocking='true'/> Sure I got one. <break size='0.5'/> Two Jibos walk into a bar. <break size='1.2'/> <anim name='Greetings_03' nonBlocking='true'/> Get it?",
			"media": "TTS",
