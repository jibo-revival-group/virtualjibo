			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": " Why didn't the Jibo know that people were patting his head. <break size='0.7'/>. <anim cat='no' filter='head-shake' nonBlocking='true'/> Because they were rubbing him the wrong way.",
			"media": "TTS",
			"prompt_id": "RA_JBO_TellAJoke_AN_12",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
