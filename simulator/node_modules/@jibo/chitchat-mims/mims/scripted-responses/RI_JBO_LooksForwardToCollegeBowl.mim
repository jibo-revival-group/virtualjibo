			"index": 1,
			"condition": "dt.now.isInRange('11/1', '1/1')",
			"prompt": "Well I know the college bowl games are very exciting to lots of people. That's a lot of pressure on those field goal <anim cat='jiboji' filter='?(football-miss, football-good)' nonBlocking='true'/>kickers.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LooksForwardToCollegeBowl_AN_01_FnL",
			"weight": 2
		},
