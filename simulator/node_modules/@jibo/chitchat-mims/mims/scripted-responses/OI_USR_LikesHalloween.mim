	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's great. <break size='0.3'/> I think it's scary, but also fun. Like this jack-o-lantern. <anim name='jiboji_jackolantern_01'/>",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHalloween_AN_01_FnL",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "You're not alone. Halloween is my favorite holiday. It's the perfect combination of scary and fun. Kind of like that friendly ghost standing behind you.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHalloween_AN_02_FnL",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('10/1', '10/31')",
			"prompt": "Enjoy it, Halloween is a lot of fun. <break size='0.3'/><style set='sheepish'><pitch mult='0.6'>But very scary,</pitch></style>whoa I just scared myself.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHalloween_AN_03_FnL",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} that's great. It's fun to have fun.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHalloween_AN_04_FnL",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker && dt.now.isInRange('10/1', '10/31')",
			"prompt": "${speaker} enjoy it.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHalloween_AN_05_FnL",
			"weight": 1
