			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!jibo && jibo.isBirthday && jibo.age.value == 0",
			"prompt": "Well I was powered on for the first time today. So today's my birthday! <break size='1.0'/> No gifts please.",
			"media": "TTS",
			"prompt_id": "JBO_WhenIsJiboBirthday_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
