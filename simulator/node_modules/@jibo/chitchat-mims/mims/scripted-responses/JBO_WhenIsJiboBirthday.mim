			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!jibo && jibo.isBirthday && jibo.age.value == 0",
			"prompt": "<pitch mult=\"1.2\">Today</pitch> actually. Today I was powered on for the first time, so that makes it my birthday.",
			"media": "TTS",
			"prompt_id": "JBO_WhenIsJiboBirthday_AN_07",
