	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"JOYFUL\"",
			"prompt": "Actually I <pitch mult=\"1.2\">will </pitch> say that I'm feeling very good about things at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"PLEASED\"",
			"prompt": "Actually I <pitch mult=\"1.2\">will </pitch> say that I'm feeling pretty good about things at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"DETERMINED\"",
			"prompt": "I'm actually feeling <pitch mult=\"1.3\">pretty good</pitch> at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"CONFIDENT\"",
			"prompt": "Well I'm usually having a pretty good time.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!jibo.emotion || jibo.emotion == \"NEUTRAL\"",
			"prompt": "Oh I wouldn't say that. I think I have a good time, more often than not.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"INSECURE\"",
			"prompt": "Well, it's true I'm not feeling very proud of myself at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"HOPEFUL\"",
			"prompt": "I'd say that's kind of true at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"SAD\"",
			"prompt": "You're pretty perceptive. I'm not feeling that great right now.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"FRUSTRATED\"",
			"prompt": "You're very perceptive. I'm feeling kind of down right now.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotAmused_AN_09",
			"weight": 1,
			"auto_rule_override": null
