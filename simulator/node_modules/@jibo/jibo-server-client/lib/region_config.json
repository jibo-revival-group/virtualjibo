{
  "rules": {
    "local/*": {
      "endpoint": "http://localhost:8080",
      "wsendpoint": "ws://localhost:8090"
    },
    "internal/*": {
      "endpoint": "http://security:8080",
      "wsendpoint": "ws://socket:8090"
    },
    "mock-region/*": {
      "endpoint": "{service}.{region}.api.jibo.com",
      "wsendpoint": "ws://socket:8090"
    },
    "*/*": "globalSSL"
  },

  "patterns": {
    "globalSSL": {
      "endpoint": "http://api.5x1.com:80",
      "wsendpoint": "ws://api.5x1.com:80",
      "globalEndpoint": true
    },
    "global": {
      "endpoint": "http://api.5x1.com:80",
      "wsendpoint": "ws://api.5x1.com:80",
      "globalEndpoint": true
    }
  }
}
