    "start": "ELECTRON_DISABLE_SANDBOX=1 electron . --no-sandbox",
    "be": "JIBO_CLOUD_HOST=http://api.5x1.com:80 JIBO_CLOUD_HOSTNAME=api.5x1.com JIBO_CLOUD_PORT=80 JetstreamSim_hubHost=api.5x1.com JetstreamSim_hubPort=80 ETCO_server_hubTokenSecret=your-hub-token-secret ELECTRON_DISABLE_SANDBOX=1 electron . --no-sandbox --path ../stuff/@be/be"
