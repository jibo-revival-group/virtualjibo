{
    "compilerOptions": {
        "target": "ES6",
        "allowJs": false,
        "module": "commonjs",
        "moduleResolution": "node",
        "noUnusedLocals": true,
        "experimentalDecorators": true,
        "typeRoots": [
            "../../node_modules/@types", "./node_modules/@types"
        ],
        "types": ["node", "pixi.js"]
    },
    "compileOnSave": false,
    "include": [
        "src/**/*.ts",
        "typings/index.d.ts",
        "../jibo/typings/index.d.ts"
    ]
}