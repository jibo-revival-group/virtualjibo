      "additionalProperties": false,
      "properties": {
        "LevelHeadFlag": {
          "description": "If `true`, Jibo will go to the closest possible kinematic\nposition to the requested position while requiring the display remain level. If `false`,\nJibo will go to the exact requested position, but the head may not be level.",
          "type": "boolean"
        },
        "LookAtTarget": {
          "$ref": "#/definitions/JIBO.v1.LookAtTarget"
        },
        "TrackFlag": {
          "description": "If `true`, Jibo will track the desired target. Note that for a position or angle\ntarget this will just hold Jibo steady.",
          "type": "boolean"
        },
        "Type": {
          "$ref": "#/definitions/JIBO.v1.Commands.LookAt"
        }
      },
      "required": [
        "LookAtTarget",
        "TrackFlag",
        "Type"
      ],
      "type": "object"
    },
