{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "additionalProperties": false,
  "definitions": {
    "JIBO.v1.AcknowledgementBody": {
      "additionalProperties": false,
      "description": "Response body.",
      "properties": {
        "ResponseCode": {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.ResponseCodeType"
        },
        "ResponseString": {
          "type": "string"
        },
        "Value": {
          "enum": [
            "Success",
            "Error"
          ],
          "type": "string"
        }
      },
      "required": [
        "Value",
        "ResponseCode",
        "ResponseString"
      ],
      "type": "object"
    },
    "JIBO.v1.AllAcknowlegements": {
      "anyOf": [
        {
          "$ref": "#/definitions/JIBO.v1.AcknowledgementBody"
        },
        {
          "$ref": "#/definitions/JIBO.v1.SessionResponse"
        },
        {
          "$ref": "#/definitions/JIBO.v1.CancelResponse"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ListenErrorResponse"
        },
        {
          "$ref": "#/definitions/JIBO.v1.LookAtErrorResponse"
        },
        {
          "$ref": "#/definitions/JIBO.v1.UnloadAssetResponse"
        }
      ]
    },
    "JIBO.v1.CancelResponse": {
      "additionalProperties": false,
      "description": "Reponse for the Cancel command.",
      "properties": {
        "ResponseBody": {
          "type": [
            "string",
            "null"
          ]
        },
        "ResponseCode": {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.ResponseCodeType"
        },
        "ResponseString": {
          "type": "string"
        },
        "Value": {
          "enum": [
            "Success",
            "Error"
          ],
          "type": "string"
        }
      },
      "required": [
        "ResponseBody",
        "ResponseCode",
        "ResponseString",
        "Value"
      ],
      "type": "object"
    },
    "JIBO.v1.ListenErrorResponse": {
      "additionalProperties": false,
      "properties": {
        "ErrorDetail": {
          "type": "string"
        },
        "ResponseCode": {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.ResponseCodeType"
        },
        "ResponseString": {
          "type": "string"
        },
        "Value": {
          "enum": [
            "Success",
            "Error"
          ],
          "type": "string"
        }
      },
      "required": [
        "ErrorDetail",
        "ResponseCode",
        "ResponseString",
        "Value"
      ],
      "type": "object"
    },
    "JIBO.v1.LookAtErrorResponse": {
      "additionalProperties": false,
      "properties": {
        "ErrorDetail": {
          "type": "string"
        },
        "ResponseCode": {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.ResponseCodeType"
        },
        "ResponseString": {
          "type": "string"
        },
        "Value": {
          "enum": [
            "Success",
            "Error"
          ],
          "type": "string"
        }
      },
      "required": [
        "ErrorDetail",
        "ResponseCode",
        "ResponseString",
        "Value"
      ],
      "type": "object"
    },
    "JIBO.v1.ResponseCodes.Accepted": {
      "description": "The command was accepted and will begin execution. Most asynchronous commands will get a this response ",
      "enum": [
        202
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.BadRequest": {
      "description": "Badly formatted request ",
      "enum": [
        400
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.Conflict": {
      "description": "There is a conflicting command already executing ",
      "enum": [
        409
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.Created": {
      "description": "The command was accepted and executed. Synchronous calls only ",
      "enum": [
        201
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.Forbidden": {
      "description": "The command request is not a supported command ",
      "enum": [
        403
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.InternalError": {
      "description": "The Controller has crashed or hit a different error that was unexpected ",
      "enum": [
        500
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.NotAcceptable": {
      "description": "The data in the command is not acceptable ",
      "enum": [
        406
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.NotFound": {
      "description": "Command not found ",
      "enum": [
        404
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.OK": {
      "description": "The command was accepted and executed. Synchronous calls only. ",
      "enum": [
        200
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.PreconditionFailed": {
      "description": "The execution of the command requires the execution of a prior command ",
      "enum": [
        412
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.RequestTimeout": {
      "description": "Unable to marshal the resources and set up the command within the time limits set in the Controller ",
      "enum": [
        407
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.ResponseCodeType": {
      "anyOf": [
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.OK"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.Created"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.Accepted"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.BadRequest"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.Forbidden"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.NotFound"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.NotAcceptable"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.RequestTimeout"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.Conflict"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.PreconditionFailed"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.InternalError"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.ServiceUnavailable"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.VersionNotSupported"
        },
        {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.VersionConflict"
        }
      ]
    },
    "JIBO.v1.ResponseCodes.ServiceUnavailable": {
      "description": "The Controller is temporarily unavailable. The Robot SSM may be rebooting something ",
      "enum": [
        503
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.VersionConflict": {
      "description": "The Version requested is not the same version of the current connection. ",
      "enum": [
        506
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseCodes.VersionNotSupported": {
      "description": "The Version requested is not supported ",
      "enum": [
        505
      ],
      "type": "number"
    },
    "JIBO.v1.ResponseHeader": {
      "additionalProperties": false,
      "properties": {
        "RobotID": {
          "pattern": "^[a-z]{3,15}-[a-z]{3,15}-[a-z]{3,15}-[a-z]{3,15}$",
          "type": "string"
        },
        "SessionID": {
          "description": "The session identifier that was assigned for this connection between the Server and Controller. ",
          "type": "string"
        },
        "TransactionID": {
          "$ref": "#/definitions/JIBO.v1.TransactionID"
        }
      },
      "required": [
        "RobotID",
        "SessionID",
        "TransactionID"
      ],
      "type": "object"
    },
    "JIBO.v1.SessionInfo": {
      "additionalProperties": false,
      "properties": {
        "SessionID": {
          "type": "string"
        },
        "Version": {
          "pattern": "^\\d+\\.\\d+$",
          "type": "string"
        }
      },
      "required": [
        "SessionID",
        "Version"
      ],
      "type": "object"
    },
    "JIBO.v1.SessionResponse": {
      "additionalProperties": false,
      "properties": {
        "ResponseBody": {
          "$ref": "#/definitions/JIBO.v1.SessionInfo"
        },
        "ResponseCode": {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.OK"
        },
        "ResponseString": {
          "type": "string"
        },
        "Value": {
          "enum": [
            "Success"
          ],
          "type": "string"
        }
      },
      "required": [
        "ResponseBody",
        "ResponseCode",
        "ResponseString",
        "Value"
      ],
      "type": "object"
    },
    "JIBO.v1.TransactionID": {
      "description": "128bit hexidecimal number that must be unique every transaction issued by the particular ROM\nServer.  The Command Library supplied by Jibo does a 128 bit hash on the Server IP address and\nthe current time.  Because this is a hash this ID cannot be treated as a sequence number for\nCommand serialization. Must be 32 characters long",
      "maxLength": 32,
      "minLength": 32,
      "type": "string"
    },
    "JIBO.v1.UnloadAssetResponse": {
      "additionalProperties": false,
      "properties": {
        "ErrorDetail": {
          "type": "string"
        },
        "ResponseCode": {
          "$ref": "#/definitions/JIBO.v1.ResponseCodes.ResponseCodeType"
        },
        "ResponseString": {
          "type": "string"
        },
        "Value": {
          "enum": [
            "Success",
            "Error"
          ],
          "type": "string"
        }
      },
      "required": [
        "ErrorDetail",
        "ResponseCode",
        "ResponseString",
        "Value"
      ],
      "type": "object"
    }
  },
  "properties": {
    "Response": {
      "$ref": "#/definitions/JIBO.v1.AllAcknowlegements"
    },
    "ResponseHeader": {
      "$ref": "#/definitions/JIBO.v1.ResponseHeader"
    }
  },
  "required": [
    "ResponseHeader",
    "Response"
  ],
  "type": "object"
}