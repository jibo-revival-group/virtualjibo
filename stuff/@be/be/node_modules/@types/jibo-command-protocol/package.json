{
  "name": "@types/jibo-command-protocol",
  "version": "2.7.0",
  "description": "Jibo Command Protocol Typings",
  "scripts": {
    "docs": "typedoc --excludeExternals --includeDeclarations --name \"Jibo Client Protocol\" --readme ./DOCS-README.md --hideGenerator --mode modules --target ES6 --out docs ./index.d.ts",
    "schema": "ts-json-schema-generator --path=./index.d.ts --type 'JIBO.v1.Command' --expose 'export' --topRef 'yes' --jsDoc 'extended' > ./commandSchema.json; ts-json-schema-generator --path=./index.d.ts --type 'JIBO.v1.Acknowledgement' --expose 'export' --topRef 'yes' --jsDoc 'extended' > ./acknowledgementSchema.json; ts-json-schema-generator --path=index.d.ts --type 'JIBO.v1.EventMessage' --expose 'export' --topRef 'yes' --jsDoc 'extended' > ./eventSchema.json"
  },
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:phoenix/jibo-command-protocol.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jibo/ts-json-schema-generator": "0.18.1",
    "typedoc": "^0.10.0"
  },
  "dependencies": {}
}
