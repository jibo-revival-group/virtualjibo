{
    "compilerOptions": {
        "target": "es6",
        "allowJs": false,
        "module": "commonjs",
        "moduleResolution": "node",
        "noUnusedLocals": true,
        "lib": ["es2016.array.include", "es6", "dom"],
        "experimentalDecorators": true,
        "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
        "types": ["node", "fs-extra", "os-homedir"]
    },
    "compileOnSave": false,
    "include": ["src/**/*.ts"]
}
