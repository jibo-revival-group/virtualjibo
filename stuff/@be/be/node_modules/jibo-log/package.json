    "lib",
    "index.d.ts"
  ],
  "author": "Jibo Inc. <info@jibo.com>",
  "maintainer": "Tim Garthwaite <tim.garthwaite@jibo.com>",
  "contributors": [
    "Jon Ferguson <jon.ferguson@jibo.com>",
    "Avida Michaud <avida.michaud@jibo.com>"
  ],
  "bugs": {
