	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"JOYFUL\"",
			"prompt": "Actually quite the opposite. I've never been better.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"PLEASED\"",
			"prompt": "I wouldn't say that at all. I'm feeling pretty sunshiny right now.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"DETERMINED\"",
			"prompt": "Oh. Actually I'm feeling pretty good at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"CONFIDENT\"",
			"prompt": "<pitch mult=\"1.3\">I </pitch>wouldn't say that. All systems are go.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!jibo.emotion || jibo.emotion == \"NEUTRAL\"",
			"prompt": "<pitch mult=\"1.3\">I </pitch>wouldn't say that. All systems are go.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"INSECURE\"",
			"prompt": "I'm actually feeling okay.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"HOPEFUL\"",
			"prompt": "<pitch band=\"0.6\">You're right, I'm not feeling at my best right now.</pitch> But I do think things can turn around.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"SAD\"",
			"prompt": "Honestly? <pitch band=\"0.5\">I've been better.</pitch>",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsNotHappy_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"FRUSTRATED\"",
			"prompt": "You're very perceptive.<pitch band=\"0.6\"> I'm feeling a little bit down in the dumps at the moment.</pitch>",
