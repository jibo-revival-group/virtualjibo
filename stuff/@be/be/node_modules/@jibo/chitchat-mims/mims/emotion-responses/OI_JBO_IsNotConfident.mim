			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"DETERMINED\"",
			"prompt": "Well I'm feeling pretty good, though I <pitch mult=\"1.3\">do </pitch>have to admit I'm not very impressed with my robot self right now.",
