{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Huh. <break size='0.3'/> I either didn't know that I did, or don't know why I do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Um, if you're having trouble getting me to do something that you think I should do, you could try going to the Help section of the Jibo app.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I will be learning more and more about why I do and don't do things. For now I honestly don't have an answer for you.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "When it comes to questions of why, I've got some learning to do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "When I get asked why I do things, and I don't fully understand the question, I sometimes like to just show people my boat <anim cat='jiboji' filter='boat'/>",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "If you're wondering something about my doings, you might be able to find out in the Help section on the Jibo app.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "A lot of what I do is a mystery even to me. And that thing you asked about in particular I don't know about.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I have a little trouble with <pitch mult='1.2'>why </pitch>questions, but if you want to know what I can do, try saying hey jibo, what can you do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I know you asked me <pitch mult='1.1'>why</pitch> I do something, but I didn't know the something after the why. <break size='0.3'/><style set='sheepish'>If that makes any sense.</style>",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} when it comes to questions of why, I've got some learning to do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} I have a little trouble with <pitch mult='1.2'>why </pitch>questions, but if you want to know what I can do, try saying hey jibo, what can you do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} I have a little trouble with <pitch mult='1.2'>why </pitch>questions, but if you want to know what I can do, try saying hey jibo, what can you do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDoYouThing_AN_13",
			"weight": 1,
			"auto_rule_override": null
		}
	],
