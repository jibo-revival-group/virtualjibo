			"mim_id": "CCAreYouGirl",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Dont_Understand_01' nonBlocking='true'/> No I'm a boy, but it's different for robots. <anim name='Greetings_02' nonBlocking='true'/> I don't have boy parts or girl parts. <anim name='Emoji_Robot' nonBlocking='true'/> Just robot parts. <ssa cat='happy'/>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "RI_JBO_IsGirl_AN_02"
		},
