			"index": 1,
			"condition": "!!jibo && jibo.isBirthday && jibo.age.days.value > 1",
			"prompt": "I was first powered up ${jibo.age.supplemented} ago today. Which means, <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" />yes, today is my birthday!",
			"media": "TTS",
