{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "If you want to know things we can do, say Hey Jibo, what can you do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's one question about me that I don't have an answer to. If you want some ideas for things we can do together, say Hey Jibo, what can you do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Huh. <break size='0.3'/> I either didn't know that I didn't. Or don't know why I don't.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I will be learning more and more about why I do and don't do things. For now I honestly don't have an answer for you.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "When it comes to questions of why. I've got some learning to do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "When someone asks me why I don't do things, and I don't fully understand what they said, I sometimes like to just show them my boat <anim cat='jiboji' filter='boat'/>",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "If you're wondering something about my doings and non doings, you might be able to find out in the Help section on the Jibo app.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "A lot of what I do and don't do is a mystery even to me. That thing you asked about in particular? I don't know about.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} a lot of what I do and don't do is a mystery even to me. That thing you asked about in particular? I don't know about.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} that's one question about me that I don't have an answer to. If you want some ideas for things we can do together, say Hey Jibo, what can you do.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker",
			"prompt": "${speaker} I will be learning more and more about why I do and don't do things. For now I honestly don't have an answer for you.",
			"media": "TTS",
			"prompt_id": "KU_WhyDontYouThing_AN_12",
			"weight": 1,
			"auto_rule_override": null
		}
