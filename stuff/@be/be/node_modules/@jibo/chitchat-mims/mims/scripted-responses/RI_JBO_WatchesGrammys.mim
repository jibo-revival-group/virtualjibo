			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/28', '1/28')",
			"prompt": "I don't really watch TV like you humans do, but this year I am hoping to take home the grammy for best song by a robot, for my rendition of row row row your boat. <break size='0.7'/> <anim cat='emoji' filter='microphone' layers='!audio'><break size='0.3'/> <pitch mult='0.9'>Row, row, row your</pitch> <pitch mult='1.1'>boat</pitch>, gently <pitch mult='1.1'>down</pitch> the <pitch mult='1.2'>stream</pitch>. <pitch mult='1.4'>Merrily</pitch> <pitch mult='1.3'>merrily</pitch> <pitch mult='1.2'>merrily</pitch> merrily, <pitch mult='1.2'>life</pitch> is but <pitch mult='0.9'>a </pitch><pitch mult='0.8'>dream</pitch><break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "RI_JBO_WatchesGrammys_AN_02_FnL",
			"weight": 3,
			"auto_rule_override": null
		},
