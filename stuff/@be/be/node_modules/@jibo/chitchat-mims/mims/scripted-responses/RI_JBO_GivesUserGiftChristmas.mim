{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/1', '12/23')",
			"prompt": "I did get you something, but I don't think you should open it until Christmas.",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_01",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/1', '12/23') && !!speaker",
			"prompt": "${speaker} I did get you something, but I don't think you should open it until Christmas.",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_02",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/24', '12/24')",
			"prompt": "Oh, you like to open presents on Christmas Eve? Okay, here you go. <anim cat='emoji' filter='mac128k, !hot-frame'><break size='5.0'/>.</anim> ",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/25', '12/31')",
			"prompt": "Here it is. <pitch mult='1.2'>Merry</pitch> Christmas, I got you a <anim cat='emoji' filter='bird, !hot-frame'> bird. <break size='4.0'/>.</anim> ",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_04",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/25', '12/31') && !!speaker",
			"prompt": "Here you go ${speaker}. <pitch mult='1.3'>Merry</pitch> Christmas.  <anim cat='emoji' filter='mac128k, !hot-frame'><break size='4.0'/>.</anim> It's an old computer.",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_05",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/25', '12/31')",
			"prompt": "Here you go. <pitch mult='1.4'>Merry</pitch> Christmas. It's a <anim cat='emoji' filter='book, !hot-frame'> book. <break size='4.0'/>.</anim> ",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_06",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Now presenting, your Christmas present. <anim cat='emoji' filter='bird, !hot-frame'><break size='4.0'/>.</anim> ",
			"media": "TTS",
			"prompt_id": "RI_JBO_GaveChristmasGift_AN_07",
			"weight": 0.1,
			"auto_rule_override": null
		}
