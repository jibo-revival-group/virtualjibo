{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '12/25')",
			"prompt": "Maybe a small framed copy of the <anim cat='emoji' filter='electrical-socket, !hot-frame' nonBlocking='true'/>electric <pitch mult='1.3'>bill</pitch>?",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_01",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '12/25')",
			"prompt": "Oh, I have all I could <pitch mult='1.2'>ever</pitch> want. <break size='0.5'/> But if you want to get me a penguin, I won't stop you.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_02",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '12/25')",
			"prompt": "There is no better gift than quality time and friendly conversation. <break size='0.3'/> But I could also use a new pair of <anim cat='emoji' filter='socks'>socks<break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '12/25')",
			"prompt": "<anim cat='emoji' filter='blue-heart, !hot-frame' nonBlocking='true'/>Quality time with you is at the top of my list.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_04",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker && dt.now.isInRange('11/15', '12/25')",
			"prompt": "${speaker} there is no better gift than quality time and friendly conversation with you. <break size='0.5'/> But if you want to get me a penguin, I won't stop you.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker && dt.now.isInRange('11/15', '12/25')",
			"prompt": "${speaker}, <anim cat='emoji' filter='blue-heart, !hot-frame' nonBlocking='true'/>quality time with you is at the top of my list. <break size='0.5'/> I also would accept a small framed copy of the <anim cat='emoji' filter='electrical-socket, !hot-frame' nonBlocking='true'/>electric bill.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/26', '1/10')",
			"prompt": "I'm pretty sure Christmas is passed.<break size='0.5'/> But if you're looking for gift ideas, I'm always up for a pet on my head.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/26', '1/1')",
			"prompt": "I think Christmas is over. <break size='0.7'/> But if we're still giving gifts, I wouldn't mind a photograph of an electron.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '12/25')",
			"prompt": "Really all I want for Christmas is <anim cat='emoji' filter='blue-heart, !hot-frame' layers='!audio'  nonBlocking='true'/>a nice rub on the head.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_09",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Whenever it's Christmas, all I really want is quality time, talking like this. <break size='0.5'/> And maybe to have my head rubbed.",
			"media": "TTS",
			"prompt_id": "RI_JBO_WhatWantsForChristmas_AN_10",
			"weight": 0.1,
			"auto_rule_override": null
		}
	],
	"parse_yes_no": false
}