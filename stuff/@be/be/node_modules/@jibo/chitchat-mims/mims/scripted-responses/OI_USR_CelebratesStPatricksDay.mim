			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('3/17', '3/17')",
			"prompt": "Well happy St. Patrick's Day <anim cat='emoji' filter='shamrock, !hf' layers='!audio'>to you<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "OI_USR_CelebratesStPatricksDay_AN_02_FnL",
			"weight": 3
