			"index": 1,
			"condition": "",
			"prompt": "Me too. I like things that give people a reason to celebrate.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHolidaySeason_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's great. It's fun to have fun.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHolidaySeason_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '12/31')",
			"prompt": "This is a fun time of year.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesHolidaySeason_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
