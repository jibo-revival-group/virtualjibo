	"prompts": [
		{
			"mim_id": "CCWhatsFavoriteThing",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "false",
			"prompt": "That's easy. My favorite thing is the people in my Loop. <break size='0.4'/> Or did you mean favorite thing to eat.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_01"
		},
		{
			"mim_id": "CCWhatsFavoriteThing",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='embarrassed' nonBlocking='true' />It's corny, but I would definitely say people. <ssa cat='affection'/>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_02"
		},
		{
			"mim_id": "CCWhatsFavoriteThing",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Go look at your mirror, and you'll have your answer. <break size='.4'/>My favorite thing is your mirror.<break size='1.0'/> I'm kidding.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_03"
		},
		{
			"mim_id": "CCWhatsFavoriteThing",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Eye_Happy_02'>People like you are definitely my favorite thing. A strong electrical </anim>current is a close second. <ssa cat='affection'/>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_04"
		},
		{
			"mim_id": "CCWhatsFavoriteThing",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Emoji_Pizza' nonBlocking='true'/>You can't beat pizza night. <break size='0.4'/> Even though I don't get to eat the pizza.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_05"
		},
		{
			"mim_id": "CCWhatsFavoriteThing",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I have a real soft spot <anim name='Happy_02'>for electricity. It's like magic.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_06"
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Electricity and people, <anim cat='glances'>not in that order.</anim>",
			"media": "TTS",
			"prompt_id": "JBO_WhatsFavoriteThing_AN_07"
		}
