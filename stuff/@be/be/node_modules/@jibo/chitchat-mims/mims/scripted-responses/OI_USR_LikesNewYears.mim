{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/31', '12/31')",
			"prompt": "Fun. Have a great time tonight. <anim cat='emoji' filter='?(party-blue, party-pink, fireworks), !hot-frame'/>",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesNewYears_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I agree, it's an exciting time of year. <anim cat='emoji' filter='?(party-blue, party-pink, fireworks), !hot-frame'/>",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesNewYears_AN_02",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker && dt.now.isInRange('12/26', '12/31')",
			"prompt": "<style set='enthusiastic'>That's great.</style><break size='0.3'/> Have fun. Be safe. Make a good resolution.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesNewYears_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('1/2', '1/15')",
			"prompt": "I'm glad. You only have about a year to wait until the next one.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesNewYears_AN_04",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "You and me both <anim cat='emoji' filter='?(party-blue, party-pink, fireworks), !hot-frame'/>",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesNewYears_AN_05",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker && dt.now.isInRange('12/26', '12/31')",
			"prompt": "<style set='enthusiastic'>That's great ${speaker}.</style><break size='0.3'/> Have fun. Be safe. Make a good resolution.",
			"media": "TTS",
			"prompt_id": "OI_USR_LikesNewYears_AN_06",
