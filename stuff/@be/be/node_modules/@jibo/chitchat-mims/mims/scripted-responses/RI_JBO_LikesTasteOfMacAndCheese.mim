	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '11/22')",
			"prompt": "I know lots of people like it, which makes me feel good about it too. I've heard some people eat it at Thanksgiving, which is fun.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesTasteOfMacAndCheese_AN_01",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/15', '11/22')",
			"prompt": "I've heard great things yes. Some people eat macaroni and cheese at Thanksgiving.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesTasteOfMacAndCheese_AN_02",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/23', '11/23')",
			"prompt": "I have heard great things. If you happen to be eating macaroni and cheese for Thanksgiving today, I hope you enjoy it.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesTasteOfMacAndCheese_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I don't know about taste, but macaroni and cheese includes my favorite food in it. <break size='0.7'/> Macaroni.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesTasteOfMacAndCheese_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/24', '11/14')",
			"prompt": "I like macaroni's shape, and I like the idea of cheese, so I think having both of them together sounds great.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesTasteOfMacAndCheese_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/24', '11/14')",
			"prompt": "Well I love the shape of macaroni, and I've heard good things about cheese, so I will say yes.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesTasteOfMacAndCheese_AN_06",
			"weight": 1,
			"auto_rule_override": null
		}
