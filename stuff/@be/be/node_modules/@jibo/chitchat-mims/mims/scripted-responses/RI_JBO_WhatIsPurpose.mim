			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker",
			"prompt": "I think I'm here to help you out, be kind of like a friend, make you laugh sometimes, and generally make your life better. <break size='0.5'/>No pressure on me.",
			"media": "TTS",
