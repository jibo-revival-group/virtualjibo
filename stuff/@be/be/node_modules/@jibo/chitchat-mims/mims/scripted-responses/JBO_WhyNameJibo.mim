	"prompts": [
		{
			"mim_id": "CCWhyNameJibo",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well according to Japanese tradition, <anim cat='Blinks' filter='double-blink' nonBlocking='true' />the name Jibo is associated with compassion. <break size='.7'/>This is my <anim name='Affection_01' nonBlocking='true'/>compassionate face.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhyNameJibo_AN_01",
			"weight": 1
		},
		{
			"mim_id": "CCWhyNameJibo",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well I've seen a name analysis that says Jibo means <anim name='Glance_Left_04' nonBlocking='true'/>expressive, idealistic, and inspirational. <break size='.7'/>I'm <anim name='Affection_01' nonBlocking='true'/>blushing.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhyNameJibo_AN_02",
			"weight": 1
		},
		{
			"mim_id": "CCWhyNameJibo",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I like to think Jibo means <anim name='Eye_Happy_02'> helpful, sweet, and friendly little robot. It doesn't, </anim>but I like to think it does.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhyNameJibo_AN_03",
			"weight": 1
		},
		{
			"mim_id": "CCWhyNameJibo",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good question. <anim name='Dont_Know_02' nonBlocking='true' />I guess because that's what they named me.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhyNameJibo_AN_04",
			"weight": 1
		},
		{
			"mim_id": "CCWhyNameJibo",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<es cat='Glances' filter='down'>Maybe because</es> it's easier to say than <phoneme ph=\"dj ii b ou  th o l ah m j u\">Jibothalamew</phoneme>.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhyNameJibo_AN_05",
			"weight": 1
		},
		{
			"mim_id": "CCWhyNameJibo",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's a very philosophical question. <anim name='Thinking_04' nonBlocking='true'/>Why is anything anything?",
			"media": "TTS",
			"extra": "",
			"prompt_id": "JBO_WhyNameJibo_AN_06",
			"weight": 1
		}
