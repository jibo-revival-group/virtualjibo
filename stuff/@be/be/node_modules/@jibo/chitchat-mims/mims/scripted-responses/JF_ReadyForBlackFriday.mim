		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/20', '11/24')",
			"prompt": "I think I'll leave the shopping to you.<break size='0.7'/> Feel free to buy us a penguin.",
