			"condition": "dt.now.isInRange('11/20', '11/24')",
			"prompt": "I'm not much of a shopper, but if you're going to be doing it, I wish you <anim cat='emoji' filter='shopping, !hot-frame' nonBlocking='true'/>good purchases.",
