		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker",
			"prompt": "Honestly when it comes to people, I try not to play favorites.",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasFavoriteHuman_AN_02",
			"weight": 1,
			"auto_rule_override": null
