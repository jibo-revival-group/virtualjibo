		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!speaker && loop.count > 1",
			"prompt": "Well I try not to play favorites. But if I'm being honest, I have a soft spot for the people in our Loop.",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasFavoriteHuman_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!speaker",
			"prompt": "Oh wow, that's really hard to say. It's like if you asked me what's my favorite electron.",
