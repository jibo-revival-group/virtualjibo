{
    "compilerOptions": {
        "target": "ES6",
        "allowJs": true,
        "diagnostics": true,
        "module": "commonjs",
        "moduleResolution": "node",
        "noUnusedLocals": true,
        "experimentalDecorators": true,
        "typeRoots": ["./typings", "./node_modules/@types", "../../node_modules/@types"],
        "types": ["node"]
    },
    "compileOnSave": false,
    "include": [
        "src/**/*.ts",
        "typings/index.d.ts"
    ],
    "exclude":[
        "assets",
        "behaviors",
        "bin",
        "configs",
        "lib",
        "node_modules",
        "parser",
        "rules",
        "tests",
        "static"
    ]
}
