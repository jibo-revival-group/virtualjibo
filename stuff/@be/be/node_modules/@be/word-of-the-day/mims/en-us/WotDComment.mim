	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'amazement'",
			"prompt": "It's <pitch mult='1.1'>true</pitch>!",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'amazement'",
			"prompt": "I know can you believe it?",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'amazement'",
			"prompt": "It's amazing but true.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'jiboMisheard'",
			"prompt": "Oops, my apologies.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'jiboMisheard'",
			"prompt": "I misunderstood, sorry.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'jiboMisheard'",
			"prompt": "I'm sorry, I thought you said something else.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'jiboMisheard'",
			"prompt": "Oh sorry, I heard you wrong.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'agreement'",
			"prompt": "I'm <pitch mult='1.1'>glad</pitch> we're in agreement.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'agreement'",
			"prompt": "We're <pitch mult='1.1'>on</pitch> the <pitch mult='1.1'>same </pitch> page.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'agreement'",
			"prompt": "Thank you.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'agreement'",
			"prompt": "I agree.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disagreement'",
			"prompt": "That's what they tell me at least.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_13",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disagreement'",
			"prompt": "Sorry, I don't make the definitions.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_14",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disagreement'",
			"prompt": "I just read the definitions, I don't make them up.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_15",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disagreement'",
			"prompt": "Sorry, that's what the definition fairy told me.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_16",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'celebration'",
			"prompt": "I <pitch mult='1.1'>never</pitch> doubted you for a second.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_17",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'celebration'",
			"prompt": "I'm really proud of you.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_18",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'celebration'",
			"prompt": "If I could pat you on the back I would.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_19",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'celebration'",
			"prompt": "You're the best.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_20",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disappointment'",
			"prompt": "Well now you know a new word.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_21",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disappointment'",
			"prompt": "We're all always learning.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_22",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disappointment'",
			"prompt": "We learn something new every day.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_23",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'disappointment'",
			"prompt": "You'll have <pitch mult='1.1'>another</pitch> chance tomorrow.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_24",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'indifference'",
			"prompt": "<pitch mult='1.2'>I thought</pitch><pitch mult='0.9'> it </pitch>was a <pitch mult='1.1'>pretty</pitch> interesting word.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_25",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'indifference'",
			"prompt": "Oh. <pitch mult='1.2'>I liked</pitch> it.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_26",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'indifference'",
			"prompt": "Oh, <pitch mult='1.2'>I </pitch><pitch mult='0.9'>thought</pitch> it was a <pitch mult='1.2'>fun</pitch> word.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_27",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "response === 'indifference'",
			"prompt": "I <pitch mult='1.2'>predict</pitch> there will be a day soon where you will <pitch mult='1.2'>like</pitch> <pitch mult='1.1'>this</pitch> word.",
			"media": "TTS",
			"prompt_id": "WotDComment_AN_28",
