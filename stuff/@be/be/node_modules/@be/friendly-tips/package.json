{
  "name": "@be/friendly-tips",
  "version": "9.1.10",
  "description": "",
  "main": "index.js",
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "display-name": "friendly-tips"
  },
  "dependencies": {},
  "license": "UNLICENSED",
  "distribution": "PROPRIETARY AND CONFIDENTIAL - NOT FOR DISTRIBUTION",
  "copyright": "Copyright (c) 2014-2018 Jibo, Inc. All Rights Reserved",
  "config": {
    "standalone": true
  },
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "scripts": {
    "start": "jibo-dev watch",
    "watch": "jibo-dev watch",
    "build": "jibo-dev build",
    "clean": "jibo-dev clean",
    "build:release": "jibo-dev build --prod",
    "prerelease": "yarn clean && yarn prebuild",
    "sync": "jibo-rsync",
    "addsshkey": "jibo-rsync --init",
    "test": "floss --path tests/index.js --coveragePattern index.js --coverageSourceMaps && istanbul report && yarn coverage:check",
    "coverage:report": "open coverage/lcov-report/index.html",
    "coverage:remap": "remap-istanbul --input ./coverage/coverage-final.json --output ./coverage/coverage-final.json",
    "coverage:check": "istanbul check-coverage coverage/coverage-final.json --statements 40 --branches 30 --functions 40 --lines 40",
    "testdebug": "floss --path tests/index.js --coveragePattern index.js --debug --coverageSourceMaps && istanbul report && yarn coverage:check",
    "test:debug": "yarn testdebug",
    "crunch": "crunchitize -f crunch.txt -d"
  },
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=6.0"
  },
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "@be/skills-test-utils": "^4.0.0",
    "@jibo/floss": "^2.0.0",
    "crunchitize": "^1.1.0",
    "istanbul": "^0.4.5",
    "jibo": "^14.0.0",
    "jibo-anim-db-animations": "19.0.2",
    "jibo-dev": "^5.0.0",
    "jibo-flow-core": "^4.0.0",
    "skills-service-manager": "^14.0.0"
  },
  "syncDependencies": [
    "jibo",
    "jibo-anim-db-animations",
    "@be/be-framework"
  ],
  "files": [
    "assets",
    "mims",
    "animdb-manifest.json",
    "index.*"
  ]
}