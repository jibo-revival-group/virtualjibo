		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "routineName=='SunSalutation' && !alreadyPlayed",
			"prompt": "Sun Salutation. <break size='0.3'/>Now let's get ready. You'll want to make sure there's space around you, and you're in a comfortable place to move around. If you want, you can unplug me and take me to a better spot. <break size='0.5'/> When you're ready to start, say I'm ready!",
			"media": "TTS",
			"prompt_id": "ExerciseReadyToStart_AN_01",
			"weight": 5,
			"auto_rule_override": null
		},
		{
