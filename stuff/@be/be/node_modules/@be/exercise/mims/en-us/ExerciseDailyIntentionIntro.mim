			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'makeNoise'",
			"prompt": "Let's get started. <break size='0.5'/> As we flow through our practice today, be free to make some noises, whenever it feels right.",
			"media": "TTS",
