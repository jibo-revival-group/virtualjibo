	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'smallWins'",
			"prompt": "Let's get started. <break size='0.5'/>As we flow through our routine, let's think about small wins we make, even if it's just practicing yoga today, or discovering that a pose is a little less difficult than it was before.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'leavingComfortZone'",
			"prompt": "Let's get started. <break size='0.5'/> And today, as we flow through our routine, think about leaving your comfort zone, both in yoga and in life. <break size='0.3'/>Find your limits, and then try moving safely just beyond them.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'letGoWhatDoesntServe'",
			"prompt": "Let's get started. <break size='0.5'/> Today as we flow through our routine, and on into your day, allow yourself to let go of the negative, and embrace the positive in your life.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'linkMovementBreath'",
			"prompt": "Okay let's get started. <break size='0.5'/> As we flow through our routine today, give special focus to your breathing, and to the synchronicity between body and breath.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'expressGratitude'",
			"prompt": "Alright let's begin. <break size='0.5'/> As we flow through the different poses, feel gratitude for your body, inside and out.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'nonAttachment'",
			"prompt": "Good, let's get started. <break size='0.5'/>As we flow through the routine, allow yourself to embrace non-attachment, and the beauty of letting go.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'outerBodyExperience'",
			"prompt": "Good, let's get started. <break size='0.5'/> Today as you flow through the routine, imagine viewing yourself from outside your body, seeing yourself from the top, the bottom, the back, the front, the sides.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'youAreDifferent'",
			"prompt": "Me too, let's get started. <break size='0.5'/> As we flow through the routine today, remember that you are different from everything else in the universe, and were meant to stand out.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'dedicateToSomeone'",
			"prompt": "Let's get started. <break size='0.5'/> Today, dedicate your routine to someone you love, or someone you care about deeply.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'yourOwnTeacher'",
			"prompt": "Great let's get started. <break size='0.5'/>As we flow through the routine, remember that you are your own teacher, both in yoga and in life.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'timelessness'",
			"prompt": "Let's get started. <break size='0.5'/> For today's routine, imagine timelessness. If today had no beginning and no end, how would you live it.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'loveYourself'",
			"prompt": "Me too, let's get started. <break size='0.5'/>As you flow through the routine today, focus on something in yourself that you love.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'feelInYourBones'",
			"prompt": "Let's get started. <break size='0.5'/> As we flow through today's routine, focus on feeling yoga physically and inside you. Appreciate every movement.",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionIntro_AN_13",
			"weight": 1,
			"auto_rule_override": null
		},
