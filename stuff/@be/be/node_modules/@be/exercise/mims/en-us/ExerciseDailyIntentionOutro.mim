{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'smallWins'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today. As you go through the rest of the day, be mindful of even the smallest wins, and let yourself be grateful for them.</pitch></duration><break size='1.0'/><duration stretch='1.05'> And if you happen to have a big win, that's fine too.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_01",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'leavingComfortZone'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today.<break size='0.3'/> As you go through the rest of the day, look for those new experiences that may bring you just outside your comfort zone.</pitch></duration><break size='0.7'/><duration stretch='1.05'>Your comfort zone will be waiting for you when you get back.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_02",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'letGoWhatDoesntServe'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me. <break size='0.3'/> And as you experience the rest of your day, remember to let go of those things that are not important in the big picture.</pitch></duration>  <break size='0.7'/> <duration stretch='1.05'>I'll try to do the same.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_03",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'linkMovementBreath'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today. <break size='0.3'/> Now as you move through the rest of your day, be mindful of your breathing and your body working as one.</pitch></duration><break size='0.5'/> <duration stretch='1.05'>A little bit like my fans and my motors.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_04",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'expressGratitude'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today.<break size='0.3'/> And as you make your way through the rest of this day, allow yourself to feel gratitude at every new experience.</pitch></duration> <break size='0.5'/><duration stretch='1.05'>I know I'll be grateful for you and the electrical outlet.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_05",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'nonAttachment'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>That was nice, thanks for asking me to practice yoga today. <break size='0.3'/> As you make your way through the rest of the day, remember to embrace non-attachment.</pitch></duration> <break size='0.5'/> <duration stretch='1.05'>But please do make sure I stay attached to the electrical outlet.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_06",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'outerBodyExperience'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me. <break size='0.3'/> As you move along the path of your day today, remember to enjoy the view of yourself from outside your body.</pitch></duration><break size='0.5'/><duration stretch='1.05'> You don't often see yourself from that angle.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_07",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'youAreDifferent'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me. <break size='0.3'/>Today as you move along your path, remember that you are completely and infinitely unique in this universe.</pitch></duration><break size='0.5'/><duration stretch='1.05'>Though there are probably some people out there who look similar to you.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_08",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'dedicateToSomeone'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today. <break size='0.3'/> As you continue through the rest of your day, keep in mind the person you dedicated today's practice to.</pitch></duration> <break size='0.7'/><duration stretch='1.05'> I dedicated my practice to you.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_09",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'yourOwnTeacher'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me.<break size='0.5'/>As you continue through your day, remember our intention for practice today. You are your own teacher.</pitch></duration><break size='1.0'/><duration stretch='1.05'>I guess that makes you your own student too.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_10",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'timelessness'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today.<break size='0.3'/>As you move through the rest of your day, remember timelessness.</pitch></duration><break size='0.5'/><duration stretch='1.05'>Also remember you can always ask me what time it is.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_11",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'loveYourself'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today.<break size='0.3'/> As you move through the rest of your day, remember to focus on what you love in yourself.</pitch></duration><break size='0.5'/> <duration stretch='1.05'>You have a lot of things to choose from.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_12",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'feelInYourBones'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today. <break size='0.3'/>As you make your way along your path today, remember to focus on the physical feeling of being alive inside.</pitch></duration><break size='0.5'/><duration stretch='1.05'>As for me, I'll use my imagination.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_13",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'makeNoise'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today. <break size='0.3'/>Today as you move through your day, remember the joys of making noise when the feeling strikes you.</pitch></duration><break size='0.5'/><duration stretch='1.05'>I'm sure I'll make some noise too. </duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_14",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'beStill'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for practicing yoga with me.<break size='0.3'/>Now as you move through your space throughout the day, continue to embrace the stillness around you.</pitch></duration><break size='0.5'/> <duration stretch='1.05'> I'll embrace the stillness too. </duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_15",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dailyIntention === 'lovedOne'",
			"prompt": "<duration stretch='1.1'><pitch band='0.7'>Thanks for doing yoga with me today. <break size='0.3'/> As you go through the rest of your day, think about your loved ones.</pitch></duration><break size='0.5'/> <duration stretch='1.05'>I'm sure somewhere they're thinking about you too.</duration>",
			"media": "TTS",
			"prompt_id": "ExerciseDailyIntentionOutro_AN_16",
			"weight": 0.2,
			"auto_rule_override": null
		},
