{
  "name": "@be/exercise",
  "version": "2.0.18",
  "description": "",
  "main": "index.js",
  "config": {
    "standalone": true
  },
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "launch.rule",
    "display-name": "exercise"
  },
  "dependencies": {
    "jibo-common-types": "^5.0.0"
  },
  "license": "UNLICENSED",
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "scripts": {
    "start": "jibo-dev watch",
    "watch": "jibo-dev watch",
    "postbuild": "yarn preprocess:csv",
    "build": "jibo-dev build",
    "clean": "jibo-dev clean",
    "postbuild:release": "yarn preprocess:csv",
    "build:release": "jibo-dev build --prod",
    "prerelease": "yarn run clean && yarn run prebuild",
    "sync": "jibo-rsync",
    "addsshkey": "jibo-rsync --init",
    "test": "floss --path tests/index.js --coveragePattern index.js --coverageSourceMaps && istanbul report && yarn run coverage:check",
    "test:report": "yarn test --reporter=spec,xunit",
    "coverage:report": "open coverage/lcov-report/index.html",
    "coverage:remap": "remap-istanbul --input ./coverage/coverage-final.json --output ./coverage/coverage-final.json",
    "coverage:check": "istanbul check-coverage coverage/coverage-final.json --statements 5 --branches 1 --functions 1 --lines 5",
    "testdebug": "floss --path tests/index.js --coveragePattern index.js --debug --coverageSourceMaps && istanbul report && yarn run coverage:check",
    "test:debug": "yarn run testdebug",
    "preprocess:csv": "tsc --target es6 scripts/tools/SpreadsheetReader.ts && node scripts/tools/SpreadsheetReader.js"
  },
  "files": [
    "resources",
    "mims",
    "index.*"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=6.0"
  },
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "@be/skills-test-utils": "^4.0.0",
    "@jibo/floss": "^2.0.0",
    "istanbul": "^0.4.5",
    "jibo": "^14.0.0",
    "jibo-anim-db-animations": "19.0.2",
    "jibo-dev": "^5.0.0",
    "jibo-rsync": "^4.0.0",
    "csvtojson": "1.1.9"
  },
  "syncDependencies": [
    "@be/be-framework",
    "jibo",
    "jibo-anim-db-animations"
  ]
}