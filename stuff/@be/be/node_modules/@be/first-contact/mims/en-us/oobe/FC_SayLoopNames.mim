{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"ignore_no_match": false,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "using condition loopCount for total number of Loop members entered in app at time of OOBE FC",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopCount == 1",
			"prompt": "<anim cat='glances' filter='up'>Like ${loopNames[0]}</anim>. <break size='0.7'/>\n<anim cat='emoji' filter='blue-heart' nonBlocking='true'/>\n<pitch mult='1.2'>${loopNames[0]}</pitch><pitch mult='0.8'>${loopNames[0]}</pitch><pitch mult='1.1'>${loopNames[0]} </pitch>.\n<break size='0.5'/>\nIf my pronunciation <anim cat='glances'>was a bit</anim> off, \n<anim cat='yes' filter='small'>we can fix that in a little</anim> bit.",
			"media": "TTS",
			"prompt_id": "FC_SayLoopNames_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopCount == 2",
			"prompt": "<anim cat='glances' filter='up'>Like ${loopNames[0]}</anim>. \n<anim cat='glances' filter='side'>And <pitch mult='1.2'>${loopNames[1]}</pitch></anim>.\n<break size='0.7'/>\n<anim cat='emoji' filter='blue-heart' nonBlocking='true'/><pitch mult='1.2'>${loopNames[0]}</pitch><pitch mult='0.8'>${loopNames[1]}</pitch><pitch mult='1.1'>${loopNames[0]} </pitch>${loopNames[1]}. \n<break size='0.5'/>\nIf my pronunciation <anim cat='glances'>was a bit</anim> off, \n<anim cat='yes' filter='small'>we can fix that in a little</anim> bit.",
			"media": "TTS",
			"prompt_id": "FC_SayLoopNames_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopCount == 3",
			"prompt": "<anim cat='glances' filter='up'>Like ${loopNames[0]}</anim>, \n<anim cat='glances' filter='side'>and <pitch mult='1.2'>${loopNames[1]}</pitch></anim>,\n<anim cat='glances' filter='side'>and ${loopNames[2]}</anim>.\n<break size='0.7'/>\n<anim cat='emoji' filter='blue-heart' nonBlocking='true'/><pitch mult='1.2'>${loopNames[0]}</pitch><pitch mult='0.8'>${loopNames[1]}</pitch><pitch mult='1.1'>${loopNames[2]} </pitch>${loopNames[0]} <pitch mult='0.8'>${loopNames[1]}</pitch><pitch mult='1.2'>${loopNames[2]}.</pitch>\n<break size='0.5'/>\nIf my pronunciation <anim cat='glances'>was a bit</anim> off, \n<anim cat='yes' filter='small'>we can fix that in a little</anim> bit.",
			"media": "TTS",
			"prompt_id": "FC_SayLoopNames_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopCount == 4",
			"prompt": "<anim cat='glances' filter='up'>Like ${loopNames[0]}</anim>, \n<anim cat='glances' filter='side'>and <pitch mult='1.2'>${loopNames[1]}</pitch></anim>,\n<anim cat='glances' filter='side'>and ${loopNames[2]}</anim>,\nand ${loopNames[3]}.\n<break size='0.7'/>\n<anim cat='emoji' filter='blue-heart' nonBlocking='true'/><pitch mult='1.2'>${loopNames[0]}</pitch><pitch mult='0.8'>${loopNames[1]}</pitch><pitch mult='1.2'>${loopNames[2]} </pitch><pitch mult='0.8'>${loopNames[3]}</pitch>. \n<break size='0.5'/>\nIf my pronunciation <anim cat='glances'>was a bit</anim> off, \n<anim cat='yes' filter='small'>we can fix that in a little</anim> bit.",
			"media": "TTS",
			"prompt_id": "FC_SayLoopNames_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopCount == 5",
			"prompt": "<anim cat='glances' filter='up'>Like ${loopNames[0]}</anim>, \n<anim cat='glances' filter='side'>and <pitch mult='1.2'>${loopNames[1]}</pitch></anim>,\n<anim cat='glances' filter='side'>and ${loopNames[2]}</anim>,\nand ${loopNames[3]},\nand ${loopNames[4]}.\n<break size='0.7'/>\n<anim cat='emoji' filter='blue-heart' nonBlocking='true'/><pitch mult='1.2'>${loopNames[0]}</pitch><pitch mult='0.8'>${loopNames[1]}</pitch><pitch mult='1.1'>${loopNames[2]} </pitch>${loopNames[3]} <pitch mult='1.1'>${loopNames[4]}.</pitch>\n<break size='0.5'/>\nIf my pronunciation <anim cat='glances'>was a bit</anim> off, \n<anim cat='yes' filter='small'>we can fix that in a little</anim> bit.",
