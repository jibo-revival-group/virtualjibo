			"prompt": "<anim cat='global' filter='360'>Like <duration stretch='0.9'><pitch mult='1.2'>${loopNames[0]}</pitch> <pitch mult='0.9'>${loopNames[1]}</pitch> <pitch mult='1.1'>${loopNames[2]}</pitch>\n<pitch mult='0.9'>${loopNames[3]}</pitch><pitch mult='1.1'> ${loopNames[4]}</pitch>${loopNames[5]}.</duration> \n</anim>\n<break size='0.7'/>\n<style set='sheepish'>If my<anim cat='glances'>pronunciation was a bit</anim> off</style>, \n<anim cat='yes' filter='small'>we can fix that in a little bit.</anim>",
