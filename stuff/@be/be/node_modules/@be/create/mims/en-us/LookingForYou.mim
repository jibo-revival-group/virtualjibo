	"notes": "If Jibo does not detect any faces before taking a photo, he asks where the subject is so he can find them and center on them.\nThere are zero no matches. Just focus on the misunderstood words and center on the location of those.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "first",
			"prompt": "I need to zero in on you, can you clap your hands for me?",
			"media": "TTS",
