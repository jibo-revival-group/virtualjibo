{
	"mim_type": "question",
	"rule_name": "create/is_it_a_keeper",
	"gui": {
		"type": "Menu",
		"data": {
			"buttons": [
				{
					"label": "No",
					"color": "cancel",
					"icon": "jibo://resources/actionIcons/delete.png",
					"utterance": "no",
					"notes": ""
				},
				{
					"label": "Yes",
					"color": "confirm",
					"icon": "jibo://resources/actionIcons/ok.png",
					"utterance": "yes",
					"notes": ""
				}
			],
			"title": "Keep the photo?",
			"allowSwipe": true
		},
		"pause": true
	},
	"timeout": 6,
	"no_matches_for_gui": 1,
	"no_inputs_for_gui": 1,
	"ignore_no_match": false,
	"barge_in": true,
	"es_auto_tagging": false,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "No input length is only three seconds. NI 1 is silence and we surface GUI at that time. So user gets about 3 seconds during prompt to review photo plus 3 seconds during no input to review photo before buttons surface.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isRestart",
			"prompt": "Is it a <pitch mult=\"1.2\">keeper?</pitch>",
			"media": "TTS",
