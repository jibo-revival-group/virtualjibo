		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Verbose",
			"index": 1,
			"condition": "",
			"prompt": "Yes or no. Do you like it?",
			"media": "TTS",
			"prompt_id": "IsItAKeeper_VB_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
