			"prompt": "A <pitch mult=\"1.2\">photo</pitch>. Don't <pitch mult=\"1.3\">mind if I</pitch> do.",
			"media": "TTS",
			"prompt_id": "EchoPhoto_AN_04",
			"weight": 1,
			"auto_rule_override": false
