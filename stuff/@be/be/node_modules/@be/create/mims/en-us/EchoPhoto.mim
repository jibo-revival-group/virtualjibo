		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numPhotos==1 && !!loopMember",
			"prompt": "Okay ${loopMember}, <pitch mult=\"1.2\">let me </pitch> get my camera. <break size='0.2'/>Let's see, where did I put it. <break size='0.2'/>I'm kidding. It's in my head.",
