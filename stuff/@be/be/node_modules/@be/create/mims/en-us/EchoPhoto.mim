{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": {
		"hotWords": false,
		"punctuation": false,
		"voice": true,
		"beat": false
	},
	"notes": "${loopMember} is person requesting photo",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numPhotos==1 && !!loopMember",
			"prompt": "A <pitch mult=\"1.2\">photo</pitch>. Sure ${loopMember}.",
			"media": "TTS",
			"prompt_id": "EchoPhoto_AN_01",
			"weight": 1,
			"auto_rule_override": false
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numPhotos==1 && !!loopMember",
			"prompt": "Okay ${loopMember}.",
			"media": "TTS",
			"prompt_id": "EchoPhoto_AN_02",
			"weight": 1,
			"auto_rule_override": false
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numPhotos==1",
			"prompt": "A <pitch mult=\"1.2\">photo.</pitch> <pitch mult=\"1.3\">You got</pitch> it.",
			"media": "TTS",
			"prompt_id": "EchoPhoto_AN_03",
			"weight": 1,
			"auto_rule_override": false
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
