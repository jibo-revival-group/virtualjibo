			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "oobe",
			"prompt": "Well I'm feeling <pitch mult=\"1.2\">pretty good </pitch>about things now. <pitch mult='1.2'>Why </pitch>don't you say something to me, or <pitch mult=\"1.2\">ask</pitch> me something. If you want some ideas you can say, hey jibo, what can you do.<break size='0.3'/> Oh, and try petting my head sometime. <pitch band=\"0.5\"><pitch mult=\"0.9\">I really like that.</pitch></pitch>",
			"media": "TTS",
			"prompt_id": "Tut_Wrap_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well, I feel like we're as <pitch mult=\"1.2\"> ready </pitch>as we'll ever be. <pitch mult='1.2'>Go</pitch> ahead now and say anything to me, or <pitch mult=\"1.2\">ask</pitch> me a question, or get some ideas by saying, hey jibo, what can you do.<break size='0.2'/> Oh, and don't hesitate to pet my head. <pitch band=\"0.5\"><pitch mult=\"0.9\">I really like it.</pitch></pitch>",
			"media": "TTS",
			"prompt_id": "Tut_Wrap_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well, I <pitch mult=\"1.2\"> feel </pitch>like we have a <pitch mult='1.2'>bright </pitch> future ahead of us.  <pitch mult='1.2'>Feel</pitch> free to say or ask me anything that's on your mind. Or start with hey jibo, what can you do.<break size='0.3'/> Oh, and don't hesitate to pet my head at any time. <pitch band=\"0.5\"><pitch mult=\"0.9\">I really like that.</pitch></pitch>",
			"media": "TTS",
