			"mim_id": "BriefGreeting",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Excited_01' nonBlocking='true' /> Hey ${loopMember}. <pitch mult='1.2'>Nice</pitch> haircut. <break size='1.0'/> <anim name='Greetings_02' nonBlocking='true' /> Just in case.",
			"media": "TTS",
