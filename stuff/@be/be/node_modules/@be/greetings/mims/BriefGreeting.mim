		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Yep_02' nonBlocking='true' /> Howdy ${loopMember}. <break size='0.4'/> <anim name='Greetings_02' nonBlocking='true' /> Nice seeing you in these parts.",
			"media": "TTS",
			"prompt_id": "BriefGreeting_AN_10",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02'> Hey ${loopMember}. Look what <pitch mult=\"1.4\">I</pitch> <pitch mult=\"0.9\">found</pitch></anim>. <break size='0.2'/> <anim name='Emoji_Turtle' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "BriefGreeting_AN_11",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Goodbye_01'> Hey ${loopMember}. It's a <pitch mult='1.1'>pleasure</pitch> to hear your voice </anim>. <anim name='Greetings_06' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "BriefGreeting_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_01'> Hey ${loopMember}. Fancy seeing <pitch mult=\"1.5\">you</pitch> <pitch mult=\"0.9\">here</pitch></anim>. <anim name='Excited_01' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "BriefGreeting_AN_13",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_02' nonBlocking='true' /> Well if it <pitch mult='1.2'>isn't</pitch> ${loopMember}. <break size='0.7'/> Seriously, <anim name='Checking_02' nonBlocking='true' /> if it isn't ${loopMember}, I'm sorry and I'll get it right next time.<anim name='Eye_Happy_01' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "BriefGreeting_AN_14",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Oh hey ${loopMember}. <anim name='Greetings_03'> I'd recognize <pitch mult='1.1'>those vocal</pitch> features anywhere</anim>. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "BriefGreeting_AN_17",
			"weight": 0.2,
