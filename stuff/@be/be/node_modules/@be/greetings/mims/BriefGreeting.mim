			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_02' nonBlocking='true' /> <ssa cat='happy'/> Hi ${loopMember}. <anim name='Greetings_01' nonBlocking='true' /> Nice to hear you.",
			"media": "TTS",
			"extra": "",
