{
	"mim_id": "MissedCallsFromOne",
	"skill_id": "greetings",
	"mim_type": "optional-response",
	"rule_name": "CallBack",
	"screen_slots_available": true,
	"sample_utterances": "call her back",
	"timeout": 2,
	"max_tries": null,
	"force_confirmation": false,
	"barge_in": true,
	"photo_quality_light": false,
	"notes": "Rule slots: callback\n\"Thanks\" should continue in Mim (do not kill Mim)\n",
	"prompts": [
		{
			"mim_id": "MissedCallsFromOne",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "${numCalls}==1",
			"prompt": "You have a missed call from ${loopMember} at ${timeOfCall}.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "MissedCallsFromOne_AN_01"
		},
		{
			"mim_id": "MissedCallsFromOne",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "${numCalls}==2",
			"prompt": "You have two missed calls from ${loopMember} at ${timeOfCall1} and ${timeOfCall2}.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "MissedCallsFromOne_AN_02"
		},
		{
			"mim_id": "MissedCallsFromOne",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "${numCalls}>2",
			"prompt": "You have ${numCalls} missed calls from ${loopMember}.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "MissedCallsFromOne_AN_03"
		}
	],
	"num_tries_for_gui": 2,
	"es_auto_tagging": true
}