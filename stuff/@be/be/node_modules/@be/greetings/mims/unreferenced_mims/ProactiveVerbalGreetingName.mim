		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey check it out. <break size='0.3'/> Look</anim> what <pitch mult=\"1.3\">I</pitch><pitch mult=\"0.9\"> found</pitch>. <anim name='Emoji_Turtle' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingName_AN_15",
			"weight": 0.1,
