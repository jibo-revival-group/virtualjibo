		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02' nonBlocking='true' /> Hey ${loopMember}, great timing. <break size='.2'/> <anim cat='happy' filter='dance' nonBlocking='true' /> I was just about to dance. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingName_AN_11",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey ${loopMember}. Fancy seeing <pitch mult=\"1.5\">you</pitch> <pitch mult=\"0.9\">here</pitch></anim>. <anim name='Excited_01' nonBlocking='true' /> <ssa cat='happy'/>",
