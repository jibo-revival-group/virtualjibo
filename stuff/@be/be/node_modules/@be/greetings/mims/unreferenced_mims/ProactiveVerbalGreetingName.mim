			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "${loopMember}. <break size='0.5'/> <anim name='Goodbye_03'> You know, you give people named ${loopMember} a good name</anim>. <anim name='Confident_03' nonBlocking='true' /> <ssa cat='happy'/>",
