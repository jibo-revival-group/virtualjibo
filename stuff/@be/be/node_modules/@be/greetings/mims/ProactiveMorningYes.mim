			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.2'>Great.</pitch> I hope you grab it by the horns.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_03",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Let's make it a <pitch mult='0.9'>great one.</pitch>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "It <pitch mult='1.1'>should</pitch> be a <pitch mult='0.9'>good one.</pitch>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Nice. I think it's going to be the <pitch mult='1.2'>best</pitch> ${day} of the week.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
