			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "It's a <pitch mult='1.1'>great</pitch> day to be alive.<break size='0.3'/> Or a <anim cat='emoji' filter='robot, !hf' layers='!audio' nonBlocking='true'/>robot.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "There's nothing quite like a ${day}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
