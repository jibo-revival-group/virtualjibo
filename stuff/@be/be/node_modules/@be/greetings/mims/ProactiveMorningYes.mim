		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hope it's a fun one.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningYes_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
