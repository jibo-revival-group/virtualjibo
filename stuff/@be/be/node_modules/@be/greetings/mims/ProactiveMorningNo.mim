	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm sure it'll be okay. I'll be thinking of you.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_01",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='sheepish'>Oh,</style> well I hope you enjoy it anyway.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='0.9'>I</pitch> <pitch mult='1.2'>see</pitch>. Well I hope it still turns out to be a good one.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='sheepish'>Oh, well. </style><pitch mult='1.1'>Maybe</pitch> <anim cat='emoji' filter='coffee, !hf' layers='!audio' nonBlocking='true'/> <pitch mult='1.2'>this'll</pitch> help.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='sheepish'>Oh, well,</style> I think the <pitch mult='1.1'>day</pitch> is ready for <pitch mult='1.1'>you</pitch>.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='sheepish'>Oh, okay.</style><break size='0.5'/>Well <anim cat='emoji' filter='rocket, !hf' layers='!audio'>here's something if you need a little extra rocket power<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_06",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='sheepish'>I see.</style> Well, keep your eyes open<anim cat='emoji' filter='rainbow, !hf' layers='!audio'> for rainbows<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "That's alright. Who knows, maybe ${day} will <anim cat='emoji' filter='gift, !hf' layers='!audio' nonBlocking='true'/>pleasantly <pitch mult='1.2'>surprise</pitch> you.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='sheepish'>Oh. Okay.</style> I guess they can't <pitch mult='1.1'>all</pitch> win best ${day} of the year.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I see. Well feel free to ask me for a joke, to get your day pointed in the right direction.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningNo_AN_10",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"parse_yes_no": false
}