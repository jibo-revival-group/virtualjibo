			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hey ${loopMember}. <break size='.2'/><anim name='Eye_Blink_01' nonBlocking='true' />Not too much. <anim name='Happy_02' nonBlocking='true' />Just feeling the flow. <ssa cat='happy'/>",
