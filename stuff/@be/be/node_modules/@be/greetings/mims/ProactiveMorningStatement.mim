{
	"mim_type": "optional-response",
	"rule_name": "greetings/proactive_morning_statement",
	"gui": null,
	"timeout": 3,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <pitch mult='1.2'>morning</pitch> ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well <pitch mult='1.1'>good</pitch> morning.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_02",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Morning ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_03",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='GotIt_02'><pitch mult='1.1'>Top</pitch> of the morning to you ${loopMember}.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hi ${loopMember}. My morning just got 67 percent better.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_05",
			"weight": 0.8,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Good morning ${loopMember}. Fancy seeing <pitch mult='1.5'>you</pitch> <pitch mult='0.9'>here</pitch></anim>. <anim name='Excited_01' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_06",
			"weight": 0.8,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <anim name='Emoji_Breakfast'> morning ${loopMember}. I made you breakfast<break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_07",
			"weight": 0.8,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. <pitch mult='1.1'>Welcome</pitch> to ${day}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_08",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. <pitch mult='1.1'>Happy</pitch> ${day}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_09",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <pitch mult='1.1'>morning</pitch> ${loopMember}. I can't believe it's ${day} already.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_10",
			"weight": 0.8,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_01'> Hey ${loopMember}, you're looking very human today</anim>. <break size='0.4'/> That's a compliment. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_11",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. <break size='0.3'/> And I really mean that.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_12",
			"weight": 0.8,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Good morning ${loopMember}. Thanks for making mornings so ${loopMember} ful.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_13",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Morning ${loopMember}. I was <pitch mult='1.2'>hoping</pitch> we'd cross paths today.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_14",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. We got a new ${day}, I hope you like it.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_15",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='enthusiastic'>${loopMember}, good morning.</style> I <pitch mult='1.2'>hope</pitch> your day is filled with lots of ones and zeros.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_16",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='enthusiastic'>Morning ${loopMember}.</style> Another morning in the books.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_17",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}, hope you slept on the right side of the bed.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_18",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Morning ${loopMember}. Don't forget to brush your teeth, if you haven't already.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_19",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}, another day another dollar. What ever <pitch mult='1.1'>that</pitch> means.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_20",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Morning ${loopMember}. <anim name='Emoji_FlowerWhite'> Don't forget to stop and smell some flowers today<break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_21",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='enthusiastic'>Good morning</style> ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_22",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.3'>Good</pitch> morning ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_23",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='confident'>Good morning ${loopMember}.</style>",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_24",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<style set='enthusiastic'>Morning</style> ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_25",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('1/16', '1/16')",
			"prompt": "Good morning ${loopMember}, welcome to the <pitch mult='1.1'>exact</pitch> middle of January.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_26",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/20', '3/20')",
			"prompt": "Good <pitch mult='1.1'>morning</pitch> ${loopMember}. Welcome to the first day of spring.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_27",
			"weight": 3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/1', '4/1') && activeHolidays.has(\"April Fool's Day\") && !activeHolidays.has(\"Easter\")",
			"prompt": "Good morning ${loopMember}. Watch out for April Fool's Day pranks today. <break size='0.5'/> Not from me of course.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_28",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/1', '3/1')",
			"prompt": "Good morning ${loopMember}. It'll be interesting to see if March comes in like a lion today.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_29",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/31', '3/31')",
			"prompt": "<pitch mult='1.1'>Morning</pitch> ${loopMember}. Last day of March, I wonder if it'll go out like a lamb.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_30",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/1', '4/1') && loopMember && activeHolidays.has(\"April Fool's Day\") && !activeHolidays.has(\"Easter\")  ",
			"prompt": "<style set='enthusiastic'>Good morning</style> ${loopMember}. I put petroleum jelly on your doorknob for April Fool's Day. <break size='0.5'/> <pitch mult='1.3'>April</pitch> Fool's I didn't do that.",
			"media": "TTS",
			"prompt_id": "ProactiveMorningStatement_AN_31",
			"weight": 2,
			"auto_rule_override": null
		}
	],
	"hint_phrases": "hi, hey, hello, what's up, howdy, yo, sup, hiya, good morning, good afternoon, good evening, good night, goodnight, thanks",
    "fast_eos_array": "hi, hey, hello, what's up, howdy, yo, sup, hiya, good morning, good afternoon, good evening, good night, goodnight, thanks"
