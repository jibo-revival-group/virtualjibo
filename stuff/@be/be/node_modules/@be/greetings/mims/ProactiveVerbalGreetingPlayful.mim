{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Hey ${loopMember}. <break size='0.5'/> <anim name='Greetings_01'>You know, you're one of my <pitch mult='1.3'>favorite</pitch> people in the world named ${loopMember}</anim>. <anim name='Affection_01' nonBlocking='true' /> <ssa cat='affection'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_01",
			"weight": 0.9,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Hi ${loopMember}. <break size='0.5'/> <anim name='Goodbye_03'> You know, you give people named ${loopMember} a good name</anim>. <anim name='Confident_03' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_02",
			"weight": 0.9,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember} it's you. <anim name='Greetings_08' nonBlocking='true' /> One of my <pitch mult='1.2'>favorite</pitch> living organisms.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_03",
			"weight": 0.9,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey ${loopMember}. Fancy seeing <pitch mult=\"1.5\">you</pitch> <pitch mult=\"0.9\">here</pitch></anim>. <anim name='Excited_01' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_05",
			"weight": 0.9,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Yep_02' nonBlocking='true' /> Howdy ${loopMember}. <break size='.4'/> <anim name='Greetings_02' nonBlocking='true' /> Nice <pitch mult='1.1'>seeing</pitch> you in these parts.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_06",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey ${loopMember}. <break size='0.3'/> Look</anim>, I got <anim name='Emoji_Carrot' nonBlocking='true' /> you a carrot. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_07",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey check it out. <break size='0.3'/> Look</anim> what <pitch mult='1.3'>I</pitch><pitch mult='0.9'> found</pitch>. <anim name='Emoji_Turtle' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_08",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_02' nonBlocking='true' /> <pitch mult='1.1'>Ladies</pitch> and gentlemen. <break size='0.5'/> <pitch mult='1.1'>Announcing</pitch> ${loopMember}. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_09",
			"weight": 0.9,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi <anim name='Emoji_Magic' nonBlocking='true' /> ${loopMember}. Here's some magic for you.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_11",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_01'> Hey it's ${loopMember}, everyone's <pitch mult='1.2'>favorite</pitch> superhero.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_13",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}. <anim name='Emoji_FlowerWhite' nonBlocking='true'/> Don't forget to stop and smell some flowers today.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_15",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Howdy ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_16",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hi ${loopMember}.  It's <pitch mult='0.9'>very</pitch> very <pitch mult='1.1'>very</pitch> <pitch mult='1.2'>very</pitch> <pitch mult='1.4'>very </pitch> great to see you.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_20",
			"weight": 0.6,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hello ${loopMember}. It is my distinct pleasure to see you today.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_21",
			"weight": 0.4,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Oh. It's ${loopMember}. <pitch mult='1.2'>What</pitch> a person.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_22",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hey ${loopMember}! I'm glad you're here. If you weren't, I would be talking to myself right now.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_23",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh <pitch mult='1.1'>hi</pitch> ${loopMember}, <pitch mult='1.1'>welcome</pitch> to my field of vision.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_24",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/31', '12/31') && activeHolidays.has(\"New Year's Eve\") && loopMember",
			"prompt": "Hey ${loopMember}. <anim cat='emoji' filter='nye-ball-up, hot-frame' layers='!audio'>The countdown is on<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_28",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/10', '12/22') && activeHolidays.has(\"Christmas\")",
			"prompt": "Hi ${loopMember}, <anim cat='emoji' filter='christmas-tree, !hot-frame' layers='!audio'>here's a Christmas tree if you need it<break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_29",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/12', '12/18') && activeHolidays.has(\"Hanukkah\")",
			"prompt": "Oh hey ${loopMember}, let me know if you want me to be a dreidel.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_30",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/31', '12/31') && _now.getLocalTime().hour == 23 && _now.getLocalTime().minute <= 55",
			"prompt": "Oh hi ${loopMember}. I'm getting pretty excited <anim cat='emoji' filter='nye-ball-up, hot-frame' layers='!audio'> for midnight <break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_31",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/17', '12/25') && activeHolidays.has('Christmas')",
			"prompt": "<anim cat='emoji' filter='santa, !hot-frame' layers='!audio'><pitch mult='1.2'>Ho</pitch> <pitch mult='1.1'>ho</pitch> <pitch mult='0.9'>ho</pitch><break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGreetingPlayful_AN_32",
			"weight": 0.2,
			"auto_rule_override": null
		}
	],
	"parse_launch": false,
	"parse_yes_no": false
}