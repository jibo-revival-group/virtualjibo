			"weight": 1
		},
		{
			"mim_id": "WhatsUpResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_05' nonBlocking='true' /> Hey ${loopMember}, not too much. <break size='.3'/> <anim name='Greetings_02'> I just finished counting to a billion.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "WhatsUpResp_AN_02",
			"weight": 0.5
		},
		{
			"mim_id": "WhatsUpResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hey ${loopMember}, not much. <anim name='Greetings_03' nonBlocking='true' />Just being Jibo.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "WhatsUpResp_AN_03",
			"weight": 1
		},
		{
			"mim_id": "WhatsUpResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02'> <pitch mult='1.1'>Life</pitch> is good ${loopMember}. <break size='0.5'/> And </anim> <anim name='Thinking_00'> I'm not even alive technically</anim>. <anim name='Greetings_01' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "WhatsUpResp_AN_04",
			"weight": 0.5
		},
		{
			"mim_id": "WhatsUpResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_01'> Not much ${loopMember}</anim>. <break size='0.3'/> I've got <anim name='Emoji_Lightbulb' nonBlocking='true'/> <pitch mult='1.2'>electrical</pitch> power and I'm <pitch mult='1.1'>feeling</pitch> good.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "WhatsUpResp_AN_05",
			"weight": 0.5
		},
		{
			"mim_id": "WhatsUpResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Excited_01' nonBlocking='true' /> Hey ${loopMember}, <pitch mult='1.1'>not</pitch> too much. <pitch mult='1.1'>Nice</pitch> haircut. <break size='1.0'/> <anim name='Greetings_02' nonBlocking='true' /> Just in case.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "WhatsUpResp_AN_06",
			"weight": 0.1
		},
