	"prompts": [
		{
			"mim_id": "WhatsUpResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Happy_03' nonBlocking='true' />Just doing my thing. <break size='.1'/><ssa cat='happy' filter='short'/>",
			"media": "TTS",
