{
	"mim_type": "question",
	"rule_name": "greetings/proactive_playful_question",
	"gui": null,
	"timeout": 4,
	"no_matches_for_gui": 1,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}, one of my <pitch mult='1.2'>favorite</pitch> living organisms, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Howdy ${loopMember}, <style set='enthusiastic'>how's it going.</style>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Hello ${loopMember}. It is my distinct pleasure to see you today, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}. <pitch mult='1.2'>What </pitch> a pleasure, how are you doing.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Hey it's one of my favorite people, how are you ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Oh look, it's one of the world's greatest ${loopMember}'s. How are you ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_01'> Hey it's ${loopMember}, everyone's <pitch mult='1.2'>favorite</pitch> superhero,</anim> how's it going ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}! I <pitch mult='1.2'>thought </pitch> that was you, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}'s here, <pitch mult='1.1'>how's</pitch> it going.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "${loopMember}, <pitch mult='1.2'>welcome</pitch> to my humble abode. How are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.2'>Greetings</pitch> ${loopMember}, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.2'>Welcome</pitch> to my planet ${loopMember}, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}, <pitch mult='1.2'>always</pitch> nice to see a <pitch mult='1.1'>friendly</pitch> face, how are you doing.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_13",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Hello ${loopMember}, how does it feel to be a human today.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_14",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "<style set='enthusiastic'>Hip hip hello! How's it going.</style>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_15",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Hello ${loopMember}, <pitch mult='1.1'>nice</pitch> to see your face. How are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_16",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Oh hey ${loopMember}, thanks for being here, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_17",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Hi hey hello ${loopMember}, how're you doing.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_18",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Well if it isn't ${loopMember}, how's it going.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_19",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "And a <pitch mult='1.3'>big</pitch> hello to you ${loopMember}, how are you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_20",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}! My face identification system and I are happy to see you. How's it going.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_21",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "${loopMember}! It's quite nice to see you at this particular time and place in the history of the universe. Are you doing well?",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulQuestion_QN_22",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"hint_phrases": "yes, yeap, yeah, no, nah, nope, sure, alright, fine, decent, good, great, wonderful, awesome, super, better, terrible, awful, horrible, bad, worse, you bet, thanks",
    "fast_eos_array": "yes, yeap, yeah, no, nah, nope, sure, alright, fine, decent, good, great, wonderful, awesome, super, better, terrible, awful, horrible, bad, worse, you bet, thanks"
