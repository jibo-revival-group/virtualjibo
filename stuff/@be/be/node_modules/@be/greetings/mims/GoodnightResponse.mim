{
	"mim_id": "GoodnightResponse",
	"skill_id": "greetings",
	"mim_type": "announcement",
	"rule_name": "",
	"rule_slots": "",
	"screen_slots_available": false,
	"timeout": 4,
	"max_tries": null,
	"force_confirmation": false,
	"barge_in": true,
	"photo_quality_light": false,
	"notes": "",
	"prompts": [
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodnight ${loopMember}. <anim cat='emoji' filter='moon, !hf' layers='!audio'> I hope your sleep is very slumberful<break size='3.0'/>.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_01",
			"weight": 1
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodnight ${loopMember}. Here's a <anim name='Emoji_Sheep'> sheep to count if you need it<break size='5.0'/>.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_02",
			"weight": 1
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='emoji' filter='sleep' nonBlocking='true' /><pitch mult='1.1'>Nitey</pitch> night night night.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_03",
			"weight": 0.3
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='emoji' filter='sleep' nonBlocking='true' /><pitch mult='1.1'>Good</pitch> night, <pitch mult='1.1'>sleep</pitch> tight.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_04",
			"weight": 1
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02'> Sleep tight, wake up loose.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_05",
			"weight": 0.8
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Goodnight ${loopMember}. I hope you sleep like a baby</anim>. <break size='0.7'/> <anim name='Thinking_04' nonBlocking='true'/> I'm not sure if I used that expression correctly.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_06",
			"weight": 0.1
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Happy_01'>Good night. Sleep</anim>tight.<anim name='Puzzled_02'><break size='.4' />Don't bite the bedbugs.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_07",
			"weight": 1
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodnight ${loopMember}. Tell everyone in your dreams I said hi.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_08",
			"weight": 0.2
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodnight. <anim cat='emoji' filter='sleep' nonBlocking='true' /> <break size='.3'/>I hope your dreams are fun.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_09",
			"weight": 0.5
		},
		{
			"mim_id": "GoodnightResponse",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodnight ${loopMember}. <break size='.2'/> <anim cat='happy' filter='eye-only'>I hope your dreams are everything you dreamed they would be.</anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodnightResponse_AN_10",
			"weight": 0.2
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_07' nonBlocking='true' /> Sleep well ${loopMember}.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_11",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember && _now.isInRange('12/24', '12/24') && activeHolidays.has(\"Christmas\")",
			"prompt": "Goodnight ${loopMember}. I hope visions of sugar plums dance in your head.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_13",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/31', '12/31') && _now.getLocalTime().hour >= 20",
			"prompt": "Goodnight ${loopMember}. Don't forget to say goodbye to 2017.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_14",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember && _now.isInRange('12/20', '12/20') && activeHolidays.has(\"Hanukkah\")",
			"prompt": "Goodnight ${loopMember}. Hope you had a nice eight nights of Hanukkah.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_15",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/19', '3/19') && _now.getLocalTime().hour > 18",
			"prompt": "<pitch mult='1.1'>Goodnight</pitch> ${loopMember}. When you wake up in the morning, it'll be <pitch mult='1.1'>spring</pitch>.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/31', '3/31') && _now.getLocalTime().hour > 18",
			"prompt": "Good <pitch mult='1.1'>night</pitch> ${loopMember}. See you in <pitch mult='1.1'>April</pitch>.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_16",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/30', '4/30') && _now.getLocalTime().hour > 18",
			"prompt": "<pitch mult='1.2'>Good</pitch> night ${loopMember}. See you in <pitch mult='1.1'>May</pitch>.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_17",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/1', '4/1') && _now.getLocalTime().hour > 18 && activeHolidays.has(\"April Fool's Day\") && !activeHolidays.has(\"Easter\")",
			"prompt": "Good night ${loopMember}, but before you go to sleep, there's something that I just can't keep to myself anymore. <break size='1.0'/> I filled your pillow with spaghetti for April Fool's Day.",
			"media": "TTS",
			"prompt_id": "GoodnightResponse_AN_18",
			"weight": 4,
			"auto_rule_override": null
		}
	],
	"es_auto_tagging": true,
	"gui": null,
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"ignore_no_match": false,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"hint_phrases": "",
	"fast_eos_array": ""
