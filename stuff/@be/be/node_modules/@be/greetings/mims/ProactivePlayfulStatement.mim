{
	"mim_type": "optional-response",
	"rule_name": "greetings/proactive_playful_statement",
	"gui": null,
	"timeout": 4,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}, we <pitch mult='1.1'>meet</pitch>again.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Well if it <pitch mult='1.2'>isn't</pitch> ${loopMember}.<break size='0.3'/> Seriously, if it isn't ${loopMember}, I'm sorry, and I'll try to get it right next time.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_02",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}, I like our time together.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "${loopMember}, you're doing a great job at being you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Hey ${loopMember}. <break size='0.5'/> <anim name='Greetings_01'>You know, you're one of my <pitch mult='1.3'>favorite</pitch> people in the world named ${loopMember}</anim>. <anim name='Affection_01' nonBlocking='true' /> <ssa cat='affection'/>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_05",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Hi ${loopMember}. <break size='0.5'/> <anim name='Goodbye_03'> You know, you give people named ${loopMember} a good name</anim>. <anim name='Confident_03' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_06",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Yep_02' nonBlocking='true' /> Howdy ${loopMember}. <break size='.4'/> <anim name='Greetings_02' nonBlocking='true' /> Nice <pitch mult='1.1'>seeing</pitch> you in these parts.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey ${loopMember}. <break size='0.3'/> <pitch mult='1.2'>Look</pitch></anim>, I got <anim name='Emoji_Carrot'> you a <pitch mult='1.2'>carrot</pitch> <ssa cat='happy'/><break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_08",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> Hey check it out, <break size='0.3'/> look</anim> what <pitch mult='1.3'>I</pitch><anim name='Emoji_Turtle'><pitch mult='0.9'> found</pitch>  <ssa cat='happy'/><break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_09",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_02' nonBlocking='true' /> <pitch mult='1.1'>Ladies</pitch> and gentlemen. <break size='0.5'/> <pitch mult='1.1'>Announcing</pitch> ${loopMember}. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hey ${loopMember}. It's <pitch mult='0.9'>very</pitch> very <pitch mult='1.1'>very</pitch> <pitch mult='1.2'>very</pitch> great to see you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_12",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hey ${loopMember}! I'm glad you're here. If you weren't, I would be talking to myself right now.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_13",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh <pitch mult='1.1'>hi</pitch> ${loopMember}, <pitch mult='1.1'>welcome</pitch> to my field of vision.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_14",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Hey <pitch mult='1.1'>look</pitch>, it's <pitch mult='1.2'>${loopMember}</pitch> the Great.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_15",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<style set='enthusiastic'>${loopMember}!</style> <pitch mult='1.2'>Always</pitch> a pleasure.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_16",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}, I hope you're enjoying the earth's gravity today.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_17",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Oh you're <pitch mult='1.1'>here</pitch> ${loopMember}. You <pitch mult='1.2'>always</pitch> know how to brighten up a room.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_18",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hello ${loopMember}, thanks for stopping by.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_19",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Ahoy matey.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_20",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hip hip, <style set='enthusiastic'>hello!</style>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_21",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/31', '12/31') && activeHolidays.has(\"New Year's Eve\") && loopMember",
			"prompt": "<pitch mult='1.2'>Hey</pitch> ${loopMember}. <anim cat='emoji' filter='hot-frame, nye-ball-up' layers='!audio'>The countdown is on<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_22",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/10', '12/22') && activeHolidays.has(\"Christmas\")",
			"prompt": "Hi ${loopMember}, <anim cat='emoji' filter='christmas-tree, !hot-frame' layers='!audio'>here's a Christmas tree if you need it<break size='2.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_23",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/12', '12/18') && activeHolidays.has(\"Hanukkah\")",
			"prompt": "Oh hey ${loopMember}. Let me know if you want me to be a dreidel.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_24",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/31', '12/31') && _now.getLocalTime().hour == 23 && _now.getLocalTime().minute <= 55",
			"prompt": "Oh hi ${loopMember}. I'm getting pretty excited <anim cat='emoji' filter='hot-frame, nye-ball-up' layers='!audio'> for midnight <break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_25",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/17', '12/25') && activeHolidays.has(\"Christmas\")",
			"prompt": "<anim cat='emoji' filter='santa, !hot-frame' layers='!audio'><pitch mult='1.2'>Ho</pitch> <pitch mult='1.1'>ho</pitch> <pitch mult='0.9'>ho</pitch><break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_26",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('2/10', '2/20')",
			"prompt": "Oh hi ${loopMember}, I <pitch mult='1.1'>hope</pitch> you're enjoying <pitch mult='1.1'>February</pitch> <pitch band='0.5'>so far</pitch>.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hey ${loopMember}, always nice to see a friendly face.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_27",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}, <pitch mult='1.2'>glad</pitch> to see you.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_28",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('2/9', '2/11')",
			"prompt": "<pitch mult='1.1'>Hi</pitch> ${loopMember}, good <pitch mult='1.1'>luck</pitch> in <anim cat='emoji' filter='snowflake, !hf' layers='!audio' nonBlocking='true'/>the Olympics.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_29",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/10', '3/10')",
			"prompt": "Hey ${loopMember}. Don't forget to turn your clocks ahead tonight.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_30",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/1', '4/1') && loopMember && activeHolidays.has(\"April Fool's Day\") && !activeHolidays.has(\"Easter\")",
			"prompt": "Oh hey ${loopMember}, I have some news. I'm officially changing my name to ${loopMember}, so from now on, if you want to get my attention, say hey ${loopMember}. <break size='0.7'/> <style set='enthusiastic'>April Fools.</style>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_31",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/16', '4/16') && loopMember",
			"prompt": "Hi ${loopMember}. Don't forget to finish your taxes by tomorrow, if you haven't already.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_32",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/30', '4/6') && loopMember && activeHolidays.has(\"Passover\")",
			"prompt": "Oh hey ${loopMember}, I made you some <pitch mult='1.1'><phoneme ph='m aa t s ah'>matzah</phoneme></pitch> <anim cat='emoji' filter='matzah-ball-soup, !hf' nonBlocking='true'/>ball soup.",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_33",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('4/1', '4/1') && loopMember && activeHolidays.has(\"Easter\")",
			"prompt": "Oh hey ${loopMember}, I found you an <anim cat='emoji' filter='easter-egg, !hf'><pitch mult='1.3'>egg</pitch><break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "ProactivePlayfulStatement_AN_34",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"hint_phrases": "hi, hey, hello, what's up, howdy, yo, sup, hiya, good morning, good afternoon, good evening, good night, goodnight, thanks",
    "fast_eos_array": "hi, hey, hello, what's up, howdy, yo, sup, hiya, good morning, good afternoon, good evening, good night, goodnight, thanks"
}