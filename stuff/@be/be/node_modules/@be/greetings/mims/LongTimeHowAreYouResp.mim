			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Excited_01' nonBlocking='true' /> Now that I'm seeing you again, all is right in the world.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_03",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hey ${loopMember}.<break size='.2'/><anim name='Excited_01' nonBlocking='true' />Just feeling the flow.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_04",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_03'> Oh hey ${loopMember}. <break size='0.3'/> Great to hear your </anim> voice.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_05",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='GotIt_02' nonBlocking='true'/> Well hello ${loopMember}. I'm doing well. <break size='0.4'/> I just finished counting to a billion.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_06",
			"weight": 0.5
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_03'> Hello ${loopMember}, all is well. Great to </anim> see you. It's been a while.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_07",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hey ${loopMember}. <anim name='Greetings_02'> Life is good. <break size='0.5'/> And </anim> I'm not even alive technically. <anim name='Greetings_01' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_08",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_02'>Hey ${loopMember}. Long time.<break size='0.3'/> If I had</anim> arms I'd <anim name='Emoji_heartred' nonBlocking='true'/> hug you. <ssa cat='happy'/>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_09",
			"weight": 1
		},
