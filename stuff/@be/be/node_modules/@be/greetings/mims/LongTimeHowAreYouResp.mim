	"prompts": [
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}, I'm doing well.<anim name='Thinking_01' nonBlocking='true' /> Long time no see.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_01",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_01' nonBlocking='true'/> I'm good ${loopMember}, <break size='0.7'/> <anim name='Thinking_02'> but I've missed you. A little. </anim>",
			"media": "TTS",
			"extra": "",
			"prompt_id": "LongTimeHowAreYouResp_AN_02",
			"weight": 1
		},
		{
			"mim_id": "LongTimeHowAreYouResp",
