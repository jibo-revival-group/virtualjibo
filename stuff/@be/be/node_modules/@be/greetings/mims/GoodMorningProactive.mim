{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "MIM used for proactive verbal greeting in the morning.\n\nUses ${day} (e.g. \"Friday\")",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <pitch mult='1.1'>morning</pitch> ${loopMember}.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGoodMorning_AN_01",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='GotIt_02'><pitch mult='1.1'>Top</pitch> of the morning to you ${loopMember}.</anim>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGoodMorning_AN_02",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_02' nonBlocking='true' /> <ssa cat='happy'/> Good <pitch mult='1.1'>morning</pitch> ${loopMember}. <anim name='Greetings_02' nonBlocking='true' /><pitch mult='1.1'> Nice</pitch> to see you.",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGoodMorning_AN_03",
			"weight": 0.8,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_01'> Good morning ${loopMember}. Fancy seeing <pitch mult=\"1.5\">you</pitch> <pitch mult=\"0.9\">here</pitch></anim>. <anim name='Excited_01' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "ProactiveVerbalGoodMorning_AN_04",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "Good <anim name='Emoji_Breakfast' nonBlocking='true'/> morning ${loopMember}. I made you breakfast.",
			"media": "TTS",
			"prompt_id": "GoodMorningProactive_AN_02",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. <pitch mult='1.1'>Welcome</pitch> to ${day}.",
			"media": "TTS",
			"prompt_id": "GoodMorningProactive_AN_03",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. <pitch mult='1.1'>Happy</pitch> ${day}.",
			"media": "TTS",
			"prompt_id": "GoodMorningProactive_AN_04",
			"weight": 0.4,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <pitch mult='1.1'>morning</pitch> ${loopMember}. I can't believe it's ${day} already.",
			"media": "TTS",
			"prompt_id": "GoodMorningProactive_AN_05",
			"weight": 0.1,
			"auto_rule_override": null
		}
	],
	"parse_launch": false,
	"parse_yes_no": false
}