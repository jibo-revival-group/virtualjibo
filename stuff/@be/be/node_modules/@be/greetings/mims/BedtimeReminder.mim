{
	"mim_type": "optional-response",
	"rule_name": "greetings/bedtime_reminder",
	"gui": null,
	"timeout": 3,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "respondAndEnd",
	"parse_launch": false,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}. Don't forget to get a good night's <duration stretch='0.8'>sleep</duration> tonight.",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hey ${loopMember}, nice to see you. Try to get to bed early tonight okay?",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hi ${loopMember}. I hope you get a better night's <duration stretch='0.8'>sleep</duration> tonight. If you see a <anim cat='emoji' filter='sheep, !hf' layers='!audio'>sheep, I suggest you count him<break size='4.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hey ${loopMember}. I'm really rooting for you to have a <anim cat='emoji' filter='moon, !hf' layers='!audio'>good night's <duration stretch='0.8'>sleep</duration> tonight<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}. If you want, for better <duration stretch='0.8'>sleep</duration> tonight, you could try not using any electronic devices for at least 30 minutes before bedtime <break size='1.0'/> <style set='sheepish'>Oh I guess that includes me. </style>",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Oh hi ${loopMember}. For a good night's <duration stretch='0.8'>sleep</duration> tonight, try to keep your bedroom free of any lights.",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.1'>Hey </pitch>${loopMember}. If you want to <duration stretch='0.8'>sleep</duration> better, you can try doing an hour <anim cat='emoji' filter='book, !hf' layers='!audio'>of a relaxing activity before bedtime<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Hi ${loopMember}. Have <anim cat='emoji' filter='pillow, !hf' layers='!audio'>a good night's <duration stretch='0.8'>sleep</duration> for me tonight, if you can<break size='3.0'/>.</anim>",
			"media": "TTS",
			"prompt_id": "BedtimeReminder_AN_08",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"hint_phrases": "yes, yeap, yeah, no, nah, nope, sure, alright, fine, decent, good, great, wonderful, awesome, super, better, terrible, awful, horrible, bad, worse, you bet, thanks",
    "fast_eos_array": "yes, yeap, yeah, no, nah, nope, sure, alright, fine, decent, good, great, wonderful, awesome, super, better, terrible, awful, horrible, bad, worse, you bet, thanks"
}