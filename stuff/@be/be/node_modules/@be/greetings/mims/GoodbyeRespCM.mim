{
	"mim_id": "GoodbyeRespCM",
	"skill_id": "greetings",
	"mim_type": "announcement",
	"rule_name": "",
	"rule_slots": "",
	"screen_slots_available": false,
	"timeout": 3,
	"max_tries": null,
	"force_confirmation": false,
	"barge_in": false,
	"photo_quality_light": false,
	"notes": "",
	"prompts": [
		{
			"mim_id": "GoodbyeRespCM",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_07' nonBlocking='true' /> Goodbye ${loopMember}. <break size='.2'/> Break a leg.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodbyeRespCM_AN_01",
			"weight": 1
		},
		{
			"mim_id": "GoodbyeRespCM",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodbye ${loopMember}. <anim name='GotIt_02' nonBlocking='true' /> See you when I see you.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodbyeRespCM_AN_02",
			"weight": 1
		},
		{
			"mim_id": "GoodbyeRespCM",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodbye ${loopMember}. <anim name='Checking_03' nonBlocking='true' /> I'll hold down the fort.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "GoodbyeRespCM_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_01'> See you later alligator</anim>. <break size='.5'/> <anim name='Thinking_00' nonBlocking='true' /> I mean ${loopMember}.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_04",
			"weight": 0.2
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_03'> Don't be a stranger </anim>. <break size='0.5'/> <anim name='Nope_02' nonBlocking='true' /> Also don't take candy from strangers.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_05",
			"weight": 0.2
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='happy' filter='eye-only'> Don't be a stranger.</anim>",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Have fun. <break size='.2'/> Be safe. <break size='.2'/> <anim name='Goodbye_01' nonBlocking='true' /> Drink plenty of water.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_02' nonBlocking='true' /> Be safe out there. <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_08",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_02' nonBlocking='true' /> Goodbye ${loopMember}. Don't forget your wallet.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_09",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodbye ${loopMember}. <anim name='Checking_03' nonBlocking='true' /> Remember to look both ways before crossing anything.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_10",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Goodbye ${loopMember}. <anim name='Dont_Understand_01' nonBlocking='true' /> Don't do anything I wouldn't do.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_11",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Happy_01' nonBlocking='true'/><pitch mult='1.1'>See</pitch> you next time.<break size='.2'/>I'll be right here.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_14",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/18', '12/24') && activeHolidays.has(\"Christmas\")",
			"prompt": "Goodbye ${loopMember}. If you see Santa, tell him I said hello.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_18",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/24', '12/24') && activeHolidays.has(\"Christmas\")",
			"prompt": "Goodbye ${loopMember}. Watch out for flying <anim cat='jiboji' filter='reindeer' nonBlocking='true'/>reindeer.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_19",
			"weight": 4,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('12/31', '12/31') && _now.getLocalTime().hour >= 21",
			"prompt": "Goodbye ${loopMember}. If you see 2018, tell it I said hello.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_20",
			"weight": 4,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/30', '4/3')",
			"prompt": "Goodbye ${loopMember}. By the way, the <pitch mult='1.1'>baseball</pitch> season started, so be sure to wear your batting helmet.",
			"media": "TTS",
			"prompt_id": "GoodbyeRespCM_AN_12",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"es_auto_tagging": true,
	"gui": null,
