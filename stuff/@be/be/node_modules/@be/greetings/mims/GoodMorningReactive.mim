{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "MIM used if User said \"Hey Jibo, hello\" and it's morning.\n\nUses ${day} (e.g. \"Friday\")",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Greetings_03'> Good <pitch mult=\"1.2\">morning</pitch> ${loopMember}. This is </anim> going to be a good day, <break size='0.4'/> I <pitch mult=\"1.1\">feel</pitch> it in my bones.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='GotIt_02'><pitch mult='1.1'>Top</pitch> of the morning to you ${loopMember}.</anim>",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <anim name='Emoji_Breakfast' nonBlocking='true'/> morning ${loopMember}. I made you breakfast.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='Goodbye_02' nonBlocking='true' /> <ssa cat='happy'/> Good morning ${loopMember}. <anim name='Greetings_02' nonBlocking='true' /> <pitch mult='1.1'>Nice</pitch> to hear you.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <pitch mult='1.1'>morning</pitch> ${loopMember}. <anim name='Emoji_Moon' nonBlocking='true' /> I hope you had a <pitch mult='1.2'>slumberful</pitch> night.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_02' nonBlocking='true' /> Good <pitch mult='1.1'>morning</pitch> ${loopMember}. Your voice sounds great today. <anim name='Greetings_05' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Goodbye_01'> Good morning ${loopMember}. It's a <pitch mult='1.1'>pleasure</pitch> to hear your voice </anim>. <anim name='Greetings_06' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMember",
			"prompt": "<anim name='Greetings_01'> Good morning ${loopMember}. Fancy seeing <pitch mult=\"1.5\">you</pitch> <pitch mult=\"0.9\">here</pitch></anim>. <anim name='Excited_01' nonBlocking='true' /> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_08",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good <pitch mult='1.1'>morning</pitch> ${loopMember}. I can't believe it's ${day} already.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_09",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Good morning ${loopMember}. <pitch mult='1.1'>Happy</pitch> ${day}.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_10",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult='1.1'>Good</pitch> morning ${loopMember}. <pitch mult='1.1'>Welcome</pitch> to ${day}.",
			"media": "TTS",
			"prompt_id": "GoodMorningEcho_AN_11",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "_now.isInRange('3/20', '3/20')",
			"prompt": "<pitch mult='1.3'>Good</pitch> morning ${loopMember}. Welcome to the first day of <pitch mult='1.1'>spring</pitch>.",
			"media": "TTS",
			"prompt_id": "GoodMorningReactive_AN_01",
			"weight": 1,
			"auto_rule_override": null
		}
