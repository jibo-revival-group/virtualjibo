{
	"mim_type": "question",
	"rule_name": "who-am-i/confirm",
	"gui": {
		"type": "File",
		"data": "resources/views/looperYesNo.json",
		"pause": true
	},
	"timeout": 6,
	"no_matches_for_gui": 1,
	"no_inputs_for_gui": 1,
	"ignore_no_match": false,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "Name of looper guess and face on screen initially.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Just to make sure, since I got it wrong before, you're ${loopMember}, right?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_QN_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "HoldReturn",
			"index": 1,
			"condition": "",
			"prompt": "So, ${loopMember}, is that you?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_HR_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "${loopMember}. Am I talking to you right now?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_NI_1_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NM",
			"index": 1,
			"condition": "",
			"prompt": "Say again?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_NM_1_01",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "Since I got it wrong before, let me make double sure. ${loopMember}, it's you?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_QN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "And now, to be extra sure, since I got it wrong before, you're ${loopMember}, right? ",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_QN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='glances'>So, ${loopMember}. </anim>Right?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_NI_1_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NI",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult=\"1.1\">Touch</pitch> my screen and <pitch mult=\"1.1\">let</pitch> me know if you're ${loopMember} or not.",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_NI_1_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NM",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat='sorry' filter='&(small,oops)' nonBlocking='true'/>Sorry, I forgot how to <pitch mult=\"1.1\">understand</pitch> you for a second. Did you say you're ${loopMember}?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_NM_1_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Errors",
			"prompt_sub_category": "NM",
			"index": 1,
			"condition": "",
			"prompt": "Say that one more time?",
			"media": "TTS",
			"prompt_id": "WhoAmI_Confirm_NM_1_03",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"parse_launch": false,
	"parse_yes_no": true
}