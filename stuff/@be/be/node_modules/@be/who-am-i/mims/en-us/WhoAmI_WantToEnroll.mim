			"index": 1,
			"condition": "wantToEnroll==='all'",
			"prompt": "It <pitch mult=\"1.1\">looks</pitch> like we haven't officially <pitch mult=\"1.1\">met </pitch>yet. I can learn your voice and face, so I'll recognize you in the future. Want to do that now?",
			"media": "TTS",
