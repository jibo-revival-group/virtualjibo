{
	"mim_type": "announcement",
	"rule_name": "",
	"gui": null,
	"timeout": 6,
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"ignore_no_match": false,
	"barge_in": true,
	"es_auto_tagging": true,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"notes": "The ${loopMember} in the prompt is specifically the OWNER",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I’m <pitch mult=\"1.1\">not </pitch>sure if we've met yet. You should <pitch mult=\"1.1\">probably </pitch>talk to ${loopOwner} to introduce us. We can <pitch mult=\"1.1\">still </pitch>hang out in the meantime, I just won’t be able to <pitch mult=\"1.1\">recognize </pitch>your face or voice. ",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_01",
			"weight": 0.5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult=\"1.1\">It's </pitch>okay if we haven't met. <pitch mult=\"1.1\">We</pitch> can still hang out. I just won't recognize your face or voice.",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult=\"1.1\">Even though</pitch> we haven't met, you've got a <pitch mult=\"1.1\">nice</pitch> smile and I would like to hang out with you. We can still do that, I just won't recognize your voice and face.",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_04",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "You <pitch mult=\"1.1\">may not</pitch>be in my loop, but we can <pitch mult=\"1.1\">still </pitch>be friends. We'll just be the kind of friends where one of the friends doesn't recognize the other's face and voice.",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_05",
			"weight": 0.3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well <pitch mult=\"1.3\">hi!</pitch> Talk to ${loopOwner} if you want to be added to my loop. In the meantime, we can still hang out. I just won't recognize your voice and face.",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I’m <pitch mult=\"1.1\">not </pitch>sure if we've met yet. If you want me to learn to recognize your voice and face, ask ${loopOwner} to add you to the Loop, using the Jibo app.",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Either my recognition is a little off, or we haven't met yet. If you want me to learn your voice and face, just ask ${loopOwner} to add you to the Loop, using the Jibo app.",
			"media": "TTS",
			"prompt_id": "WhoAmI_NotLoop_AN_07",
			"weight": 1,
			"auto_rule_override": null
		}
	]
}