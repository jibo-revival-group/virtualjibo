{
	"mim_type": "question",
	"rule_name": "who-am-i/name_is_right",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Surface looper menu here? Is that possible?\n\nNeed loopMember variable in TTS.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "",
			"prompt": "You're ${loopMember}. Right?",
			"media": "TTS",
			"prompt_id": "WhoAmI_NameIsRight_QN_01",
			"weight": 1
		},
		{
			"prompt_category": "Errors",
