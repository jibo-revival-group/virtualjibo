		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "gender==\"male\"",
			"prompt": "My <pitch mult=\"1.1\">results</pitch> suggest either ${loopMember}, or Abraham Lincoln? Is one of those right?",
			"media": "TTS",
