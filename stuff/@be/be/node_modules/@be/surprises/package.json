  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "",
    "prompt": "",
    "display-name": "surprises"
  },
  "monorailConfig": {
    "public": false
  },
  "scripts": {
    "start": "yarn watch",
    "build": "gulp debug",
    "build:release": "gulp",
    "clean": "gulp clean-all",
    "watch": "gulp watch",
    "test": "gulp test && istanbul report && yarn coverage:check",
    "coverage:report": "istanbul report && open coverage/lcov-report/index.html",
    "coverage:check": "istanbul check-coverage --statements 40 --branches 30 --functions 30 --lines 40",
    "coverage:remap": "remap-istanbul --input ./coverage/coverage-final.json --output ./coverage/coverage-final.json",
    "test:report": "gulp test-report",
    "test:debug": "gulp test --debug"
  },
  "files": [
    "lib",
    "index.html"
  ],
  "eslintConfig": {
    "extends": "eslint:recommended",
    "rules": {
      "no-console": 0,
      "no-debugger": 1
    },
    "parserOptions": {
      "ecmaVersion": 6,
      "sourceType": "module"
    },
    "env": {
      "browser": true,
      "node": true
    },
    "globals": {
      "expect": true,
      "sinon": true,
      "jibo": true,
      "PIXI": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=6.0"
  },
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "async": "^2.0.1",
    "gulp": "^3.9.1",
    "istanbul": "^0.4.5",
    "jibo": "^14.0.0",
    "jibo-gulp": "^8.0.0",
    "skills-service-manager": "^14.0.0"
  }
}