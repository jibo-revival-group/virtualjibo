{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es6",
        "noImplicitAny": false,
        "noUnusedLocals": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "allowUnreachableCode": true,
        "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
        "types": ["node", "pixi.js"],
        "declaration": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ],
    "compileOnSave": false
}
