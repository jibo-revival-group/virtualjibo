                            jibo.expression.acquireTarget({ entity: blackboard.originalFace }).then(acquireHandle => {
                                return acquireHandle.promise;
                            }).then(() => {
                                done();
                            }).catch(err => {
                                blackboard.log.warn('acquireTarget failed. ', err);
                                done('noFace');
                            });
                        } else {
