{
  "name": "@be/remote",
  "version": "3.3.3",
  "description": "Remote operation mode skill",
  "main": "index.js",
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "",
    "prompt": "",
    "display-name": "remote"
  },
  "license": "UNLICENSED",
  "distribution": "PROPRIETARY AND CONFIDENTIAL - NOT FOR DISTRIBUTION",
  "copyright": "Copyright (c) 2014-2018 Jibo, Inc. All Rights Reserved",
  "config": {
    "standalone": true
  },
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "scripts": {
    "start": "jibo-dev watch",
    "watch": "jibo-dev watch",
    "build": "jibo-dev build",
    "clean": "jibo-dev clean",
    "build:release": "jibo-dev build --prod",
    "prerelease": "yarn clean && yarn prebuild",
    "sync": "jibo-rsync",
    "addsshkey": "jibo-rsync --init",
    "test": "floss --path tests/index.js",
    "test:disabled": "floss --path tests/index.js",
    "test:debug": "yarn test --debug",
    "testdebug": "yarn test --debug",
    "test:report": "yarn test -- --reporter=spec,xunit"
  },
  "files": [
    "mims",
    "animdb-manifest.json",
    "index.*"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "dependencies": {},
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "@jibo/floss": "^2.0.0",
    "@be/skills-test-utils": "^4.0.0",
    "@types/jibo-command-protocol": "^2.7.0",
    "jibo": "^14.0.0",
    "jibo-anim-db-animations": "19.0.2",
    "jibo-dev": "^5.0.0",
    "jibo-rsync": "^4.0.0"
  },
  "syncDependencies": [
    "jibo",
    "jibo-anim-db-animations",
    "@be/be-framework"
  ]
}