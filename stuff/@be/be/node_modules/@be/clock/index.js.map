        '412841e5-4dd1-4c8f-8894-224ef61ed8d9': function () {
            return {
                'id': '412841e5-4dd1-4c8f-8894-224ef61ed8d9',
                'name': 'Range within 24 hours?',
                'asset-pack': 'core',
                'transitions': [
                    {
                        'frm': '412841e5-4dd1-4c8f-8894-224ef61ed8d9',
                        'to': 'c790f982-8349-4b4e-97d1-308c01ebd422',
                        'value': 'true'
                    },
                    {
                        'frm': '412841e5-4dd1-4c8f-8894-224ef61ed8d9',
                        'to': '192f830f-fa2e-4065-9a19-cd685f4610e1',
                        'value': 'false'
                    }
                ],
                'exceptions': [],
                'class': 'Flow.Eval',
                'options': {
                    'Script': () => {
                        let skill = blackboard.alarmTimer;
                        let within24Hours = !!skill.isRangeUnder24Hrs(skill._result) && !!skill.isRangeOver5Seconds(skill._result);
                        if (!within24Hours) {
                            blackboard.alarmTimer.setGuiData(blackboard.alarmTimer._result);
                        }
                        return within24Hours;
                    }
                }
            };
        },
        'c790f982-8349-4b4e-97d1-308c01ebd422': function () {
            return {
                'id': 'c790f982-8349-4b4e-97d1-308c01ebd422',
                'name': 'Set or Edit?',
                'asset-pack': 'core',
                'transitions': [
                    {
                        'frm': 'c790f982-8349-4b4e-97d1-308c01ebd422',
                        'to': 'da695f0f-a50a-4201-8221-9c883e817943',
                        'value': 'set'
                    },
                    {
                        'frm': 'c790f982-8349-4b4e-97d1-308c01ebd422',
                        'to': 'c5177e82-644e-46eb-9ce7-d8fc8d06a975',
                        'value': 'edit'
                    }
                ],
                'exceptions': [],
                'class': 'Flow.Eval-Async',
                'options': {
                    'exec': done => {
                        let intent = blackboard.alarmTimer._intent;
                        if (intent === 'set' || intent === 'start') {
                            done('set');
                        } else if (intent === 'query' || intent === 'stop' || intent === 'delete' || intent === 'edit') {
                            if (blackboard.alarmTimer.valueAtLaunch()) {
                                return blackboard.alarmTimer.changeAlarmTimer(false).then(() => {
                                    done('edit');
                                }, err => {
                                    blackboard.alarmTimer.handleViewError(err);
                                    done('~error');
                                });
                            } else {
                                done('edit');
                            }
                        }
                    },
                    'onStop': () => {
                    }
                }
            };
        },
