        '9e86c966-cd4c-4778-877b-a4688b79a4ea': function () {
            return {
                'id': '9e86c966-cd4c-4778-877b-a4688b79a4ea',
                'name': 'Alarm Timer_ Alarm Edit',
                'asset-pack': 'core',
                'transitions': [{
                        'frm': '9e86c966-cd4c-4778-877b-a4688b79a4ea',
                        'to': '72f64101-864c-48e8-a1a4-a337becd9dd4',
                        'value': ''
                    }],
                'exceptions': [],
                'class': 'Mim.Optional-Response',
                'options': {
                    'mimPath': 'mims/AlarmTimer_AlarmEdit.mim',
                    'getPromptData': () => {
                        return {};
                    },
                    'onStatus': status => {
                        let mimState = status.state;
                        let asrResults = status.asrResults;
                    },
                    'onSuccess': results => {
                        let mimState = results.state;
                        let asrResults = results.asrResults;
                        let transition = results.firstGrammarTag;
                        if (results.state.lastResultState === 'noInput') {
                            return '~close';
                        }
                        let result = blackboard.alarmTimer.createTimeObject(results.asrResults);
                        if (result.intent === 'cancel') {
                            return '~close';
                        }
                        blackboard.alarmTimer.sanitizeInput(result.ampm, result.time);
                        let ampm = blackboard.alarmTimer._ampm;
                        let time = blackboard.alarmTimer._time;
                        blackboard.alarmTimer._result = {
                            ampm,
                            time
                        };
                        return transition;
                    }
                }
            };
        },
        '4be205a4-2c81-48ae-bd9d-acc7a2dea254': function () {
            return {
                'id': '4be205a4-2c81-48ae-bd9d-acc7a2dea254',
                'name': 'Alarm Timer_ Timer Edit',
                'asset-pack': 'core',
                'transitions': [{
                        'frm': '4be205a4-2c81-48ae-bd9d-acc7a2dea254',
                        'to': '72f64101-864c-48e8-a1a4-a337becd9dd4',
                        'value': ''
                    }],
                'exceptions': [],
                'class': 'Mim.Optional-Response',
                'options': {
                    'mimPath': 'mims/AlarmTimer_TimerEdit.mim',
                    'getPromptData': () => {
                        return {};
                    },
                    'onStatus': status => {
                        let mimState = status.state;
                        let asrResults = status.asrResults;
                    },
                    'onSuccess': results => {
                        let mimState = results.state;
                        let asrResults = results.asrResults;
                        let transition = results.firstGrammarTag;
                        if (results.state.lastResultState === 'noInput') {
                            return '~close';
                        }
                        let result = blackboard.alarmTimer.createTimeObject(results.asrResults);
                        if (result.intent === 'cancel' || results.state.lastResultState === 'noInput') {
                            return '~close';
                        }
                        blackboard.alarmTimer._result = result;
                        return transition;
                    }
                }
            };
        },
