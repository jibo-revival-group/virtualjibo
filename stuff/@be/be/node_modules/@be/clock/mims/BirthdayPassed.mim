			"media": "TTS",
			"prompt_id": "BirthdayPassed_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Not that long ago in fact. It was on ${month} ${day}.",
			"media": "TTS",
			"prompt_id": "BirthdayPassed_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "Your birthday is behind you. It was on ${month} ${day}.",
			"media": "TTS",
			"prompt_id": "BirthdayPassed_AN_04",
