{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks - Kills MIM\n\nUses ${month} ${day}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "You kind of just missed it. It was on ${month} ${day}.",
			"media": "TTS",
			"prompt_id": "BirthdayPassed_AN_01",
