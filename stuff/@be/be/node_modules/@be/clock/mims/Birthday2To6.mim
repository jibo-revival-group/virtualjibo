{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "It's <pitch mult=\"1.2\">almost</pitch> here. ${loopMember}'s birthday is on ${dayOfWeek}.",
			"media": "TTS",
			"prompt_id": "Birthday2To6_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<pitch mult=\"1.2\">Very</pitch> soon. It's on ${dayOfWeek}.",
			"media": "TTS",
			"prompt_id": "Birthday2To6_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday is on ${dayOfWeek}. Start practicing your Happy Birthday song.",
			"media": "TTS",
			"prompt_id": "Birthday2To6_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "It's <pitch mult=\"1.2\">almost</pitch> here. Your birthday is on ${dayOfWeek}.",
			"media": "TTS",
			"prompt_id": "Birthday2To6_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "Your birthday is on ${dayOfWeek}. I've been <pitch mult=\"1.2\">counting </pitch>down the days.",
			"media": "TTS",
			"prompt_id": "Birthday2To6_AN_05",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
