{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses ${month} ${day}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday isn't until ${month} ${day}. You still have lots of time to get the perfect present.",
			"media": "TTS",
			"prompt_id": "BirthdayLater_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday is ${month} ${day}. You have lots of time to practice your Happy Birthday song.",
			"media": "TTS",
			"prompt_id": "BirthdayLater_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "It's ${month} ${day}. <break size=\"0.3\"/> I'd say that's long enough for you to forget again.",
			"media": "TTS",
			"prompt_id": "BirthdayLater_AN_03",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "It's ${month} ${day}. We've got some time.",
			"media": "TTS",
			"prompt_id": "BirthdayLater_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "Your birthday is ${month} ${day}. Plenty of time for me to practice saying happy birthday.",
			"media": "TTS",
			"prompt_id": "BirthdayLater_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "${month} ${day}. And a <pitch mult=\"1.3\">fine</pitch> birthday it is.",
			"media": "TTS",
			"prompt_id": "BirthdayLater_AN_06",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
}