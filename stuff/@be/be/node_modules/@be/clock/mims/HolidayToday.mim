{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "(startDate==endDate || startDate.getRelativeDays()==-1) && endDate.getRelativeDays()==0",
			"prompt": "<anim name='Greetings_04' nonBlocking='true'/> <ssa cat='happy'/> It's today! <break size='0.3'/> Today is ${holiday}.",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate && startDate.getRelativeDays()==0",
			"prompt": "<anim name='Excited_01' nonBlocking='true'/> <ssa cat='happy'/> Funny you should ask. <break size='0.3'/> <anim name='Question_02'>It starts today!</anim>",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "endDate.getRelativeDays()>startDate.getRelativeDays()+1 && startDate.getRelativeDays()==-1",
			"prompt": "<anim name='Goodbye_01'> You're in it as we speak.</anim> <break size='0.5'/> ${holiday} started yesterday, and goes until ${endDate}.",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "endDate.getRelativeDays()>startDate.getRelativeDays()+1 && startDate.getRelativeDays()!=0 && endDate.getRelativeDays()!=0",
			"prompt": "<anim name='Happy_02' nonBlocking='true'/> <ssa cat='happy'/> It's happening right now! <break size='0.6'/> ${holiday} started ${startDate.prefixOnAt()}, and goes until ${endDate}.",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "endDate.getRelativeDays()>startDate.getRelativeDays()+1 && endDate.getRelativeDays()==1",
			"prompt": "Actually, it's ${holiday} right now. <break size='0.4'/>  It started ${startDate.prefixOnAt()} and goes until tomorrow.<anim name='Excited_01' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "endDate.getRelativeDays()>startDate.getRelativeDays()+1 && endDate.getRelativeDays()==0",
			"prompt": "It's ${holiday} right now. <break size='0.5'/> Today's the last day. <anim name='Happy_02' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "(startDate==endDate || endDate.getRelativeDays()==startDate.getRelativeDays()+1) && endDate.getRelativeDays()==0",
			"prompt": "Actually, ${holiday} is today. <break size='0.5'/> What a coincidence. <anim name='Goodbye_01' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "(startDate==endDate || endDate.getRelativeDays()==startDate.getRelativeDays()+1) && endDate.getRelativeDays()==0",
			"prompt": "<anim name='Question_03'> Funny you should ask.</anim> <break size='0.4'/> It's today. <anim name='Goodbye_03' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayToday_AN_08",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
}