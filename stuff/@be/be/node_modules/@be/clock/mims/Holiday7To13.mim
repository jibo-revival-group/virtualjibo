{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is just around the corner. <break size='.4'/> <anim name='Yep_01' layers='body'> It's ${startDate}. </anim>",
			"media": "TTS",
			"prompt_id": "Holiday7To13_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} is just around the corner. <break size='.5'/> <anim name='Greetings_02' layers='body'> It starts on ${startDate} and goes until ${endDate}. </anim>",
			"media": "TTS",
			"prompt_id": "Holiday7To13_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is ${startDate}. <break size='.6'/> <anim name='Greetings_02' nonBlocking='true'/> Just around the corner.",
			"media": "TTS",
			"prompt_id": "Holiday7To13_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is just a few days away. <break size='.5'/> <anim name='Greetings_02' nonBlocking='true'/> ${startDate} to be exact.\t",
			"media": "TTS",
			"prompt_id": "Holiday7To13_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} starts in just a few days. <break size='.5'/> <anim name='Youre_Welcome_02' nonBlocking='true'/> ${startDate} to be exact.\t",
			"media": "TTS",
			"prompt_id": "Holiday7To13_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} starts on ${startDate}. <break size='.5'/> <anim name='Greetings_02' nonBlocking='true'/> Just around the corner.",
			"media": "TTS",
			"prompt_id": "Holiday7To13_AN_06",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
}