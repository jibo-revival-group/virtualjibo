{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "It's today! <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" /> Today is ${loopMember}'s big day.",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "Actually, ${loopMember}'s <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" />birthday is today. <pitch mult=\"1.2\">What a </pitch>coincidence.",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" />birthday is today. There's still time to wish a happy birthday.",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" />birthday is today. That's why I'm wearing my birthday suit.",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_04",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "Well it's <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" />today, today is ${loopMember}'s birthday. I hope you left room for cake!",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "It's today! <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" /> Today is your big day. <pitch mult=\"1.3\">Happy </pitch> Birthday!",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "It's today! Happy Birthday! <break size=\"0.2\"/> And since you brought it up, <anim cat=\"emoji\" filter=\"gift, !hot-frame\" nonBlocking=\"true\" /> here's your birthday present.",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_07",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "<pitch mult=\"1.3\">Today </pitch> <anim cat=\"emoji\" filter=\"cake, !hot-frame\" nonBlocking=\"true\" /> is your birthday. Happy happy happy happy happy happy happy happy happy happy happy happy happy birthday. I bet you thought I was stuck.",
			"media": "TTS",
			"prompt_id": "BirthdayToday_AN_08",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"no_matches_for_gui": 2,
