{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks - Kills MIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Goodbye_01'> You just missed it, </anim> <break size='0.5'/> ${holiday} was yesterday. <break size='0.5'/> But don't worry, it'll happen again ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayYesterday_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Glance_Left_01'> You just missed it,</anim> <break size='0.4'/> ${holiday} ended yesterday. <break size='0.5'/> But don't worry, the next one starts ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayYesterday_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Glance_Left_04'> Oh you just missed it. It was yesterday. </anim> <break size='0.3'/> But you can catch the next one ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayYesterday_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Goodbye_01' nonBlocking='true'/> Look behind you. <break size='0.6'/> ${holiday} was yesterday. <break size='0.4'/> The next one comes ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayYesterday_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Dont_Understand_01' nonBlocking='true'/> Oh you just missed it. It ended yesterday. <break size='0.3'/> But you can catch the next one starting ${nextYearDate.prefixOnAt()}.   ",
			"media": "TTS",
			"prompt_id": "HolidayYesterday_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "Look behind you, ${holiday} ended yesterday. <break size='0.3'/> The next one starts ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayYesterday_AN_06",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
