{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks - Kills MIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Glance_Left_03' nonBlocking='true'/> You kind of just missed it. <break size='0.3'/> ${holiday} was ${endDate.prefixOnAt()}. <break size='0.5'/> Next time it'll be ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayPassed_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Glance_Right_04' nonBlocking='true'/> You kind of just missed it. <break size='0.3'/> ${holiday} ended ${endDate.prefixOnAt()}. <break size='0.5'/> Next time it'll start ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayPassed_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is behind you. <break size='0.4'/> It was ${endDate.prefixOnAt()}. <break size='0.3'/> <anim name='Glance_Right_04' nonBlocking='true'/> The next one will be ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayPassed_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": " <anim name='Question_02'> Not that long ago in fact.</anim> <break size='0.3'/> It was ${endDate.prefixOnAt()}. <break size='0.3'/> You can catch the next one ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayPassed_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} is behind you. <break size='0.7'/> <anim name='Glance_Left_03' nonBlocking='true'/> It ended ${endDate.prefixOnAt()}. <break size='0.3'/> The next one will start ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayPassed_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": " <anim name='Dont_Understand_01'> Not that long ago in fact. </anim> <break size='0.3'/> It ended ${endDate.prefixOnAt()}. <break size='0.3'/> You can catch the next one starting ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayPassed_AN_06",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
