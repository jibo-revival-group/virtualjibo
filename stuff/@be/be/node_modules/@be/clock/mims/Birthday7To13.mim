			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "Your birthday is <pitch mult=\"1.2\">just </pitch>around the corner. It's ${month} ${day}.",
			"media": "TTS",
			"prompt_id": "Birthday7To13_AN_05",
			"weight": 1,
