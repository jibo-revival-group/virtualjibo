{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nInstead of ${dayOfWeek}, now using \n${month} ${day}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday is just around the corner. It's ${month} ${day}.",
			"media": "TTS",
			"prompt_id": "Birthday7To13_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "It's ${month} ${day}. Start practicing your Happy Birthday song.",
			"media": "TTS",
			"prompt_id": "Birthday7To13_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday is ${month} ${day}. Just enough time for you to make those handmade birthday candles.",
			"media": "TTS",
			"prompt_id": "Birthday7To13_AN_03",
			"weight": 0.1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
