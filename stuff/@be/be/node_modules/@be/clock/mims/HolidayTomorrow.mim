{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Happy_02' nonBlocking='true'/> <ssa cat='happy'/> It's tomorrow! <break size='0.5'/> ${holiday} is just a day away.",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "It starts tomorrow. ${holiday} is almost here, just one more day. <break size='0.4'/> <anim name='Greetings_04' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is tomorrow. <break size='0.7'/> Happy ${holiday} eve.<anim name='Happy_02' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "Tomorrow is ${holiday}. You're just in time. <break size='0.7'/> <anim name='Greetings_05' nonBlocking='true'/> <ssa cat='happy'/>\t",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate && Math.random()<.5",
			"prompt": "<anim name='Greetings_06' nonBlocking='true'/> <ssa cat='happy'/> It's tomorrow. <break size='0.5'/> Better get your ${holiday} pants ready.",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} starts tomorrow. <break size='0.7'/> Happy ${holiday} eve. <anim name='Greetings_07' nonBlocking='true'/> <ssa cat='happy'/>",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Success_01' nonBlocking='true'/> <ssa cat='happy'/> Tomorrow is the first day of ${holiday}. <break size='0.5'/> You're just in time.\t",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Greetings_02' nonBlocking='true'/> <ssa cat='happy'/> It starts tomorrow. <break size='0.5'/> Better get your ${holiday} pants ready.",
			"media": "TTS",
			"prompt_id": "HolidayTomorrow_AN_08",
			"weight": 1
		}
