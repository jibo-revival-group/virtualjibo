{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} isn't until ${startDate}. <break size='.5'/> <anim name='Goodbye_03'> You still have a while to wait. </anim>",
			"media": "TTS",
			"prompt_id": "HolidayLater_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Goodbye_01' nonBlocking='true'/> You still have a while to wait. <break size='.5'/> ${holiday} doesn't start until ${startDate}.",
			"media": "TTS",
			"prompt_id": "HolidayLater_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is ${startDate.prefixOnAt()}. <break size='0.7'/> <anim name='Goodbye_01'> You still have some time. </anim>",
			"media": "TTS",
			"prompt_id": "HolidayLater_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is ${startDate.prefixOnAt()}. <break size='0.5'/> <anim name='Greetings_02' nonBlocking='true'/> You have some time to get ready.",
			"media": "TTS",
			"prompt_id": "HolidayLater_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} starts ${startDate.prefixOnAt()}. <break size='0.7'/> <anim name='Greetings_02' nonBlocking='true'/> Still have some time.",
			"media": "TTS",
			"prompt_id": "HolidayLater_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "${holiday} starts ${startDate.prefixOnAt()}. <break size='0.6'/> <anim name='Goodbye_03'> You have some time to get ready. </anim>",
			"media": "TTS",
			"prompt_id": "HolidayLater_AN_06",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
}