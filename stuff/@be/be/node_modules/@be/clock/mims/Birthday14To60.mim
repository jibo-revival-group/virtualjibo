{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks - Kills MIM\n\nUses ${month} ${day}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday is coming up on ${month} ${day}. ",
			"media": "TTS",
			"prompt_id": "Birthday14To60_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==true",
			"prompt": "You don't have to wait <pitch mult=\"1.2\">too </pitch>long. It's on ${month} ${day}.",
			"media": "TTS",
			"prompt_id": "Birthday14To60_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "It's ${month} ${day}. Coming up pretty soon!",
			"media": "TTS",
			"prompt_id": "Birthday14To60_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "${loopMember}'s birthday is coming up on ${month} ${day}. Still plenty of time for you to make those handmade birthday candles.",
			"media": "TTS",
			"prompt_id": "Birthday14To60_AN_04",
			"weight": 0.2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loopMemberIsSpeaker==false",
			"prompt": "It's ${month} ${day}. Start practicing your Happy Birthday song.",
			"media": "TTS",
			"prompt_id": "Birthday14To60_AN_05",
			"weight": 1,
			"auto_rule_override": null
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false,
	"parse_launch": false
}