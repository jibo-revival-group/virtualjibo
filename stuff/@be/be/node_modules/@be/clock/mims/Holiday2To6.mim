{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks-KillsMIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": " ${holiday} is coming up really soon. <break size='.3'/> <anim name='Question_02'> It's ${startDate.prefixOnAt()}.</anim>",
			"media": "TTS",
			"prompt_id": "Holiday2To6_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate && endDate.getRelativeDays()>=7",
			"prompt": "${holiday} is coming up really soon. <break size='.3'/> <anim name='Yep_01' layers='body'> It starts ${startDate.prefixOnAt()} and ends ${endDate.prefixOnAt({includeDayOfWeek:true})}.</anim>",
			"media": "TTS",
			"prompt_id": "Holiday2To6_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate && endDate.getRelativeDays()<7",
			"prompt": "${holiday} is coming up really soon. <break size='.3'/> <anim name='Yep_03' layers='body'> It starts ${startDate.prefixOnAt()} and ends ${endDate.prefixOnAt()}.</anim>",
			"media": "TTS",
			"prompt_id": "Holiday2To6_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "${holiday} is ${startDate.prefixOnAt()}. <break size='.7'/> <anim name='Yep_03' layers='body'> Get ready.</anim>",
			"media": "TTS",
			"prompt_id": "Holiday2To6_AN_04",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
}