{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks - Kills MIM\n\nUses Andrew Start's ${day.prefixOnAt()}",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Goodbye_01' nonBlocking='true'/> You just missed it. ${holiday} was ${startDate.prefixOnAt()}. <break size='0.3'/> But you can catch it again ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayJustPassed_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Goodbye_03' nonBlocking='true'/> You just missed it. <break size='0.5'/> ${holiday} ended ${endDate.prefixOnAt()}. <break size='0.3'/> But you can catch it again starting ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayJustPassed_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Glance_Left_04' nonBlocking='true'/> It's right behind you. <break size='0.7'/> ${holiday} was ${startDate.prefixOnAt()}. <break size='0.3'/> Next time it'll be ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayJustPassed_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate==endDate",
			"prompt": "<anim name='Glance_Left_03'> Actually it was just a couple days ago,</anim> ${day.prefixOnAt()}. <break size='0.5'/> <anim name='Question_02'> The next one will be ${nextYearDate.prefixOnAt()}.</anim>",
			"media": "TTS",
			"prompt_id": "HolidayJustPassed_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Glance_Right_04' nonBlocking='true'/> It's right behind you. <break size='0.5'/> ${holiday} ended ${endDate.prefixOnAt()}. <break size='0.3'/> <break size='0.3'/> Next time it'll be starting ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayJustPassed_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "startDate!=endDate",
			"prompt": "<anim name='Goodbye_03'> Actually it ended just a couple days ago,</anim> ${endDate.prefixOnAt()}. <break size='0.3'/> The next one will start ${nextYearDate.prefixOnAt()}.",
			"media": "TTS",
			"prompt_id": "HolidayJustPassed_AN_06",
			"weight": 1
		}
	],
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"thanks_handling": "respondAndEnd",
	"gui": null,
	"parse_all_asr": false
}