{
  "name": "@be/restore",
  "version": "5.0.18",
  "description": "",
  "main": "index.js",
  "config": {
    "standalone": true
  },
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "",
    "prompt": "Do something",
    "display-name": "restore"
  },
  "dependencies": {},
  "license": "UNLICENSED",
  "distribution": "PROPRIETARY AND CONFIDENTIAL - NOT FOR DISTRIBUTION",
  "copyright": "Copyright (c) 2014-2018 Jibo, Inc. All Rights Reserved",
  "scripts": {
    "start": "jibo-dev watch",
    "watch": "jibo-dev watch",
    "build": "jibo-dev build",
    "clean": "jibo-dev clean",
    "build:release": "jibo-dev build --prod",
    "prepublish:release": "yarn build:release",
    "prepublish:debug": "yarn build",
    "publish:debug": "yarn publish",
    "publish:release": "yarn publish",
    "sync": "sync $npm_package_name || exit 0",
    "addsshkey": "addsshkey || exit 0",
    "test:debug": "floss --debug --path tests/index.js --coveragePattern index.js --coverageSourceMaps && istanbul report && coverage:check",
    "test": "floss --path tests/index.js --coveragePattern index.js --coverageSourceMaps && istanbul report && yarn coverage:check",
    "coverage:report": "open coverage/lcov-report/index.html",
    "coverage:remap": "remap-istanbul --input ./coverage/coverage-final.json --output ./coverage/coverage-final.json",
    "coverage:check": "istanbul check-coverage coverage/coverage-final.json --statements 40 --branches 40 --functions 40 --lines 40"
  },
  "files": [
    "resources",
    "index.*",
    "launch.rule",
    "animdb-manifest.json"
  ],
  "eslintConfig": {
    "extends": "eslint:recommended",
    "rules": {
      "no-console": 0,
      "no-debugger": 1
    },
    "parserOptions": {
      "ecmaVersion": 6,
      "sourceType": "module"
    },
    "env": {
      "browser": true,
      "node": true
    },
    "globals": {
      "jibo": true,
      "PIXI": true
    }
  },
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=6.0"
  },
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "@be/skills-test-utils": "^4.0.0",
    "@jibo/floss": "^2.0.0",
    "istanbul": "^0.4.5",
    "jibo": "^14.0.0",
    "jibo-dev": "^5.0.0",
    "jibo-anim-db-animations": "19.0.2"
  },
  "syncDependencies": [
    "jibo",
    "jibo-anim-db-animations",
    "@be/be-framework"
  ]
}