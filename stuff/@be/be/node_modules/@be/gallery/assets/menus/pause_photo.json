{
    "viewConfig": {
        "type": "GalleryItemPauseView",
        "id": "itemPause",
        "listDefault": {
            "type": "ActionButton",
            "colors": "default"
        },
        "list": [
            {
                "id": "close",
                "label": "Back to Gallery",
                "iconSrc": "jibo://resources/actionIcons/back.png",
                "colors": "default",
                "action": {
                    "type": "utterance",
                    "data":{
                        "utterance": "close"
                    }
                }
            },
            {
                "id": "delete",
                "label": "Delete",
                "iconSrc": "jibo://resources/actionIcons/delete.png",
                "colors": "cancel",
                "action": {
                    "type": "utterance",
                    "data":{
                        "utterance": "delete"
                    }
                }
            }
        ]
    },
    "open": {
        "pause":true,
        "transitionOpen":"trans_up"
    },
    "defaultClose": {
        "remove": true,
        "transitionClose":"trans_down"
    },
    "defaultSelect": {
        "remove": true,
        "transitionClose":"trans_down"
    },
    "rule": "gallery/item_pause",
    "timeout": 60,
    "events": {
        "paged": {
            "type": "sfx",
            "data": "UIFX.swipe.01"
        },
        "at_end": {
            "type": "sfx",
            "data": "UIFX.endoflist.01"
        },
        "at_front": {
            "type": "sfx",
            "data": "UIFX.endoflist.01"
        }
    }
}