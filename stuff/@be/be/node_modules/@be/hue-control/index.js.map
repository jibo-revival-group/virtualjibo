                            blackboard.log.info('No defaultGroupInfo. How did that happen?');
                        }
                        blackboard.log.info('Group Loading result, blackboard.targetedGroups:', blackboard.targetedGroups);
                        if (blackboard.targetedGroups.length > 1) {
