{
  "name": "@be/nimbus",
  "version": "2.2.9",
  "description": "",
  "main": "index.js",
  "jibo": {
    "main": "index.html",
    "type": "asset-pack",
    "launchRule": "launch.rule",
    "prompt": "",
    "display-name": "nimbus"
  },
  "dependencies": {
    "@jibo/interfaces": "^1.0.30",
    "jibo-common-types": "^5.0.0",
    "jibo-expression-client": "^5.0.0",
    "moment": "2.14.1"
  },
  "license": "UNLICENSED",
  "distribution": "PROPRIETARY AND CONFIDENTIAL - NOT FOR DISTRIBUTION",
  "copyright": "Copyright (c) 2014-2018 Jibo, Inc. All Rights Reserved",
  "config": {
    "standalone": true
  },
  "monorailConfig": {
    "public": false,
    "output": "index.js"
  },
  "files": [
    "animations",
    "assets",
    "mims",
    "res",
    "index.*",
    "launch.rule",
    "animdb-manifest.json"
  ],
  "scripts": {
    "start": "jibo-dev watch",
    "watch": "jibo-dev watch",
    "build": "jibo-dev build",
    "clean": "jibo-dev clean",
    "build:release": "jibo-dev build --prod",
    "sync": "jibo-rsync",
    "addsshkey": "jibo-rsync --init",
    "testdebug": "npm test -- --debug",
    "test": "floss --path tests/index.js --coveragePattern index.js --coverageSourceMaps",
    "coverage:report": "open coverage/index.html",
    "coverage:remap": "remap-istanbul --input ./coverage/coverage-final.json --output ./coverage/coverage-final.json",
    "coverage:check": "istanbul check-coverage coverage/coverage-final.json --statements 42 --branches 15 --functions 42 --lines 42",
    "test:debug": "npm test -- --debug",
    "test:report": "npm test -- --reporter=spec,xunit"
  },
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=6.0"
  },
  "devDependencies": {
    "@be/be-framework": "^11.0.0",
    "@be/skills-test-utils": "^4.0.0",
    "@jibo/floss": "^2.0.0",
    "@types/jibo-command-protocol": "^2.7.0",
    "electron-prebuilt": "1.4.3",
    "jibo": "^14.0.0",
    "jibo-anim-db-animations": "19.0.2",
    "jibo-dev": "^5.0.0",
    "jibo-rsync": "^4.0.0",
    "jibo-typed-events": "^6.0.0"
  },
  "syncDependencies": [
    "jibo",
    "jibo-anim-db-animations",
    "@be/be-framework"
  ]
}