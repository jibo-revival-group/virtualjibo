{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es6",
        "noImplicitAny": false,
        "sourceMap": true,
        "experimentalDecorators": true,
        "allowUnreachableCode": true,
        "types": [
            "pixi.js",
            "jibo-command-protocol"
        ]
    },
    "include": [
        "src/**/*.ts",
        "typings/index.d.ts"
    ],
    "compileOnSave": false
}
