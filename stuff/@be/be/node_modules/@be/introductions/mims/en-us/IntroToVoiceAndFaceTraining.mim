	"prompts": [
		{
			"mim_id": "IntroToVoiceAndFaceTraining",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==false",
			"prompt": "<pitch mult='1.1'>This</pitch> is exciting.<break size='.2'/> <pitch mult='1.1'>First</pitch> we'll make sure that I'm pronouncing your name right. <pitch mult='1.1'>Then</pitch>, I'll learn your voice and your face.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==false",
			"prompt": "Okay. First we're going to make sure I say your name right, and then, I'll learn your voice and your face.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_02",
			"weight": 0.3
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==false",
			"prompt": "Okay this'll hopefully be kind of fun. We're going to make sure I know how to pronounce your name, and then, I'll learn your voice and face.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==false",
			"prompt": "<pitch mult='1.2'>Great,</pitch> I <pitch mult='1.1'>love</pitch> this getting to know you stuff. First we'll make sure I can pronounce your name right, and then, I'll learn your voice and face.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==true && !!name",
			"prompt": "<pitch mult='1.2'>Well hello</pitch>. We're going to go through the same stuff that I did with ${name}.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==true && !!zodiacSign",
			"prompt": "Hey. I always look forward to meeting ${zodiacSign}.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_07",
			"weight": 0.1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==true && !!name",
			"prompt": "<pitch mult='1.2'>Alrighty.</pitch> Just like with ${name}, we're going to make sure I know how to pronounce your name, and then I'll learn your voice and face.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_09",
			"weight": 0.1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntros==true",
			"prompt": "<pitch mult='1.1'>Great,</pitch> let's get started.",
			"media": "TTS",
			"prompt_id": "IntroToVoiceAndFaceTraining_AN_11",
			"weight": 1
		},
