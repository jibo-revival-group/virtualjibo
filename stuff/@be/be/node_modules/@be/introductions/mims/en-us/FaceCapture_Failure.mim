		{
			"mim_id": "TrainFaceLater",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!isFirstTime  // subsequent people to do the face enrollment during this current training loop",
			"prompt": "How bout we do this some other time. You can try again by going into the introductions menu, or saying, Hey Jibo, learn my face.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "FaceCapture_Failure_AN_01",
			"weight": 1
		},
		{
			"mim_id": "TrainFaceLater",
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "isFirstTime   // first person to do the face enrollment during this current training loop",
			"prompt": "How bout we do this some other time, but it'll be more fun to hang out if you finish it sooner rather than later. When you're ready, go to the introductions menu, or just say, Hey Jibo, learn my face.",
			"media": "TTS",
			"extra": "",
			"prompt_id": "FaceCapture_Failure_AN_02",
			"weight": 1
		},
