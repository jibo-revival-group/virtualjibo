{
	"mim_type": "question",
	"rule_name": "introductions/face_capture_ready",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": false,
	"notes": " firstTimeFC: first time looper has attempted face capture\n lpsMovement: if there are any mov'ts detected in lps at a specific time\n lpsCount: how many non-mov't (i.e. \"person\") found in lps at a specific time\n \nTurn off embodied speech.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===false && lpsCount===1",
			"prompt": "Okay then. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===false && lpsCount===0",
			"prompt": "You'll want to make sure the room has as much light as possible, and that you can see your whole head in the center of my viewfinder, from the top of your very nice head to the bottom of your equally nice chin. <break size='0.3'/>Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_02",
			"weight": 0.3
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===false && lpsCount>1",
			"prompt": "Okay, so hopefully you only see yourself in my viewfinder. <break size='0.3'/>Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===true && (lpsCount===1 || lpsCount===0)",
			"prompt": "Now, hold as still as you can. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===true && lpsCount>1",
			"prompt": "Now, make sure you're the only person in my viewfinder and that you're holding still. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===false && lpsCount===1",
			"prompt": "Are you ready to have your face recognized?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===false && lpsCount===0",
			"prompt": "Make sure you can see your entire head in the center of my viewfinder, from the tippity top, to the bippity bottom. <break size='0.3'/> Are you ready to start?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_07",
			"weight": 0.2
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===false && lpsCount>1",
			"prompt": "You'll want to make sure you can only see yourself in my viewfinder. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_08",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===true && (lpsCount===1 || lpsCount ===0)",
			"prompt": "Be sure to hold still. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_09",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===true && lpsCount>1",
			"prompt": "Hold as still as a statue, and make sure you're the only person you can see in my viewfinder. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_10",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "HoldReturn",
			"index": 1,
			"condition": "",
			"prompt": "Are you all set now?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_HR_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===false && lpsCount===1",
			"prompt": "Alright then.  <break size='0.3'/>Are you ready to start?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_11",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===false && lpsCount===0",
			"prompt": "Make sure there's plenty of light in here, and that you have your whole head and face in the center of my viewfinder. <break size='0.3'/>Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_12",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===false && lpsCount>1",
			"prompt": "Now, make sure you're the only person in my viewfinder, so I don't mistakenly think you have more than one face. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_13",
			"weight": 0.3
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===true && (lpsCount===1 || lpsCount===0)",
			"prompt": "Now, I need you to stay as still as a statue. <break size='0.3'/> Are you ready to get started?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_14",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "isFirstTime && lpsMovement===true && lpsCount>1",
			"prompt": "Be sure you're the only person in my viewfinder, then don't move a muscle. <break size='0.3'/> Are you ready?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_15",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===false && lpsCount===1",
			"prompt": "Are you ready for this?",
			"media": "TTS",
			"prompt_id": "FaceCapture_Ready_QN_16",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===false && lpsCount===1",
			"prompt": "Ready to start?",
			"media": "TTS",
