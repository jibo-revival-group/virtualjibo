		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "Q",
			"index": 1,
			"condition": "!isFirstTime && lpsMovement===false && lpsCount===0",
			"prompt": "Make sure you can see your whole head, from head to chin, in the center of my viewfinder. <break size='0.3'/>  Are you ready to start?",
