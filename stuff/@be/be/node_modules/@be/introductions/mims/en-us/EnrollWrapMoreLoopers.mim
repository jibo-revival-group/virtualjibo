	"timeout": 2,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "Thanks - Respond then kill MIM",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntrosMaxErrors==true",
			"prompt": "We can just stop for now. But anyone can do this anytime, by saying, Hey Jibo learn my voice and face.",
			"media": "TTS",
			"prompt_id": "EnrollWrapMoreLoopers_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntrosMaxErrors==false",
			"prompt": "Then we're <pitch mult='1.1'>all </pitch>set. I'll be here if you need anything.",
			"media": "TTS",
			"prompt_id": "EnrollWrapMoreLoopers_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntrosMaxErrors==true",
			"prompt": "Well I'll be right here if you need help with anything, or if you just want to say hi.",
			"media": "TTS",
			"prompt_id": "EnrollWrapMoreLoopers_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntrosMaxErrors==false",
			"prompt": "Okay. That'll do it then.",
			"media": "TTS",
			"prompt_id": "EnrollWrapMoreLoopers_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntrosMaxErrors==true",
			"prompt": "<pitch mult='1.1'>I'm</pitch> going to say we're done for now. I'll be around, if anyone ever wants me to learn their voice or face.",
			"media": "TTS",
			"prompt_id": "EnrollWrapMoreLoopers_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "anyMoreIntrosMaxErrors==false",
