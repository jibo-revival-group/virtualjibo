			"prompt": "<pitch mult='1.1'>Perfect, now</pitch> let's try without smiling.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_11",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===2",
			"prompt": "<pitch mult='1.1'>Nicely</pitch> done, now again without the smile.",
