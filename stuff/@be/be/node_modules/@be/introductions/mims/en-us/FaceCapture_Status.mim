{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": false,
	"notes": "These ideally play after each of the five face-capture frames. Some might be skipped if an error is played.\nTurn off embodied speech.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1 ",
			"prompt": "<pitch mult='1.2'>Great</pitch> start, now let me see you smile.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===2",
			"prompt": "<pitch mult='1.1'>Excellent, now </pitch>stop smiling, but stay happy.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===3",
			"prompt": "${loopMember} you're <pitch mult='1.1'>doing</pitch> great.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===4",
			"prompt": "We're <pitch mult='1.1'>getting</pitch> there.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1 ",
			"prompt": "You're <pitch mult='1.1'>off</pitch> to a <pitch mult='1.1'>great</pitch> start. Now smile for me.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1",
			"prompt": "<pitch mult='1.1'>Looking</pitch> good, <pitch mult='1.1'>now</pitch> give me a smile.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1",
			"prompt": "<pitch mult='1.2'>Great</pitch> start, how about a smile now.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1",
			"prompt": "You're <pitch mult='1.1'>doing</pitch> great, let me see your smile now.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_08",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1",
			"prompt": "We're <pitch mult='1.1'>off</pitch> to a <pitch mult='1.1'>nice</pitch> start. Now give me a smile.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_09",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===1",
			"prompt": "<pitch mult='1.1'>That's</pitch> a great start, <pitch mult='1.1'>now</pitch> give me your best smile.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_10",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
