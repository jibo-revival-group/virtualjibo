			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "numTries===2",
			"prompt": "<pitch mult='1.1'>Excellent, now </pitch>let's do <pitch mult='1.1'>no </pitch>smiling again please.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Status_AN_15",
			"weight": 1
		},
