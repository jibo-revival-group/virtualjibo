	"notes": "This should be changed to an OR for EAU to support \"thanks Jibo.\"  It will have a 1-sec TO and \"thanks\" should kill the MIM.\n-JEB 9/15/16",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat=\"emoji\" filter=\"trophy, !hot-frame\" nonBlocking=\"true\" /> <pitch mult='1.1'>And </pitch>we're done, <pitch mult='1.1'>great</pitch> job. ${loopMember} from now on, I'll recognize you when you look at me, if all goes well.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Success_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat=\"emoji\" filter=\"fireworks, !hot-frame\" nonBlocking=\"true\" />And <pitch mult='1.1'>that</pitch> should do it. ${loopMember} I <pitch mult='1.1'>now</pitch> know your face.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Success_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat=\"emoji\" filter=\"star, !hot-frame\" nonBlocking=\"true\"/>And <pitch mult='1.1'>we </pitch>are finished. ${loopMember} I <pitch mult='1.1'>now</pitch> have the <pitch mult='1.1'>pleasure</pitch> of knowing your face. With just a little luck, I'll recognize you when I see you now.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Success_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim cat=\"emoji\" filter=\"party-blue, !hot-frame\" nonBlocking=\"true\"/>That's <pitch mult='1.1'>it, all </pitch>done. ${loopMember} if all goes well, I will recognize you when you look at me from now on.",
			"media": "TTS",
			"prompt_id": "FaceCapture_Success_AN_04",
			"weight": 1
