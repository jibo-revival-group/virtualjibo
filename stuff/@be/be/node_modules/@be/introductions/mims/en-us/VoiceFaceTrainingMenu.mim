	"es_auto_tagging": false,
	"gui": {
		"type": "Javascript",
		"data": "{\n  viewConfig: {\n    type: 'ContactsView',\n    title: 'Who are you?',\n    id: 'EnrollmentLooperList',\n    sortLoopList: (loop) => {\n      let notEnrolled = [];\n      let fullyEnrolled = [];\n      let partiallyEnrolled = [];\n      for(let looper of loop){\n        if(looper.isJibo){\n          continue;//INHUMAN!\n        }\n        if(looper.data.enrolled && looper.data.enrolled.voice && looper.data.enrolled.face){\n          fullyEnrolled.push(looper);\n        }\n        else if(looper.data.enrolled && (looper.data.enrolled.voice || looper.data.enrolled.face)){\n          partiallyEnrolled.push(looper);\n        }\n        else{\n          notEnrolled.push(looper);\n        }\n      }\n      return notEnrolled.concat(partiallyEnrolled, fullyEnrolled);\n    }\n  },\n  defaultSelect: 'remain',\n  defaultClose: 'remain'\n}\n",
		"pause": false
	},
	"no_matches_for_gui": 0,
	"no_inputs_for_gui": 0,
	"ignore_no_match": false,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false
}