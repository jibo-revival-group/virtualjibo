			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "<anim name='emoji_checkmark' nonBlocking='true'/><pitch mult='1.2'>${loopMember}</pitch> you made it. I should <pitch mult='1.1'>recognize</pitch> <anim name='Excited_03' layers='!screen' nonBlocking='true'/> your voice from now <anim cat='emoji' filter='fireworks, !hot-frame' layers='screen' nonBlocking='true'/>on.",
