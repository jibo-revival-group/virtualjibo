	"notes": "${firstLoopMember} mentioned in condition \"timesThroughCaptureHJ==2\" should be the first person who enrolled, just before this current LM.",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!firstLoopMember",
			"prompt": "<anim name='emoji_checkmark' nonBlocking='true'/>And <pitch mult='1.1'>that's</pitch> it. <pitch mult='1.1'>${loopMember},</pitch> <anim name='Excited_03' layers='!screen' nonBlocking='true'/> I've <pitch mult='1.1'>got</pitch> your voice. Now I think I can tell you from ${firstLoopMember}<anim cat='emoji' filter='party-blue, !hot-frame' layers='screen' nonBlocking='true'/>.",
