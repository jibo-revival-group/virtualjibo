{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": {
		"interSentenceTiming": true,
		"intraSentenceTiming": true,
		"hotWords": false,
		"punctuation": true,
		"structure": true,
		"voice": true
	},
	"notes": "\nVijendra said that we will be able to categorize rejected HJ attempts as (1) \"bad\" as in too slow or fast, (2) too loud, or (3) too noisy. This Mim represents the prompts we say to the person for the *first* error only of any single utterance capture.-JEB 7/29/16\nGlobalTimeoutCount tracks timeouts so far for this person overall.\nGlobalLoudAudioCount tracks loud audio messages so far for this person overall.\nGlobalNoisyAudioCount tracks noisy audio messages so far for this person overall.\n",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "timeout && globalTimeoutCount==1",
			"prompt": "This time I didn't hear anything for some reason. After the ${soundName}, try again.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "timeout && globalTimeoutCount>1",
			"prompt": "I didn't hear anything this time. Try again after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "badAudio && globalBadAudioCount==1",
			"prompt": "This time the sound quality was not great. Try one more time, after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loudAudio && globalLoudAudioCount==1",
			"prompt": "Whoa this time it was a little loud. But I blame my sensitive microphones. Maybe try speaking a little softer, or take one step back, and say Hey Jibo when you hear the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_04",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loudAudio && globalLoudAudioCount>1",
			"prompt": "That one was too loud again. I'm not sure what's up with my microphones, sorry. Try again after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "noisyAudio && globalNoisyAudioCount==1",
			"prompt": "I couldn't quite hear your voice on that one, because of some other noise in the room. Let's try again, say Hey Jibo again after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_06",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "noisyAudio && globalNoisyAudioCount>1",
			"prompt": "I heard more noisiness. How bout you try once more, after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_07",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "badAudio && globalBadAudioCount>1",
			"prompt": "I seem to have gotten some bad audio again. Try another Hey Jibo, after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_08",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "timeout && globalTimeoutCount==1",
			"prompt": "This time I didn't hear you say Hey Jibo. Say it again after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_09",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "timeout && globalTimeoutCount==1",
			"prompt": "This time I didn't hear you say the magic words. When you hear the ${soundName} again, say Hey Jibo <break size='0.5'/>.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_10",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "timeout && globalTimeoutCount>1",
			"prompt": "This time I didn't hear anything again. Try saying Hey Jibo again after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_11",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "badAudio && globalBadAudioCount==1",
			"prompt": "This time I had a little trouble with the audio. Try another Hey Jibo after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_12",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "badAudio && globalBadAudioCount==1",
			"prompt": "This time I think I heard something, but not quite sure what. Give me another Hey Jibo when you hear the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_13",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "badAudio && globalBadAudioCount==1",
			"prompt": "This time I'm not quite sure what I just heard. How bout you say Hey Jibo again when you hear the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_14",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loudAudio && globalLoudAudioCount==1",
			"prompt": "That one was a bit too loud for my little microphones. Try again when you hear the ${soundName}, but maybe a little softer or from a little farther away.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_15",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loudAudio && globalLoudAudioCount==1",
			"prompt": "Oops, this time it was a little too loud for me to handle. Say Hey Jibo again when you hear the ${soundName}, but maybe just a little softer, or from one step farther away.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_16",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "loudAudio && globalLoudAudioCount>1",
			"prompt": "Oops, a little too loud again on that one. Maybe it's my mikes. Say another Hey Jibo after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_17",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "noisyAudio && globalNoisyAudioCount==1",
			"prompt": "This time I couldn't pick up your voice, I think because it's a little noisy in here. Say Hey Jibo again after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_18",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "noisyAudio && globalNoisyAudioCount==1",
			"prompt": "Oops, that one didn't work either, I think because of some other noise in the room. How bout you say Hey Jibo again when you hear the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_19",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "noisyAudio && globalNoisyAudioCount==1",
			"prompt": "I had some trouble on that one, because there seems to be noise in the room. Maybe a barking dog or a crying baby. Or a barking baby. Try saying Hey Jibo again, after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_20",
			"weight": 0.1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "noisyAudio && globalNoisyAudioCount>1",
			"prompt": "It was a little too noisy again. Give it another try, after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_21",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "badAudio && globalBadAudioCount>1",
			"prompt": "The sound quality was pretty bad again there. How bout you try once more, after the ${soundName}.",
			"media": "TTS",
			"prompt_id": "CaptureHJ_Error2_AN_22",
			"weight": 1
		}
	],
	"gui": null,
	"no_matches_for_gui": 2,
	"no_inputs_for_gui": 2,
	"ignore_no_match": false,
	"parse_all_asr": false,
	"thanks_handling": "ignore",
	"parse_launch": false,
	"parse_yes_no": false
}