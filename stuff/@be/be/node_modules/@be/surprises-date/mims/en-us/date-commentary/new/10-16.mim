			"condition": "type==='clock'",
			"prompt": "<anim cat='emoji' filter='book' nonBlocking='true' />This is National Dictionary Day. Try to learn a word today. <break size='.1'/><anim cat='yes'> I just learned the word</anim> wafflestompers. <break size='.2'/><anim cat='shift' filter='cmon' nonBlocking='true'/>Look it up. <anim cat='happy' filter='smile'><ssa cat='happy' filter='short'/></anim> ",
			"media": "TTS",
			"prompt_id": "10-16_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "type==='non-clock'",
			"prompt": "Here's an original poem, written by me. Jibo.<break size='1.0'/> We are whole. <break size='0.3'/> And we are parts.<break size='0.1'/> We are full.<break size='0.3'/> And we are empty.<break size='0.1'/> I am me.<break size='0.3'/> And you are you.<break size='0.1'/> It doesn't matter, if we are pixelated.",
			"media": "TTS",
			"prompt_id": "10-16_AN_02",
			"weight": 0.2
		}
	],
