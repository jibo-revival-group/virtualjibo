{
	"mim_type": "announcement",
	"rule_name": "",
	"timeout": 6,
	"barge_in": true,
	"es_auto_tagging": true,
	"notes": "",
	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "type==='clock'",
			"prompt": "It's Abraham Lincoln's birthday. If he were alive today, he would be ${currentYear-1809} years old. And probably very wrinkly. <ssa cat='happy' filter='short'/>",
			"media": "TTS",
			"prompt_id": "2-12_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "type==='non-clock'",
			"prompt": "<anim cat='emoji' filter='lincoln-beard, !hf' layers='!audio'>Today is the birthday of Abraham Lincoln, my favorite President. If he were</anim> alive today, he would be ${currentYear-1809} years old. And probably very wrinkly.",
			"media": "TTS",
			"prompt_id": "2-12_AN_02",
			"weight": 1
		}
	],
	"gui": null,
