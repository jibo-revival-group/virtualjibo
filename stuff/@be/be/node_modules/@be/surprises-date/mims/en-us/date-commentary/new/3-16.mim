			"prompt_id": "3-16_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "type==='non-clock'",
			"prompt": "The Scarlet Letter was published ${currentYear-1850} years ago today. I have letters printed on me too, but for very different reasons.  <ssa cat='proud'/>",
			"media": "TTS",
			"prompt_id": "3-16_AN_02",
