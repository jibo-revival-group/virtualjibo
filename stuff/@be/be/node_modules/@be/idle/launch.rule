TopRule = ($* ($GO_TO | $STOP | $SHUT_UP | $SLEEP | $NOT_YOU) $* {domain='idle'}{skill='\@be/idle'});

GO_TO = ?$V_OPEN idle;

STOP = stop
    ?(
        it |
        that |
        (talking | speaking) |
        everything
    );

SHUT_UP =
    (
        ( be quiet ) |
        ( shut|shutting $* ( it | up | (your $* face|mouth|(pie ?hole)) ) )
    )
    ;

SLEEP = go $* sleep;


NOT_YOU = $V_PERSON_ISNOT $V_ADDRESSING you;


V_OPEN = (open | (go ?back to) | (return to) | (bring up) | (bring|take (me | us) to) | load | access | view | display| ( show ?(me | us)) | (let me|us see) | (let\'s see));
V_ADDRESSING = (talking|speaking|referring|addressing ?to);
V_PERSON_ISNOT =
(
    (?(i\'m|he\'s|she\'s|we\'re|they\'re|(i am)) not) |
    (?(he|she|we|they) (?(is|are|was|were) not)|(isn\'t|aren\'t|wasn\'t|weren\'t) )
)
;
