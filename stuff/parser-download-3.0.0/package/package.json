{
  "name": "parser-download",
  "version": "3.0.0",
  "description": "Tool for downloading platform specific versions of jibo-parser",
  "bin": "./bin/parser-download.js",
  "main": "./lib/parser-download.js",
  "scripts": {
    "postinstall": "npm i nugget@^2.0.0",
    "test": "gulp test",
    "build": "gulp debug",
    "build:release": "gulp",
    "clean": "gulp clean-all",
    "watch": "gulp watch",
    "publish:patch": "gulp publish --yes --bump=patch",
    "publish:minor": "gulp publish --yes --bump=minor",
    "publish:major": "gulp publish --yes --bump=major",
    "publish:skip": "gulp publish --yes --bump=skip",
    "publish:release": "gulp release --yes --tag=beta"
  },
  "scriptsRelease": {
    "postinstall": "npm i nugget@^2.0.0"
  },
  "typings": "lib/dts/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.jibo.com:sdk/sdk.git"
  },
  "publishConfig": {
    "registry": "http://npm.jibo.com:8080"
  },
  "engines": {
    "node": ">=4.0"
  },
  "dependencies": {
    "chalk": "^1.1.3",
    "env-paths": "^1.0.0",
    "extract-zip": "^1.5.0",
    "fs-extra": "^0.30.0",
    "minimist": "^1.2.0",
    "uuid": "^3.0.1"
  },
  "devDependencies": {
    "gulp": "^3.9.1",
    "jibo-gulp": "^4.0.0"
  }
}
