     (url){_out='uletter_rletter_lletter'} |
     (uss){_out='uletter_sletter_sletter'} |
     (vol .){_out='volume'} |
     (ww 1){_out='world_war_one'} |
     (ww 2){_out='world_war_two'};

#Two letter acronyms to be spoken letter-by-letter
#Note that these must contain at least one vowel - pure consonant TwoLA's are already covered by LetterAbbreviations
TwoLA = (3 d){_out='three_dletter'} |
       (2 d){_out='two_dletter'} |
       (ad){_out='aletter_dletter'} |
       (ap){_out='aletter_pletter'} |
       (ch .){_out='chapter'} |
       (ce){_out='cletter_eletter'} |
       (d ?. j .){_out='dletter_jletter'} |
       (eu){_out='eletter_uletter'}~0.1 |
       (ed .){_out='edition'} |
       (fa){_out='fletter_aletter'} |
       (id | (i . d .)){_out='iletter_dletter'} |
       (iq){_out='iletter_qletter'} |
       (jr .){_out='junior'} |
       (l . a .){_out='los_angeles'} |
       (mr ?.){_out='mister'} |
       (mt .){_out='mount'} |
       (ms ?.){_out='miss'}~0.1 |
       (mc | (m . c .)){_out='mletter_cletter'} |
       ((n . b .) | (nb \!)){_out='nletter_bletter'} |
       (ok){_out='oletter_kletter'} |
       (pt .){_out='part'} |
       (uk){_out='uletter_kletter'} |
       (vw){_out='volkswagen'};

# Roman numerals
# This only covers some lower ones and some super bowl ones
RomanNumeralUnsafe = i{_out='one'} |
                     v{_out='five'} |
                     x{_out='ten'} |
                     l{_out='fifty'} |
                     $RomanNumeralSafe{_out=RomanNumeralSafe._out};

RomanNumeralSafe = ii{_out='two'} |
                    iii{_out='three'} |
                    iv{_out='four'} |
                    vi{_out='six'} |
                    vii{_out='seven'} |
                    viii{_out='eight'} |
                    ix{_out='nine'} |
                    xi{_out='eleven'} |
                    xii{_out='twelve'} |
                    xiii{_out='thirteen'} |
                    xiv{_out='fourteen'} |
                    xv{_out='fifteen'} |
                    xvi{_out='sixteen'} |
                    xvii{_out='seventeen'} |
                    xviii{_out='eighteen'} |
                    xix{_out='nineteen'} |
                    xx{_out='twenty'} |
                    li{_out='fifty_one'} |
                    lii{_out='fifty_two'} |
                    liii{_out='fifty_three'};


#Four letter acronyms to be spoken letter-by-letter
#Note that these must contain at least one vowel - pure consonant FLA's are already covered by LetterAbbreviations
FLA = (byob){_out='bletter_yletter_oletter_bletter'} |
     (espn){_out='eletter_sletter_pletter_nletter'} |
     (rsvp){_out='rletter_sletter_vletter_pletter'} |
     (subj .){_out='subject'} |
     (usaf){_out='uletter_sletter_air_force'} |
     (uscg){_out='uletter_sletter_coastal_guard'} |
     (usmc){_out='uletter_sletter_marine_corps'} |
     (ussr){_out='uletter_sletter_sletter_rletter'} |
     (ywca){_out='yletter_wletter_cletter_aletter'} |
     (ymca){_out='yletter_mletter_cletter_aletter'} |
     (ncaa){_out='nletter_cletter_aletter_aletter'} |
     (wnba){_out='wletter_nletter_bletter_aletter'};

LetterAbbreviations = $DotAbbreviation{_out=DotAbbreviation._out} |
                      [$ConsonantAbbreviation{_out=ConsonantAbbreviation._out}] |
                      [$VowelAbbreviation{_out=VowelAbbreviation._out}];

#Two or more letters with dots between (e.g. i.t.l. or m.n.)
DotAbbreviation = ([$CharacterLetter{_out=CharacterLetter._out}] .)
                  +([$CharacterLetter{_out+='_'}{_out+=CharacterLetter._out}] .);

#A word consisting of two or more consonants (e.g. BT LTS MNKT)
ConsonantAbbreviation [$ConsonantLetter{_out=ConsonantLetter._out} 
                      +$ConsonantLetter{_out+='_'}{_out+=ConsonantLetter._out}];

#A word consisting of four or more vowels (e.g. aaaa uuuu ouie)
VowelAbbreviation [$VowelLetter{_out=VowelLetter._out}
                  $VowelLetter{_out+='_'}{_out+=VowelLetter._out}
                  $VowelLetter{_out+='_'}{_out+=VowelLetter._out}
                  +$VowelLetter{_out+='_'}{_out+=VowelLetter._out}];

CharacterLetter [$VowelLetter{_out=VowelLetter._out} | $ConsonantLetter{_out=ConsonantLetter._out}];

ConsonantLetter [b{_out='bletter'} |
            c{_out='cletter'} |
            d{_out='dletter'} |
            f{_out='fletter'} |
            g{_out='gletter'} |
            h{_out='hletter'} |
            j{_out='jletter'} | 
            k{_out='kletter'} | 
            l{_out='lletter'} | 
            m{_out='mletter'} | 
            n{_out='nletter'} | 
            p{_out='pletter'} | 
            q{_out='qletter'} | 
            r{_out='rletter'} | 
            s{_out='sletter'} | 
            t{_out='tletter'} | 
            v{_out='vletter'} | 
            w{_out='wletter'} | 
            x{_out='xletter'} | 
            z{_out='zletter'}];

#We can argue if y is a vowel or consonant ('yes' vs 'symbol')
#It is safer and more conservative to consider it a vowel for these purposes
VowelLetter [a{_out='aletter'} |
            e{_out='eletter'} |
            i{_out='iletter'} |
            o{_out='oletter'} |
            u{_out='uletter'} |
            y{_out='yletter'}];

Degrees = $handle:Digit{_out=Digit._ordinal}
          °{_out+='_degrees_'}
          $handle:Digit{_out+=Digit._ordinal}
          ′{_out+='_minutes_'}
          ?(
            $handle:Digit{_out+=Digit._ordinal}
            (" | ″){_out+='_seconds_'}
           )
          ?($NWES{_out+=NWES._out});

# A number of override special cases. E.g. we generally want 'oz' to be ounce but not when it's the Wizard of Oz.
Overrides = (of oz){_out='of_oz'} |
            (obama ii){_out='obama_the_second'} |
            (bowl $RomanNumeralUnsafe){_out='bowl_'}{_out+=RomanNumeralUnsafe._out} |
            (xi jinping){_out='shii_jinping'} |
            (r 2 ?- d 2){_out='rletter_two_dletter_two'} |
            (c ?- 3 po){_out='cletter_three_pletter_oletter'} |
            (j . k . rowling){_out='jletter_kletter_rowling'} |
            (washington ?, d . c .){_out='washington_dletter_cletter'} |
            (st{_out='saint_'} ?. (patrick{_out+='patrick'} | patrick\'s{_out+='patrick\'s'} | patricks{_out+='patricks'}) ) |
            (dr . seuss){_out='doctor_seuss'} |
            (hm | hmm){_out='hm'} |
            ((i\'m{_out='i\'m'} | am{_out='am'}) ken .){_out+='_ken_\[lpau\]'} |
            (spelled{_out='spelled'} +[$CharacterLetter]{_out+='_\[spau\]_'}{_out+=CharacterLetter._out} ?.) |
            (
              -{_out='minus_'}
              (
                $handle:Digit{_out+=Digit._ordinal} |
                $DigitWithDecimal{_out+=DigitWithDecimal._out}
              )
            ) |
            (
              $handle:Digit{_out=Digit._ordinal}
              –{_out+='_to_'}
              $handle:Digit{_out+=Digit._ordinal}
            ) |
            (9 - 1 - 1){_out='nine_one_one'} |
            (roche broes){_out='roche_brothers'} |
            (ups{_out='uletter_pletter_sletter_'} (store{_out+='store'}|van{_out+='van'}|delivery{_out+='delivery'}|car{_out+='car'})) |
            (3 (,|.) 2 (,|.) 1 .){_out='three_\[spau\]_two_\[spau\]_one_\[lpau\]'} |
            ([$Year] to present){_out=Year._out}{_out+='_to_present2'};

US = (the us){_out='the_uletter_sletter'} |
     (us dollar){_out='uletter_sletter_dollar'} |
     (us jobs){_out='uletter_sletter_jobs'} |
     (northern us){_out='northern_uletter_sletter'} |
     (us dollars){_out='uletter_sletter_dollars'} |
     (us marines){_out='uletter_sletter_marines'} |
     (us army){_out='uletter_sletter_army'} |
     (us navy){_out='uletter_sletter_navy'} |
     (us air force){_out='uletter_sletter_air_force'} |
     (us{_out='uletter_sletter_'} $USMeasure{_out+=USMeasure._out});

USMeasure = quart{_out='quart'} |
            quarts{_out='quarts'} |
            cup{_out='cup'} |
            cups{_out='cups'} |
            gallon{_out='gallon'} |
            gallons{_out='gallons'} |
            ounce{_out='ounce'} |
            ounces{_out='ounces'} |
            fluid{_out='fluid'} |
            teaspoon{_out='teaspoon'} |
            teaspoons{_out='teaspoons'} |
            tablespoon{_out='tablespoon'} |
            tablespoons{_out='tablespoons'};

######## Special Character Base Rules ##########
SpecChar = &{_out='and'} |
          %{_out='percent'} |
          \+{_out='plus'} |
          \={_out='equals'} |
          \>{_out='greater_than'} |
          \<{_out='less_than'} |
          ⋅{_out='times'} |
          \~{_out='infinity'} |
          \#{_out='hashtag'} |
          \@{_out='at'} |
          ((infty|infinity) \^ \~){_out='complex_infinity'} |
          ($Punc{_out=Punc._out} *$Punc)~1;

Punc = .{_out='\[lpau\]'} | ,{_out='\[spau\]'} |
       \;{_out='\[lpau\]'} | :{_out='\[lpau\]'} |
       -{_out=''}~0.1 | \?{_out='\[qpau\]'} |
       \!{_out='\[lpau\]'} | "{_out=''} |
       ``{_out=''} | \({_out='\[spau\]'} | \){_out='\[spau\]'} |
       `{_out=''} | /{_out=''} | \\{_out=''} |
       \^{_out=''}~0.1 | \|{_out=''} |
       –{_out=''}~0.1;
