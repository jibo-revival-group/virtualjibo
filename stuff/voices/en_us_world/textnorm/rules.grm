NWES = n{_out='north'} |
       nw{_out='north_west'} |
       ne{_out='north_east'} |
       s{_out='south'} |
       sw{_out='south_west'} |
       se{_out='south_east'} |
       e{_out='east'} |
       w{_out='west'};

# We go to max 999 (e.g. 999th Ave)
StreetNumber = $ToHundredDigitCardinal{_out=ToHundredDigitCardinal._out};

# We go to max 99999 (e.g. 99999, 999th Ave)
HouseNumber [$SingleDigitNoZero{_out=SingleDigitNoZero._ordinal}
            ?$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
            ?$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
            ?$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
            ?$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}];

Zip [$SingleDigit{_out=SingleDigit._ordinal}
    $SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
    $SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
    $SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
    $SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}];

# Unsafe states for e.g. address patterns
