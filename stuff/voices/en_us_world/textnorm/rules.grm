#The main rules file - to be cat'ed to the toprule files.

######### A word ########

# One or more characters we consider alphabetical
Word = [$Character{_out=Character._out} 
        *$Character{_out+=Character._out}];

Character [a{_out='a'} |
          b{_out='b'} |
          c{_out='c'} |
          d{_out='d'} |
          e{_out='e'} |
          f{_out='f'} |
          g{_out='g'} |
          h{_out='h'} |
          i{_out='i'} |
          j{_out='j'} |
          k{_out='k'} |
          l{_out='l'} |
          m{_out='m'} |
          n{_out='n'} |
          o{_out='o'} |
          p{_out='p'} |
          q{_out='q'} |
          r{_out='r'} |
          s{_out='s'} |
          t{_out='t'} |
          u{_out='u'} |
          v{_out='v'} |
          w{_out='w'} |
          x{_out='x'} |
          y{_out='y'} |
          z{_out='z'}];

######### NUMBERS #########
# Top rule for rules that deals with numbers
Numbers = $handle:Digit{_out=Digit._ordinal}~0.1 |
          [$YearSafe{_out=YearSafe._out}] |
          $DigitWithDecimal{_out=DigitWithDecimal._out} |
          $DigitCardinal{_out=DigitCardinal._out} |
          [$ClockDigit{_out=ClockDigit._out}] |
          $Currency{_out=Currency._out} |
          $NumberBaseRule{_out=NumberBaseRule._out};

# A heavily dispreferred rule to apply should we have no other number related rule to apply
# Just say the numbers one at a time (000 = zero zero zero)
NumberBaseRule = [$SingleDigit~0.9{_out=SingleDigit._ordinal} *$SingleDigit~0.9{_out+='_'}{_out+=SingleDigit._ordinal}];

##### Digits

DigitWithDecimal = $handle:Digit{_out=Digit._ordinal} $DigitDecimal{_out+='_'}{_out+=DigitDecimal._out};

DigitMaybeWithDecimal = $DigitWithDecimal{_out=DigitWithDecimal._out} |
                        $handle:Digit{_out=Digit._ordinal};

DigitCardinal = $handle:Digit $CardinalMark{_out=Digit._cardinal};

CardinalMark = th | st | nd | rd;

# If a digit starts with a zero we say each digit individually
DigitZeroBeg [0{_out='zero'} +$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}];


# A decimal
# If finish in a digit in the tens we go 'o' for every 0 and then the digit.
# If finish in a digit above the tens we say each digit individually (five four two zero nine).
DigitDecimal = .{_tmp=''}{_out=''}
                ( 
                  [+0] |
                  [*0{_tmp+='oletter_'}
                    $ToTenDigit{_out+='point_'}{_out+=_tmp}{_out+=ToTenDigit._ordinal} |
                    $SingleDigitNoZero{_out+='point_'}{_out+=_tmp}{_out+=SingleDigitNoZero._ordinal} |
                    (
                      $SingleDigitNoZero{_out+='point_'}{_out+=_tmp}{_out+=SingleDigitNoZero._ordinal}
                      $SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
                      +$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
                    )
                  ]
                );
# We say each digit individually (five four two zero nine).
#DigitDecimal = .{_tmp=''}{_out=''}
#                ( 
#                  [+0] |
#                  [*0{_tmp+='oletter_'}
#                    $SingleDigitNoZero{_out+='point_'}{_out+=_tmp}{_out+=SingleDigitNoZero._ordinal}
#                    *$SingleDigit{_out+='_'}{_out+=SingleDigit._ordinal}
#                  ]
#                );

# A single digit
SingleDigit [ 0{_ordinal = 'zero'}{_cardinal = 'zeroeth'}{_asDigit = '0'} |
              $SingleDigitNoZero{_ordinal=SingleDigitNoZero._ordinal}{_cardinal=SingleDigitNoZero._cardinal}{_asDigit = SingleDigitNoZero._asDigit} ];

SingleDigitCardinal = [$SingleDigit]{_out=SingleDigit._cardinal} $CardinalMark;

# A single digit not including zero
# Useful in e.g. HundredDigit rule
SingleDigitNoZero [ 1{_ordinal = 'one'}{_cardinal = 'first'}{_asDigit = '1'} |
                    2{_ordinal = 'two'}{_cardinal = 'second'}{_asDigit = '2'} |
                    3{_ordinal = 'three'}{_cardinal = 'third'}{_asDigit = '3'} |
                    4{_ordinal = 'four'}{_cardinal = 'fourth'}{_asDigit = '4'} |
                    5{_ordinal = 'five'}{_cardinal = 'fifth'}{_asDigit = '5'} |
                    6{_ordinal = 'six'}{_cardinal = 'sixth'}{_asDigit = '6'} |
                    7{_ordinal = 'seven'}{_cardinal = 'seventh'}{_asDigit = '7'} |
                    8{_ordinal = 'eight'}{_cardinal = 'eighth'}{_asDigit = '8'} |
                    9{_ordinal = 'nine'}{_cardinal = 'ninth'}{_asDigit = '9'} ];

# A cardinal single digit
SingleDigitNoZeroCardinal = [$SingleDigitNoZero] $CardinalMark{_out = SingleDigitNoZero._cardinal};

# The tens
Tens [ 10{_ordinal = 'ten'}{_cardinal = 'tenth'} |
       11{_ordinal = 'eleven'}{_cardinal = 'eleventh'} |
       12{_ordinal = 'twelve'}{_cardinal = 'twelvth'} |
       13{_ordinal = 'thirteen'}{_cardinal = 'thirteenth'} |
       14{_ordinal = 'fourteen'}{_cardinal = 'fourteenth'} |
       15{_ordinal = 'fifteen'}{_cardinal = 'fifteenth'} |
       16{_ordinal = 'sixteen'}{_cardinal = 'sixteenth'} |
       17{_ordinal = 'seventeen'}{_cardinal = 'seventeenth'} |
       18{_ordinal = 'eighteen'}{_cardinal = 'eighteenth'} |
       19{_ordinal = 'nineteen'}{_cardinal = 'nineteenth'} ];

# Twenties
Twenties [
           (2 $SingleDigitNoZero)
           {_ordinal='twenty'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='twenty'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           20
           {_ordinal='twenty'}
           {_cardinal='twentieth'}
         ];

TwentiesCardinal = [$Twenties]{_out=Twenties._cardinal} $CardinalMark;

# Thirties
Thirties [
           (3 $SingleDigitNoZero)
           {_ordinal='thirty'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='thirty'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           30
           {_ordinal='thirty'}
           {_cardinal='thirtieth'}
         ];

ThirtiesCardinal = [$Thirties]{_out=Thirties._cardinal} $CardinalMark;

# Fourties
Fourties [
           (4 $SingleDigitNoZero)
           {_ordinal='forty'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='forty'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           40
           {_ordinal='forty'}
           {_cardinal='fortieth'}
         ];

FourtiesCardinal = [$Fourties]{_out=Fourties._cardinal} $CardinalMark;

# Fifties
Fifties [
           (5 $SingleDigitNoZero)
           {_ordinal='fifty'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='fifty'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           50
           {_ordinal='fifty'}
           {_cardinal='fiftieth'}
         ];

FiftiesCardinal = [$Fifties]{_out=Fifties._cardinal} $CardinalMark;

# Sixties
Sixties [
           (6 $SingleDigitNoZero)
           {_ordinal='sixty'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='sixty'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           60
           {_ordinal='sixty'}
           {_cardinal='sixtieth'}
         ];

SixtiesCardinal = [$Sixties]{_out=Sixties._cardinal} $CardinalMark;

# Seventies
Seventies [
           (7 $SingleDigitNoZero)
           {_ordinal='seventy'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='seventy'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           70
           {_ordinal='seventy'}
           {_cardinal='seventieth'}
         ];

SeventiesCardinal = [$Seventies]{_out=Seventies._cardinal} $CardinalMark;

# Eighties
Eighties [
           (8 $SingleDigitNoZero)
           {_ordinal='eighty'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='eighty'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           80
           {_ordinal='eighty'}
           {_cardinal='eightieth'}
         ];

EightiesCardinal = [$Eighties]{_out=Eighties._cardinal} $CardinalMark;

# Nineties
Nineties [
           (9 $SingleDigitNoZero)
           {_ordinal='ninety'}{_ordinal+='_'}{_ordinal += SingleDigitNoZero._ordinal}
           {_cardinal='ninety'}{_cardinal+='_'}{_cardinal += SingleDigitNoZero._cardinal} |
           90
           {_ordinal='ninety'}
           {_cardinal='ninetieth'}
         ];

NinetiesCardinal = [$Nineties]{_out=Nineties._cardinal} $CardinalMark;

# A digit in the tens
TenDigit [ $Tens{_ordinal = Tens._ordinal}{_cardinal = Tens._cardinal} |
           $Twenties{_ordinal = Twenties._ordinal}{_cardinal = Twenties._cardinal} |
           $Thirties{_ordinal = Thirties._ordinal}{_cardinal = Thirties._cardinal} |
           $Fourties{_ordinal = Fourties._ordinal}{_cardinal = Fourties._cardinal} |
           $Fifties{_ordinal = Fifties._ordinal}{_cardinal = Fifties._cardinal} |
           $Sixties{_ordinal = Sixties._ordinal}{_cardinal = Sixties._cardinal} |
           $Seventies{_ordinal = Seventies._ordinal}{_cardinal = Seventies._cardinal} |
           $Eighties{_ordinal = Eighties._ordinal}{_cardinal = Eighties._cardinal} |
           $Nineties{_ordinal = Nineties._ordinal}{_cardinal = Nineties._cardinal} ];

TenDigitCardinal = $TenDigit $CardinalMark{_out=TenDigit._cardinal};

# Any digit from 1 to 99
ToTenDigit [ $TenDigit{_ordinal=TenDigit._ordinal}{_cardinal=TenDigit._cardinal} |
             $SingleDigitNoZero{_ordinal=SingleDigitNoZero._ordinal}{_cardinal=SingleDigitNoZero._cardinal} ];

# Any digit from 1/01 to 31 (used for days in months)
To31Digit [
            $Tens{_ordinal = Tens._ordinal}{_cardinal = Tens._cardinal} |
            $Twenties{_ordinal = Twenties._ordinal}{_cardinal = Twenties._cardinal} |
            ( 30{_ordinal = 'thirty'}{_cardinal = 'thirtieth'} ) |
            ( 31{_ordinal = 'thirty_one'}{_cardinal = 'thirty_first'} ) |
            (
              ?0 $SingleDigitNoZero{_ordinal=SingleDigitNoZero._ordinal}{_cardinal=SingleDigitNoZero._cardinal}
            )
          ];

# Any digit from 01 to 99 normalised to ignore leading 0
ToTen2Digits [ $TenDigit{_ordinal=TenDigit._ordinal}{_cardinal=TenDigit._cardinal} |
               (0 $SingleDigitNoZero{_ordinal=SingleDigitNoZero._ordinal}{_cardinal=SingleDigitNoZero._cardinal}) ];

# A digit in the hundreds
HundredDigit [ 
               $SingleDigitNoZero
                 {_ordinal=SingleDigitNoZero._ordinal}{_ordinal+='_hundred'}
                 {_cardinal=_ordinal}
               (
                 00{_cardinal+='th'} |
                 $ToTen2Digits
                   {_ordinal+='_'}{_ordinal+=ToTen2Digits._ordinal}
                   {_cardinal+='_'}{_cardinal+=ToTen2Digits._cardinal}
               )
             ];

HundredDigitCardinal = [$HundredDigit] $CardinalMark{_out=HundredDigit._cardinal};

# Any digit from 1 to 999
ToHundredDigit [ $HundredDigit{_ordinal=HundredDigit._ordinal}{_cardinal=HundredDigit._cardinal} |
                 $ToTenDigit{_ordinal=ToTenDigit._ordinal}{_cardinal=ToTenDigit._cardinal} ];

ToHundredDigitCardinal = [$ToHundredDigit] $CardinalMark{_out=ToHundredDigit._cardinal};

# Any digit from 001 to 999 normalised to ignore leading 0
ToHundred3Digits [ $HundredDigit{_ordinal=HundredDigit._ordinal}{_cardinal=HundredDigit._cardinal} |
                 (0 $TenDigit{_ordinal=TenDigit._ordinal}{_cardinal=TenDigit._cardinal}) |
                 (00 $SingleDigitNoZero{_ordinal=SingleDigitNoZero._ordinal}{_cardinal=SingleDigitNoZero._cardinal}) ];

ToHundred3DigitsCardinal = [$ToHundred3Digits] $CardinalMark{_out=ToHundred3Digits._cardinal};

# Any digit from 1.000 up to 999.999
ThousandDigit = [
                  $ToHundredDigit
                    {_ordinal=ToHundredDigit._ordinal}{_ordinal+='_thousand'}
                    {_cardinal=_ordinal}
                  (
                    000{_cardinal+='th'} |
                    $ToHundred3Digits
                      {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}
                      {_cardinal+='_'}{_cardinal+=ToHundred3Digits._cardinal}
                  )
                ] |
                (
                  [$ToHundredDigit]
                    {_ordinal=ToHundredDigit._ordinal}{_ordinal+='_thousand'}
                    {_cardinal=_ordinal}
                  ,
                  (
                    000{_cardinal+='th'} | 
                    [$ToHundred3Digits]
                      {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}
                      {_cardinal+='_'}{_cardinal+=ToHundred3Digits._cardinal}
                  )
                );

ThousandDigitCardinal = $ThousandDigit $CardinalMark{_out=ThousandDigit._cardinal};

# A digit in the millions - 1.000.000 to 999.999.999
MillionDigit = [
                 $ToHundredDigit
                   {_ordinal=ToHundredDigit._ordinal}{_ordinal+='_million'}
                 (
                   (000) |
                   $ToHundred3Digits
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}{_ordinal+='_thousand'}
                     {_cardinal=_ordinal}
                 )
                 (
                   000{_cardinal+='th'} |
                   $ToHundred3Digits
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}
                     {_cardinal+='_'}{_cardinal+=ToHundred3Digits._cardinal}
                 )
               ] |
               (
                 [$ToHundredDigit]
                   {_ordinal=ToHundredDigit._ordinal}{_ordinal+='_million'}
                 ,
                 (
                   000 |
                   [$ToHundred3Digits]
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}{_ordinal+='_thousand'}
                     {_cardinal=_ordinal}
                 )
                 ,
                 (
                   000{_cardinal+='th'} |
                   [$ToHundred3Digits]
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}
                     {_cardinal+='_'}{_cardinal+=ToHundred3Digits._cardinal}
                 )
               );

MillionDigitCardinal = $MillionDigit $CardinalMark{_out=MillionDigit._cardinal};

# A digit in the billions - 1.000.000.000 to 999.999.999.999
BillionDigit = [
                 $ToHundredDigit
                   {_ordinal=ToHundredDigit._ordinal}{_ordinal+='_billion'}
                 (
                   (000) |
                   $ToHundred3Digits
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}{_ordinal+='_million'}
                 )
                 (
                   (000) |
                   $ToHundred3Digits
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}{_ordinal+='_thousand'}
                     {_cardinal=_ordinal}
                 )
                 (
                   000{_cardinal='th'} |
                   $ToHundred3Digits
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}
                     {_cardinal+='_'}{_cardinal+=ToHundred3Digits._cardinal}
                 )
               ] |
               (
                 [$ToHundredDigit]
                   {_ordinal=ToHundredDigit._ordinal}{_ordinal+='_billion'}
                 ,
                 (
                   000 |
                   [$ToHundred3Digits]
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}{_ordinal+='_million'}
                 )
                 ,
                 (
                   000 |
                   [$ToHundred3Digits]
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}{_ordinal+='_thousand'}
                     {_cardinal=_ordinal}
                 )
                 ,
                 (
                   000{_cardinal='th'} |
                   [$ToHundred3Digits]
                     {_ordinal+='_'}{_ordinal+=ToHundred3Digits._ordinal}
                     {_cardinal+='_'}{_cardinal+=ToHundred3Digits._cardinal}
                 )
               );

DigitWord = thousand{_out='thousand'} |
            million{_out='million'} |
            billion{_out='billion'} |
            trillion{_out='trillion'};

BillionDigitCardinal = $BillionDigit $CardinalMark{_out=BillionDigit._cardinal};

# Primarily used for time, but generally useful
ClockDigit [ ( ($ToTenDigit{_out=ToTenDigit._ordinal} | 0{_out='zero'}) | ($ToTen2Digits{_out=ToTen2Digits._ordinal} | 00{_out='zero'}) ) :{_out+='_'} ($ToTen2Digits{_out+=ToTen2Digits._ordinal} | 00{_out+='zero'}) ];

#Exact thousands - used for years
ExactThousands [ $SingleDigitNoZero 000 
               {_out=SingleDigitNoZero._ordinal}{_out+='_'}{_out+='thousand'}];

# The whole tens as plurals - used for e.g. years such as 1990's
ExactTensPlural [ 10{_out='tens'} |
                  20{_out='twenties'} |
                  30{_out='thirties'} |
                  40{_out='forties'} |
                  50{_out='fifties'} |
                  60{_out='sixties'} |
                  70{_out='seventies'} |
                  80{_out='eighties'} |
                  90{_out='nineties'}];

#### Currencies ####
# Top currency rule
Currency = $CurrencySingular{_out=CurrencySingular._out} |
           $CurrencyPlural{_out=CurrencyPlural._out}~0.1;

# A currency in the singular
CurrencySingular = $CurrencySingularLeading{_out=CurrencySingularLeading._out} |
                   $CurrencySingularTrailingSpaceDecimal{_out=CurrencySingularTrailingSpaceDecimal._out} |
                   $CurrencySingularTrailingSpace{_out=CurrencySingularTrailingSpace._out};

# A currency in plural
CurrencyPlural = $CurrencyPluralLeading{_out=CurrencyPluralLeading._out} |
                 $CurrencyPluralTrailingSpace{_out=CurrencyPluralTrailingSpace._out} |
                 $CurrencyPluralTrailingSpaceDecimal{_out=CurrencyPluralTrailingSpaceDecimal._out};

# Currencies in plural with leading/trailing sign
CurrencyPluralLeading = $CurrencySign
                        (
                          $handle:Digit{_out=Digit._ordinal}{_out+='_'}{_out+=CurrencySign._plural}
                          ?(
                            . 
                            (
                              01{_out+='_one_'}{_out+=CurrencySign._smallSingular} |
                              [$ToTen2Digits]{_out+='_'}{_out+=ToTen2Digits._ordinal}{_out+='_'}{_out+=CurrencySign._smallPlural}~0.1
                            )
                          )
                        ) | 
                        (
                          (
                            ($handle:Digit{_out=Digit._ordinal} ?(. [$ToTen2Digits]{_out+='_point_'}{_out+=ToTen2Digits._ordinal})) |
                            $DigitWithDecimal{_out=DigitWithDecimal._out}~0.2
                          )
                          $DigitWord{_out+='_'}{_out+=DigitWord._out}{_out+='_'}{_out+=CurrencySign._plural}
                        );

CurrencyPluralTrailingSpace = $handle:Digit{_out=Digit._ordinal}{_out+='_'}
                              $CurrencySign{_out+=CurrencySign._plural};

CurrencyPluralTrailingSpaceDecimal = $handle:Digit .
                                       (01 $CurrencySign)
                                       {_out=Digit._ordinal}{_out+='_'}{_out+=CurrencySign._plural}{_out+='_one_'}{_out+=CurrencySign._smallSingular} |
                                       ([$ToTen2Digits] $CurrencySign)
                                       {_out=Digit._ordinal}{_out+='_'}{_out+=CurrencySign._plural}{_out+='_'}{_out+=ToTen2Digits._ordinal}{_out+='_'}{_out+=CurrencySign._smallPlural};

#Currencies in singular with leading/trailing sign
CurrencySingularLeading = $CurrencySign 
                          (
                            (1{_out='one_'} ?$DigitWord{_out+=DigitWord._out}){_out+=CurrencySign._singular}
                            ?( 
                              . (01{_out+='_one_'}{_out+=CurrencySign._smallSingular} |
                                [$ToTen2Digits]{_out+='_'}{_out+=ToTen2Digits._ordinal}{_out+='_'}{_out+=CurrencySign._smallPlural}~0.1)
                            )
                          );

CurrencySingularTrailingSpace = 1{_out='one_'} $CurrencySign{_out+=CurrencySign._singular};

CurrencySingularTrailingSpaceDecimal = 1 . 
                                         (01 $CurrencySign)
                                         {_out='one_'}{_out+=CurrencySign._singular}{_out+='_one_'}{_out+=CurrencySign._smallSingular} |
                                         ([$ToTen2Digits] $CurrencySign)
                                         {_out='one_'}{_out+=CurrencySign._singular}{_out+='_'}{_out+=ToTen2Digits._ordinal}{_out+='_'}{_out+=CurrencySign._smallPlural};

# Currencies
CurrencySign = \${_singular='dollar'}{_plural='dollars'}{_smallSingular='cent'}{_smallPlural='cents'} |
             hkd{_singular='hong_kong_dollar'}{_plural='hong_kong_dollars'}{_smallSingular='cent'}{_smallPlural='cents'} |
             mxn{_singular='mexican_peso'}{_plural='mexican_pesos'}{_smallSingular='centavo'}{_smallPlural='centavos'} |
             cop{_singular='columbian_peso'}{_plural='columbian_pesos'}{_smallSingular='centavo'}{_smallPlural='centavos'} |
             clp{_singular='chilean_peso'}{_plural='chilean_pesos'}{_smallSingular='centavo'}{_smallPlural='centavos'} |
             cad{_singular='canadian_dollar'}{_plural='canadian_dollars'}{_smallSingular='cent'}{_smallPlural='cents'} |
             usd{_singular='uletter_sletter_dollar'}{_plural='uletter_sletter_dollars'}{_smallSingular='cent'}{_smallPlural='cents'} |
             nzd{_singular='new_zealand_dollar'}{_plural='new_zealand_dollars'}{_smallSingular='cent'}{_smallPlural='cents'} |
             ¥{_singular='yuan'}{_plural='yuans'}{_smallSingular='fen'}{_smallPlural='fens'} |
             cny{_singular='chinese_yuan'}{_plural='chinese_yuans'}{_smallSingular='fen'}{_smallPlural='fens'} |
             ¥{_singular='yen'}{_plural='yens'}{_smallSingular='sen'}{_smallPlural='sens'} |
             jpy{_singular='japanese_yen'}{_plural='japanese_yens'}{_smallSingular='sen'}{_smallPlural='sens'} |
             £{_singular='pound'}{_plural='pounds'}{_smallSingular='pence'}{_smallPlural='pence'} |
             gbp{_singular='british_pound'}{_plural='british_pounds'}{_smallSingular='pence'}{_smallPlural='pence'} |
             egp{_singular='egyptian_pound'}{_plural='egyptian_pounds'}{_smallSingular='pence'}{_smallPlural='pence'} |
             €{_singular='euro'}{_plural='euros'}{_smallSingular='cent'}{_smallPlural='cents'} |
             ₩{_singular='won'}{_plural='wons'}{_smallSingular='jeon'}{_smallPlural='jeons'} |
             kpw{_singular='north_korean_won'}{_plural='north_korean_wons'}{_smallSingular='chon'}{_smallPlural='chons'} |
             krw{_singular='south_korean_won'}{_plural='south_korean_wons'}{_smallSingular='jeon'}{_smallPlural='jeons'} |
             ₱{_singular='peso'}{_plural='pesos'}{_smallSingular='centavo'}{_smallPlural='centavos'} |
             ₹{_singular='rupee'}{_plural='rupees'}{_smallSingular='paisa'}{_smallPlural='paisas'} |
             (rs ?.){_singular='rupee'}{_plural='rupees'}{_smallSingular='paisa'}{_smallPlural='paisas'} |
             inr{_singular='indian_rupee'}{_plural='indain_rupees'}{_smallSingular='paisa'}{_smallPlural='paisas'} |
             (kr ?.){_singular='krone'}{_plural='kroner'}{_smallSingular='oere'}{_smallPlural='oerer'} |
             (s/ .){_singular='sol'}{_plural='sols'}{_smallSingular='céntimo'}{_smallPlural='céntimos'} |
             pen{_singular='peruvian_sol'}{_plural='peruvian_sols'}{_smallSingular='centimo'}{_smallPlural='centimos'} |
             ₺{_singular='lira'}{_plural='liras'}{_smallSingular='kurus'}{_smallPlural='kurus'} |
             try{_singular='turkish_lira'}{_plural='turkish_liras'}{_smallSingular='kurus'}{_smallPlural='kurus'} |
             (r ?.){_singular='rand'}{_plural='rands'}{_smallSingular='cent'}{_smallPlural='cents'} |
             zar{_singular='south_african_rand'}{_plural='south_african_rands'}{_smallSingular='cent'}{_smallPlural='cents'} |
             rub{_singular='ruble'}{_plural='rubles'}{_smallSingular='kopek'}{_smallPlural='kopeks'} |
             dkk{_singular='danish_krone'}{_plural='danish_kroner'}{_smallSingular='oere'}{_smallPlural='oerer'} |
             sek{_singular='swedish_krona'}{_plural='swedish_kronas'}{_smallSingular='oeren'}{_smallPlural='oerens'} |
             nok{_singular='norwegian_krone'}{_plural='norwegian_kroner'}{_smallSingular='oere'}{_smallPlural='oerer'} |
             isk{_singular='icelandic_krona'}{_plural='icelandic_kronur'}{_smallSingular='eyrir'}{_smallPlural='eyrir'} |
             (kč ?.){_singular='koruna'}{_plural='korunas'}{_smallSingular='haleru'}{_smallPlural='halerus'} |
             czk{_singular='czech_koruna'}{_plural='czech_korunas'}{_smallSingular='haleru'}{_smallPlural='halerus'} |
             irr{_singular='iranian_rial'}{_plural='iranian_rials'}{_smallSingular='dinar'}{_smallPlural='dinars'} |
             chf{_singular='swiss_franc'}{_plural='swiss_francs'}{_smallSingular='rap'}{_smallPlural='raps'} |
             ¢{_singular='centavo'}{_plural='centavos'}{_smallSingular='centavo'}{_smallPlural='centavos'} ;

##### Dates ######
Dates = $DateNumber{_out=DateNumber._out} |
        $YearDate{_out=YearDate._out} |
        $YearPeriod{_out=YearPeriod._out} |
        $DateWritten{_out=DateWritten._out};


#7/2/1996 or 7/2-1996 or 7 2, 1998 etc
DateNumber = (
              [$MonthsNumbers]{_out=MonthsNumbers._out}{_out+='_'} |
              $Months{_out=Months._out}{_out+='_'}
             )
             (
               (
                 (/|-|,)
                 [$To31Digit]{_out+=To31Digit._cardinal}
                 ?(/|-|,)
               ) | 
               (
                 [$To31Digit]{_out+=To31Digit._cardinal}
                 (/|-|,)
               )
             )
             ?[$Year]{_out+='_'}{_out+=Year._out};

# 10th February 1995 or February 10th 1995
DateWritten = (
                [$To31Digit]{_out=To31Digit._cardinal}{_out+='_'}
                ?$CardinalMark
                $Months{_out+=Months._out}{_out+='_'}
              ) |
              (
                $Months{_out=Months._out}{_out+='_'}
                [$To31Digit]{_out+=To31Digit._cardinal}{_out+='_'}
                ?$CardinalMark
              )
              ?,{_out+='_'}
              ?[$Year{_out+=Year._out}];

YearDate = $YearDateTrailing{_out=YearDateTrailing._out} | $YearDateLeading{_out=YearDateLeading._out};

YearDateLeading =  (
                     (from{_out='from_'} ?a{_out+='a_'}) |
                     to{_out='to_'} |
                     in{_out='in_'} |
                     on{_out='on_'} |
                     of{_out='of_'} |
                     between{_out='between_'} |
                     and{_out='and_'} |
                     before{_out='before_'} |
                     after{_out='after_'} |
                     -{_out='to_'} |
                     year{_out='year_'} |
                     years{_out='years_'} |
                     since{_out='since_'} |
                     $Months{_out=Months._out}{_out+='_'} |
                     (is a){_out='is_a_'} |
                     (is an){_out='is_an_'} |
                     (miss world){_out='miss_world_'} |
                     (published as){_out='published_as_'}
                   )
                   [$Year{_out+=Year._out}];

YearDateTrailing = [$Year{_out=Year._out}]
                   (
                     film{_out+='_film'}
                   );

# A year that starts with 1 or 2
YearSafe [ (
         ($Tens{_out=Tens._ordinal} | $Twenties{_out=Twenties._ordinal})
         (
           $TenDigit{_out+='_'}{_out+=TenDigit._ordinal} |
           (0 0~0.1){_out+='_hundred'}~1 |
           (0{_out+='_oletter_'} $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal})
         )
       ) |
       $ExactThousands{_out=ExactThousands._out} |
       ((1{_out='one'} | 2{_out='two'} ){_out+='_thousand_'} 00 $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal}) ];

#Any year
Year [ (
         $TenDigit{_out=TenDigit._ordinal}
         (
           $TenDigit{_out+='_'}{_out+=TenDigit._ordinal} |
           (0 0~0.1){_out+='_hundred'}~1 |
           (0{_out+='_oletter_'} $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal})
         )
       ) |
       $ExactThousands{_out=ExactThousands._out} |
       ($SingleDigitNoZero{_out=SingleDigitNoZero._ordinal}{_out+='_thousand_'} 00 $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal}) ];

# 1990's etc. We assume, for simplicity, these will not end in a single digit (e.g. 1999's)
YearPeriod = [$YearPlural] (\'s | s){_out=YearPlural._out};

YearPlural [  (
                 $TenDigit{_out=TenDigit._ordinal}
                 (
                   $ExactTensPlural{_out+='_'}{_out+=ExactTensPlural._out} |
                   $TenDigit~0.1{_out+='_'}{_out+=TenDigit._ordinal}{_out+='s'} |
                   (0 0~0.2){_out+='_hundreds'}~1 |
                   (0{_out+='_oletter_'} $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal}{_out+='s'})
                 )
              ) |
              $ExactThousands{_out=ExactThousands._out}{_out+='s'} |
              ($SingleDigitNoZero{_out=SingleDigitNoZero._ordinal}{_out+='_thousand_'} 00 $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal}{_out+='s'})
              ];

Months = $MonthAbbrev{_out=MonthAbbrev._out} | $MonthFull{_out=MonthFull._out};

#Months - also used for abbreviations
MonthAbbrev = (jan ?.){_out='january'} |
               (feb ?.){_out='february'} |
               (mar ?.){_out='march'} |
               (apr ?.){_out='april'} |
               (jun ?.){_out='june'} |
               (jul ?.){_out='july'} |
               (aug ?.){_out='august'} |
               (sep ?.){_out='september'} |
               (sept ?.){_out='september'} |
               (oct ?.){_out='october'} |
               (nov ?.){_out='november'} |
               (dec ?.){_out='december'};

MonthFull = january{_out='january'} |
            february{_out='february'} |
            march{_out='march'} |
            april{_out='april'} |
            may{_out='may'} |
            june{_out='june'} |
            july{_out='july'} |
            august{_out='august'} |
            september{_out='september'} |
            october{_out='october'} |
            november{_out='november'} |
            december{_out='december'};

MonthsNumbers [ (?01){_out='january'} |
                (?02){_out='february'} |
                (?03){_out='march'} |
                (?04){_out='april'} |
                (?05){_out='may'} |
                (?06){_out='june'} |
                (?07){_out='july'} |
                (?08){_out='august'} |
                (?09){_out='september'} |
                10{_out='october'} |
                11{_out='november'} |
                12{_out='december'} ];


####### Time #######
Time = $Times{_out=Times._out};

Times = ($HoursAMPM{_out=HoursAMPM._out}
          ?(
            (.|:)
            ([$TenDigit]{_out+='_'}{_out+=TenDigit._ordinal} |
             00 |
             [0{_out+='_oletter_'}$SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal}])
            ?((.|:) 00)
          )
          $AMPM{_out+='_'}{_out+=AMPM._out}) |
        (12 ?((.|:) 00) $AM{_out='midnight'}) |
        (12 ?((.|:) 00) $PM{_out='noon'}) |
        (00 ?((.|:) 00) $AM{_out='midnight'}) |
        (00 ?((.|:) 00) $PM{_out='noon'});

HoursAMPM = [$SingleDigitNoZero]{_out=SingleDigitNoZero._ordinal} |
            10{_out='ten'} |
            11{_out='eleven'} |
            12{_out='twelve'};

Hours24 = [$SingleDigitNoZero]{_out=SingleDigitNoZero._ordinal} |
          [$TenDigit]{_out=TenDigit._ordinal} |
          20{_out='twenty'} |
          21{_out='twenty_one'} |
          22{_out='twenty_two'} |
          23{_out='twenty_three'} |
          24{_out='twenty_four'};

AMPM = $AM{_out=AM._out} | $PM{_out=PM._out} | o\'clock{_out='o\'clock'};

AM = ((a . m) | am){_out='aletter_mletter'};

PM = ((p . m) | pm){_out='pletter_mletter'};

####### Measures ######

Measures = $MeasuresPlural{_out=MeasuresPlural._out} | 
            $MeasuresSingular{_out=MeasuresSingular._out} | 
            $MeasuresSpecial{_out=MeasuresSpecial._out} |
            $MeasuresWritten{_out=MeasuresWritten._out};

# A set of special exceptions/rules which are not covered by the below
MeasuresSpecial = (
                    (
                      1{_out='one_foot_'} | 
                      $handle:Digit{_out=Digit._ordinal}{_out+='_feet_'}
                    )
                    (
                      1{_out+='one_inch'} | $handle:Digit{_out+=Digit._ordinal}{_out+='_inches'}
                    ) `` 
                  ) |
                  (
                    ?\(
                    $handle:Digit{_out='\[spau\]_'}{_out+=Digit._ordinal}
                    (-|–){_out+='_to_'}
                    $handle:Digit{_out+=Digit._ordinal}
                    in .{_out+='_inches_\[spau\]'}
                    ?\)
                  );

MeasuresSingular = 1{_out='one_'} ?(. [+0]) $MeasureGroup{_out+=MeasureGroup._singular};

MeasuresPlural = ($handle:Digit{_out=Digit._ordinal} | $DigitDecimal{_out=DigitDecimal._out})
                  $MeasureGroup{_out+='_'}{_out+=MeasureGroup._plural};

#We only care about this when we're in the thousands
MeasuresWritten = $ThousandDigit{_out=ThousandDigit._ordinal}
                  $MeasureGroupWritten{_out+='_'}{_out+=MeasureGroupWritten._out};

MeasureGroup = $Weights{_singular=Weights._singular}{_plural=Weights._plural} |
               $Distances{_singular=Distances._singular}{_plural=Distances._plural} |
               $TimeMeasures{_singular=TimeMeasures._singular}{_plural=TimeMeasures._plural}~0.1 |
               $Volumes{_singular=Volumes._singular}{_plural=Volumes._plural} |
               $Speeds{_singular=Speeds._singular}{_plural=Speeds._plural};

MeasureGroupWritten = $WeightsWritten{_out=WeightsWritten._out} |
                       $DistancesWritten{_out=DistancesWritten._out} |
                       $TimeMeasuresWritten{_out=TimeMeasuresWritten._out} |
                       $VolumesWritten{_out=VolumesWritten._out} |
                       $SpeedsWritten{_out=SpeedsWritten._out};

TimeMeasures = ms{_singular='millisecond'}{_plural='milliseconds'} |
               s{_singular='second'}{_plural='seconds'} |
               (mins | min){_singular='minute'}{_plural='minutes'} |
               h{_singular='hour'}{_plural='hours'} |
               hrs{_singular='hour'}{_plural='hours'};

TimeMeasuresWritten = millisecond{_out='millisecond'} |
                      milliseconds{_out='milliseconds'} |
                      second{_out='second'} |
                      seconds{_out='seconds'} |
                      hour{_out='hour'} |
                      hours{_out='hours'};

Distances = $DistanceSafe{_singular=DistanceSafe._singular}{_plural=DistanceSafe._plural} |
            $DistanceNoSafe{_singular=DistanceNoSafe._singular}{_plural=DistanceNoSafe._plural};

# These are distance measures which are "safe" to use as general abbreviations
DistanceSafe = mm{_singular='millimeter'}{_plural='millimeters'} |
               cm{_singular='centimeter'}{_plural='centimeters'} |
               dm{_singular='decimeter'}{_plural='decimeters'} |
               km{_singular='kilometer'}{_plural='kilometers'} |
               yd{_singular='yard'}{_plural='yards'} |
               mi{_singular='mile'}{_plural='miles'} |
               ft{_singular='foot'}{_plural='feet'};

#There are measures that are not considered safe as general abbreviations
DistanceNoSafe = ``{_singular='inch'}{_plural='inches'} |
                 m{_singular='meter'}{_plural='meters'};

#                 in{_singular='inch'}{_plural='inches'};

DistancesWritten = millimeter{_out='millimeter'} |
                   millimeters{_out='millimeters'} |
                   centimeter{_out='centimeter'} |
                   centimeters{_out='centimeters'} |
                   decimeter{_out='decimeter'} |
                   decimeters{_out='decimeters'} |
                   kilometer{_out='kilometer'} |
                   kilometers{_out='kilometers'} |
                   yard{_out='yard'} |
                   yards{_out='yards'} |
                   mile{_out='mile'} |
                   miles{_out='miles'} |
                   foot{_out='foot'} |
                   feet{_out='feet'} |
                   inch{_out='inch'} |
                   inches{_out='inches'} |
                   meter{_out='meter'} |
                   meters{_out='meters'};

Volumes = $VolumesSafe{_singular=VolumesSafe._singular}{_plural=VolumesSafe._plural} |
            $VolumesNoSafe{_singular=VolumesNoSafe._singular}{_plural=VolumesNoSafe._plural};

VolumesSafe = (fl oz){_singular='fluid_ounce'}{_plural='fluid_ounces'} |
              qt{_singular='quart'}{_plural='quarts'} |
              gal{_singular='gallon'}{_plural='gallons'} |
              ml{_singular='milliliter'}{_plural='milliliters'} |
              cl{_singular='centiliter'}{_plural='centiliters'} |
              dl{_singular='deciliter'}{_plural='deciliters'};

VolumesNoSafe = pt{_singular='pint'}{_plural='pints'} |
                l{_singular='liter'}{_plural='liters'};

VolumesWritten = (fluid ounce){_out='fluid_ounce'} |
                 (fluid ounces){_out='fluid_ounces'} |
                  quart{_out='quart'} |
                  quarts{_out='quarts'} |
                  gallon{_out='gallon'} |
                  gallons{_out='gallons'} |
                  milliliter{_out='milliliter'} |
                  milliliters{_out='milliliters'} |
                  centiliter{_out='centiliter'} |
                  centiliters{_out='centiliters'} |
                  deciliter{_out='deciliter'} |
                  deciliters{_out='deciliters'} |
                  pint{_out='pint'} |
                  pints{_out='pints'} |
                  liter{_out='liter'} |
                  liters{_out='liters'};

Speeds = mph{_singular='mile_per_hour'}{_plural='miles_per_hour'} |
         (km / h){_singular='kilometer_per_hour'}{_plural='kilometers_per_hour'};

SpeedsWritten = (miles per hour){_out='miles_per_hour'} |
                (mile per hour){_out='mile_per_hour'} |
                (kilometer per hour){_out='kilometer_per_hour'} |
                (kilometers per hour){_out='kilometers_per_hour'};

Weights = $WeightSafe{_singular=WeightSafe._singular}{_plural=WeightSafe._plural} |
          $WeightNoSafe{_singular=WeightNoSafe._singular}{_plural=WeightNoSafe._plural};

WeightSafe = mg{_singular='milligram'}{_plural='milligrams'} |
             cg{_singular='centigram'}{_plural='centigrams'} |
             dg{_singular='decigram'}{_plural='decigrams'} |
             kg{_singular='kilo'}{_plural='kilos'} |
             lb{_singular='pound'}{_plural='pounds'} |
             oz{_singular='ounce'}{_plural='ounces'};

WeightNoSafe = g{_singular='gram'}{_plural='grams'} |
               st{_singular='stone'}{_plural='stones'} |
               t{_singular='ton'}{_plural='tons'};

WeightsWritten = milligram{_out='milligram'} |
                 milligrams{_out='milligrams'} |
                 centigram{_out='centigram'} |
                 centigrams{_out='centigrams'} |
                 decigram{_out='decigram'} |
                 decigrams{_out='decigrams'} |
                 kilo{_out='kilo'} |
                 kilos{_out='kilos'} |
                 pound{_out='pound'} |
                 pounds{_out='pounds'} |
                 ounce{_out='ounce'} |
                 ounces{_out='ounces'} |
                 gram{_out='gram'} |
                 grams{_out='grams'} |
                 stone{_out='stone'} |
                 stones{_out='stones'} |
                 ton{_out='ton'} |
                 tons{_out='tons'};

####### Addresses ########
# This aims to cover US style address patterns only.
Address = $StateZip{_out=StateZip._out} |
          $HouseStreet{_out=HouseStreet._out} |
          $StreetNWES{_out=StreetNWES._out} |
          $StreetStAveBlvd{_out=StreetStAveBlvd._out} |
          $StDr{_out=StDr._out};

# E.g. CA, 23456
StateZip = $StatesUnsafeWithMaine{_out=StatesUnsafeWithMaine._out} ?,|- [$Zip]{_out+='_'}{_out+=Zip._out};

# E.g. 1234, Apt. #3, 12th
# 23, Ste. 5, 34th
HouseStreet = [$HouseNumber]{_out=HouseNumber._out}{_out+='_\[spau\]'} ?,
              ?$ApartmentNo{_out+='_'}{_out+=ApartmentNo._out}{_out+='_\[spau\]'} ?,
              (
                $StreetNumber{_out+='_'}{_out+=StreetNumber._out} |
                $StreetStAveBlvd{_out+='_'}{_out+=StreetStAveBlvd._out} |
                $WordStAveBlvd{_out+='_'}{_out+=WordStAveBlvd._out}~1 |
                $StreetNWES{_out+='_'}{_out+=StreetNWES._out} |
                $WordNWES{_out+='_'}{_out+=WordNWES._out}
              )
              ?(?, $ApartmentNo{_out+='_\[spau\]_'}{_out+=ApartmentNo._out}{_out+='_\[spau\]'} ?,)
              ?$Floor{_out+='_'}{_out+=Floor._out};

ApartmentNo = (
                (
                  (apt|apartment){_out='_apartment_'} |
                  (ste|suite){_out='_suite_'}
                )
                ?.
              )
              ?( \# | (no ?.) )
              [$HouseNumber]{_out+='_'}{_out+=HouseNumber._out};

Floor = $StreetNumber{_out=StreetNumber._out} (fl|floor){_out+='_floor_\[spau\]'} ?,;

# A simple safe way to detect saint and doctor over street and drive
StDr = (st{_out='saint'}|dr{_out='doctor'}) ?. $Word{_out+='_'}{_out+=Word._out} $StAveBlvd{_out+='_'}{_out+=StAveBlvd._out};

StreetNWES = $StreetNumber{_out=StreetNumber._out} $WordNWES{_out+='_'}{_out+=WordNWES._out};

StreetStAveBlvd = $StreetNumber{_out=StreetNumber._out}
                  ?(
                    $Word{_out+='_'}{_out+=Word._out}~0.1 |
                    $LetterAbbreviations{_out+=LetterAbbreviations._out}
                  )
                  $StAveBlvd{_out+='_'}{_out+=StAveBlvd._out};

WordStAveBlvd = (
                  $Word{_out+='_'}{_out+=Word._out}~0.1 |
                  $LetterAbbreviations{_out+='_'}{_out+=LetterAbbreviations._out}
                )
                $StAveBlvd{_out+='_'}{_out+=StAveBlvd._out};

WordNWES = ($Word{_out=Word._out} ?$StAveBlvd{_out+='_'}{_out+=StAveBlvd._out} $NWES{_out+='_'}{_out+=NWES._out}) |
            ($NWES{_out=NWES._out} ?$Word{_out+='_'}{_out+=Word._out} $StAveBlvd{_out+='_'}{_out+=StAveBlvd._out});

# These are taken primarily from http://pe.usps.gov/text/pub28/28apc_002.htm
# For brevity not all are included
StAveBlvd = (
              (alley|aly){_out='alley'} |
              (annex|anex|anx){_out='annex'} |
              (arcade|arc){_out='arcade'} |
              (ave|avenue|avn|avenu){_out='avenue'} |
              (bayou|bayoo|byo){_out='bayou'} |
              (beach|bch){_out='beach'} |
              (bend|bnd){_out='bend'} |
              (bluff|bluf|blf){_out='bluff'} |
              (bluffs|blfs){_out='bluffs'} |
              (bottom|btm|bot){_out='bottom'} |
              (blvd|boulevard|boulv){_out='boulevard'} |
              (branch|br|brnch){_out='branch'} |
              (bridge|brdge|brg){_out='bridge'} |
              (brook|brk){_out='brook'} |
              (brooks|brks){_out='brooks'} |
              (burg|bg){_out='burg'} |
              (burgs|bgs){_out='burgs'} |
              (bypass|byp|byps){_out='bypass'} |
              (camp|cp|cmp){_out='cp'} |
              (canyon|canyn|cnyn|cyn){_out='canyon'} |
              (cape|cpe){_out='cape'} |
              (causeway|causwa|cswy){_out='causeway'} |
              (center|centre|cent|ctr|cntr|cen){_out='center'} |
              (centers|centres|ctrs){_out='centers'} |
              (circle|cir|crcl|circ){_out='circle'} |
              (cliff|clf){_out='cliff'} |
              (cliffs|clfs){_out='cliffs'} |
              (club|clb){_out='club'} |
              (common|cmn|comm){_out='common'} |
              (commons|cmns|comms){_out='commons'} |
              (corner|cor){_out='corner'} |
              (corners|cors){_out='corners'} |
              (course|crse){_out='course'} |
              (court|ct){_out='court'} |
              (courts|cts){_out='courts'} |
              (cove|cv){_out='cove'} |
              (coves|cvs){_out='coves'} |
              (creek|crk){_out='creek'} |
              (crescent|cres|crsent|crsnt){_out='crescent'} |
              (crest|crst){_out='crest'} |
              (crossing|crssng|xing){_out='crossing'} |
              (crossroad|xrd){_out='crossroad'} |
              (crossroads|xrds){_out='crossroads'} |
              (curve|curv){_out='curve'} |
              (dale|dl){_out='dale'} |
              (dam|dm){_out='dam'} |
              (divide|div|dv|dvd){_out='divide'} |
              (drive|dr|driv|drv){_out='drive'} |
              (drives|drs){_out='drives'} |
              (estate|est){_out='estate'} |
              (estates|ests){_out='estates'} |
              (expressway|exp|expy|expr|express|expw|expr){_out='expressway'} |
              (extension|ext|extn|exnsn){_out='extension'} |
              (extensions|exts){_out='extensions'} |
              (fall){_out='fall'} |
              (falls|fls){_out='falls'} |
              (ferry|fry){_out='ferry'} |
              (field|fld){_out='field'} |
              (fields|flds){_out='fields'} |
              (flat|flt){_out='flat'} |
              (flats|flts){_out='flats'} |
              (ford|frd){_out='ford'} |
              (fords|frds){_out='fords'} |
              (forest|frst){_out='forest'} |
              (forge|frg){_out='forge'} |
              (forges|frgs){_out='forges'} |
              (fork|frk){_out='fork'} |
              (forks|frks){_out='forks'} |
              (fort|frt|ft){_out='fort'} |
              (freeway|frwy|fwy|freewy){_out='freeway'} |
              (garden|gardn|grdn|grden){_out='garden'} |
              (gardens|gardns|grdns|grdens){_out='gardens'} |
              (gateway|gtwy|gtway|gatewy){_out='gateway'} |
              (glen|gln){_out='glen'} |
              (glens|glns){_out='glens'} |
              (green|grn){_out='green'} |
              (greens|grns){_out='greens'} |
              (grove|grov|grv){_out='grove'} |
              (groves|grvs){_out='groves'} |
