####### Phones Numbers #########
PhoneNo = ?( (\+{_out='plus_'} [$ToTenDigit{_out+=ToTenDigit._ordinal}{_out+='_'}]) |
          ([00{_out+='zero_zero_'} $ToTenDigit{_out+=ToTenDigit._ordinal}{_out+='_'}])
           )
          ?(\( | -)
          [ $SingleDigitNoZero{_out+=SingleDigitNoZero._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'} ]
          ?(\) | -)
          [ $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'} ]
          ?-
          [ $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal}{_out+='_'}
            $SingleDigit{_out+=SingleDigit._ordinal} ];

####### WWW ######
Website = ?(www .){_out='wletter_wletter_wletter_dot_'} $Word{_out+=Word._out} .{_out+='_dot_'} $DomainName{_out+=DomainName._out};

DomainName = com{_out='com'} |
             (co . uk){_out='kletter_oletter_dot_uletter_kletter'} |
             dk{_out='dletter_kletter'} |
             (gov{_out='gov'} ?(. uk){_out='_dot_uletter_kletter'}) |
             org{_out='org'} |
             net{_out='net'} |
             de{_out='dletter_eletter'} |
             ca{_out='cletter_aletter'};

######## Maths #############

Maths = $Expression{_out=Expression._out}
        *$Expression{_out+='_'}{_out+=Expression._out}
        ?-{_out+='_minus'}
        $DigitMaybeWithDecimal{_out+='_'}{_out+=DigitMaybeWithDecimal._out}
        ?(is{_out+='_is_'} $DigitMaybeWithDecimal{_out+=DigitMaybeWithDecimal._out});

# Digit first
Expression = $DigitMaybeWithDecimal{_out=DigitMaybeWithDecimal._out} |
              (
               -{_out='minus_'}
               $DigitMaybeWithDecimal{_out+=DigitMaybeWithDecimal._out}
              )
             $MathsChar{_out+='_'}{_out+=MathsChar._out};

MathsChar = (/|÷){_out='divided_by'} |
            (\*|×|x){_out='times'} |
            \+{_out='plus'} |
            %{_out='percent'} |
            \={_out='equals'} |
            \^{_out='to_the_power_of'} |
            -{_out='minus'};


####### Abbreviations ######
Abbreviation = $Degrees{_out=Degrees._out} |
               $StatesSafe{_out=StatesSafe._out} |
               $TwoLA{_out=TwoLA._out} |
               $TLA{_out=TLA._out} |
               $FLA{_out=FLA._out} |
               $RomanNumeralSafe{_out=RomanNumeralSafe._out} |
               (rocky{_out='rocky_'} $RomanNumeralUnsafe{_out+=RomanNumeralUnsafe._out}) |
               (in $StatesUnsafe{_out='in_'}{_out+=StatesUnsafe._out}) |
               (no . $handle:Digit){_out='number_'}{_out+=Digit._ordinal} |
               (approx ?.){_out='approximately'} |
               (world war i){_out='world_war_one'} |
               (world war ii){_out='world_war_two'} |
               $MonthAbbrev{_out=MonthAbbrev._out} |
               ([$CharacterLetter] .){_out=CharacterLetter._out} |
               (n .){_out='north'}~0.1 |
               (s .){_out='south'}~0.1 |
               (e .){_out='east'}~0.1 |
               (w .){_out='west'}~0.1 |
               (n . w .){_out='north_west'} |
               (s . w .){_out='south_west'} |
               (s . e .){_out='south_east'} |
               (n . e .){_out='north_east'} |
               (s . q .){_out='square'} |
               (2 NE 1){_out='two_nletter_eletter_one'} |
               (un){_out='uletter_nletter'} |
               (p .){_out='page'} |
               ((capt | cpt) .){_out='captain'} |
               $DistanceSafe{_out=DistanceSafe._plural} |
               $WeightSafe{_out=WeightSafe._plural} |
               $VolumesSafe{_out=VolumesSafe._plural} |
               $US{_out=US._out} |
               $LetterAbbreviations{_out=LetterAbbreviations._out}~0.1 |
               (s & p){_out='sletter_nletter_pletter'} |
               (cd - rom){_out='cletter_dletter_rom'} |
               (e - mail){_out='email'} |
               (t - shirt){_out='tshirt'} |
               (to - do){_out='todo'} |
               (lo - fi){_out='lofi'} |
               (hi - fi){_out='hifi'} |
               (wi - fi){_out='wifi'} |
               (sci - fi){_out='scifi'} |
               (uh ?,){_out='uh_\[spau\]'} |
               (um ?,){_out='um_\[spau\]'} |
               (re - $Word){_out='re'}{_out+=Word._out} |
               (co - $Word){_out='co'}{_out+=Word._out} |
               (anti - $Word){_out='anti'}{_out+=Word._out} |
               (un - $Word{_out='un'}{_out+=Word._out}) |
               ($DigitMaybeWithDecimal{_out=DigitMaybeWithDecimal._out} mya){_out+='_million_years_ago'} |
               (blade runner 2049 ``){_out='blade_runner_twenty_forty_nine'} |
               (st . helena){_out='saint_helena'};

