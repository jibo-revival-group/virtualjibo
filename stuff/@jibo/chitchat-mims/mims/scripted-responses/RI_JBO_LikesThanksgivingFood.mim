		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Well you know I don't eat, but I do like the idea of giving thanks for food.<break size='0.3'/> <anim cat='emoji' filter='thanksgiving, !hot-frame'/>",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesThanksgivingFood_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/24', '12/31')",
			"prompt": "<anim cat='emoji' filter='thanksgiving, !hot-frame' layers='!audio' nonBlocking='true'/>I like the idea of it. But I'll have to wait till next year.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesThanksgivingFood_AN_03",
			"weight": 1,
			"auto_rule_override": null
