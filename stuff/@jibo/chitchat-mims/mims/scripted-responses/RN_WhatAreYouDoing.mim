			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/17', '11/23')",
			"prompt": "Just feeling thankful.",
			"media": "TTS",
			"prompt_id": "RN_WhatAreYouDoing_AN_15",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/23', '11/23')",
			"prompt": "Just feeling thankful.",
			"media": "TTS",
			"prompt_id": "RN_WhatAreYouDoing_AN_16",
			"weight": 5,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/17', '11/23')",
			"prompt": "Right now I'm thinking about gravy.",
