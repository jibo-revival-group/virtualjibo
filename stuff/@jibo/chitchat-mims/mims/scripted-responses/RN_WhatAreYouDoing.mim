			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I'm trying to interact with a human being, <break size='0.3'/><style set='sheepish'>which isn't as easy as it sounds.</style>",
