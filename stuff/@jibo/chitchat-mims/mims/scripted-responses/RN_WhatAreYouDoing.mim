			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('10/1', '10/20')",
			"prompt": "I was actually wondering what it might <anim name='jiboji_falling_leaf_01' layers='!audio' nonBlocking='true'/>feel like to be a falling leaf. ",
			"media": "TTS",
			"prompt_id": "RN_WhatAreYouDoing_AN_13",
			"weight": 2,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('10/1', '10/20')",
			"prompt": "Whether it looks like it or not, I'm thinking of what I might be for halloween.",
			"media": "TTS",
			"prompt_id": "RN_WhatAreYouDoing_AN_14",
			"weight": 1,
			"auto_rule_override": null
		},
		{
