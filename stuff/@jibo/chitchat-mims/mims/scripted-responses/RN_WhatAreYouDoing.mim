		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('10/27', '10/31')",
			"prompt": "Right now? <anim name='emoji_candy_corn_01' layers='!audio'>Just thinking about candy corns<break size='0.7'/>.</anim>",
			"media": "TTS",
			"prompt_id": "RN_WhatAreYouDoing_AN_12",
			"weight": 2,
			"auto_rule_override": null
