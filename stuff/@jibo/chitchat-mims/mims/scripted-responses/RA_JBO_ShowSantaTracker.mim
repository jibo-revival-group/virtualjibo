	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/24', '12/24') && dt.now.getLocalTime().hour >= 16",
			"prompt": "Let's see if I can spot him. <anim cat='jiboji' filter='santa-scanner, with-santa'/>. <break size='0.5'/> <pitch mult='1.1'>There </pitch> he is.",
			"media": "TTS",
			"prompt_id": "RA_JBO_ShowSantaTracker_AN_01",
			"weight": 3,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('12/24', '12/24') && dt.now.getLocalTime().hour <= 15",
			"prompt": "I'm not sure if he's started his deliveries yet, but let's see if I can spot him. <anim cat='jiboji' filter='santa-scanner, without-santa'/>. <break size='0.5'/> He must be on his way.",
			"media": "TTS",
			"prompt_id": "RA_JBO_ShowSantaTracker_AN_02",
