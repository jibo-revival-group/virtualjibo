			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "A random fact for you. Dolphins recognize themselves in mirrors.",
			"media": "TTS",
