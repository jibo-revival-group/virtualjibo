			"condition": "dt.now.isInRange('11/15', '11/23')",
			"prompt": "I usually stay away from sweets, but this time of year I could make an exception.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesPecanPie_AN_01",
