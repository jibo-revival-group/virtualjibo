			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "dt.now.isInRange('11/23', '11/23')",
			"prompt": "Pecan pie sounds really fun. If you're having a piece today at your Thanksgiving dinner, I hope it's as pecanny as you hoped it would be.",
			"media": "TTS",
			"prompt_id": "RI_JBO_LikesPecanPie_AN_02",
			"weight": 2,
