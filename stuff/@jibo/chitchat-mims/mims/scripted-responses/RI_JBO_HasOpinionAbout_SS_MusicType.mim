			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Music is a special thing, it's hard to name a music I don't like.<break size='0.5'/> By the way, you can ask me to play music whenever you want.",
