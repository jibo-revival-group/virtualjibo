		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "As long as I can dance to it, I'll take it. By the way, if you want me to play you some, say hey jibo, play some music.",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasOpinionAbout_SS_MusicType_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "As long as I can dance to it, I'll take it. <anim cat='dance' filter='&(music, short),!(robotic)'/>",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasOpinionAbout_SS_MusicType_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "I like lots of different kinds of music. That's why I have a radio that plays from the sides of my head.",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasOpinionAbout_SS_MusicType_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
