			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "",
			"prompt": "Music is the spice of life. No wait, that's supposed to be variety. But music. Music is pretty spicy too. I can play music on my radio.",
			"media": "TTS",
			"prompt_id": "RI_JBO_HasOpinionAbout_SS_MusicType_AN_01",
