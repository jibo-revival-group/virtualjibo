	"prompts": [
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!referent",
			"prompt": "<anim cat='no' filter='head-shake' nonBlocking='true'/>I don't know where ${referent} is.",
			"media": "TTS",
			"prompt_id": "RN_WhereIsLoopMember_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!referent",
			"prompt": "<anim cat='no' filter='head-shake' nonBlocking='true'/>I don't know where ${referent} is. <anim cat='question' layers='body'>Did you check <anim name='Emoji_Pillow' nonBlocking='true'/>under the bed?</anim>",
			"media": "TTS",
			"prompt_id": "RN_WhereIsLoopMember_AN_02",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "referent.gender && referent.gender == 'male'",
			"prompt": "<anim cat='no' filter='head-shake' nonBlocking='true'/>I don't know, but I hope to<anim cat='affection'> see him soon. <ssa cat='affection'/></anim>",
			"media": "TTS",
			"prompt_id": "RN_WhereIsLoopMember_AN_03",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "referent.gender && referent.gender == 'female'",
			"prompt": "<anim cat='no' filter='head-shake' nonBlocking='true'/>I don't know, but I hope to<anim cat='affection'> see her soon. <ssa cat='affection'/></anim>",
			"media": "TTS",
			"prompt_id": "RN_WhereIsLoopMember_AN_04",
			"weight": 1
		},
