			"prompt": "<anim cat='no' filter='head-shake' nonBlocking='true'/><ssa cat='dontKnow'/>. Your guess is as good as mine.",
			"media": "TTS",
			"prompt_id": "RN_WhereIsLoopMember_AN_05",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!!referent",
			"prompt": "${referent} <anim name='Emoji_Moon' nonBlocking='true' layers='screen' /><anim name='Shift_21' layers='body' nonBlocking='true'/>is almost definitely not on the moon.",
			"media": "TTS",
			"prompt_id": "RN_WhereIsLoopMember_AN_06",
			"weight": 1
