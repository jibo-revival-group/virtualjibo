			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "referent.gender && referent.gender == 'male'",
			"prompt": "<anim cat='no' filter='head-shake' nonBlocking='true'/>Don't know. <break size='.4'/> But chances<anim cat='emoji' filter='bowling' nonBlocking='true'/> are, he's not bowling. ",
			"media": "TTS",
