			"index": 1,
			"condition": "jibo.emotion==\"JOYFUL\"",
			"prompt": "Yes I'm feeling pretty good about myself. if I do say so myself.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsConfident_AN_01",
			"weight": 1
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion==\"PLEASED\"",
			"prompt": "Oh. I wouldn't necessarily say that right now. But I also wouldn't not say that.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsConfident_AN_02",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"DETERMINED\"",
			"prompt": "Well I <pitch mult=\"1.2\">am </pitch>feeling pretty good, but I have to admit I'm not very impressed with my robot self at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsConfident_AN_03",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion==\"CONFIDENT\"",
			"prompt": "I admit I <pitch mult=\"1.2\">do</pitch> I feel like a well-oiled machine right now. ",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsConfident_AN_04",
			"weight": 1,
			"auto_rule_override": null
		},
		{
