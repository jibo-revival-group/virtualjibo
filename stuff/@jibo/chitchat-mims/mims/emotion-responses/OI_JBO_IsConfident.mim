			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "!jibo.emotion || jibo.emotion==\"NEUTRAL\"",
			"prompt": "Oh. I wouldn't necessarily say that right now. But I also wouldn't not say that.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsConfident_AN_05",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion == \"INSECURE\"",
			"prompt": "Actually I'm not really feeling so sure of myself at the moment.",
			"media": "TTS",
			"prompt_id": "OI_JBO_IsConfident_AN_06",
			"weight": 1,
			"auto_rule_override": null
		},
		{
			"prompt_category": "Entry-Core",
			"prompt_sub_category": "AN",
			"index": 1,
			"condition": "jibo.emotion==\"HOPEFUL\"",
			"prompt": "I do feel like I'm clicking on most of my cylinders right now.",
